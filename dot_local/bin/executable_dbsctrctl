GATES = (
    "domain", "behavior", "spec", "contract", "test_driven_implementation",
    "refactor", "review_integrate", "release", "deploy", "operate", "maintain_retire",
)
ARTIFACTS = ("README", "BACKLOG", "CHANGELOG")
SECRET_NAMES = ("credentials", "credentials.json", "id_rsa", "private_key", "password")
MANDATORY_GATES = set(GATES[:6]) | {"review_integrate"}
RISK_RANK = {"routine": 0, "elevated": 1, "critical": 2}
CURRENT_METHOD_REVISION = "3.19"
REVIEW_START_MS = 1783814400000
REVIEW_SCAN_HARD = 64 * 1024
HISTORY_SCAN_HARD = 256 * 1024
REVIEW_MAX_LIMIT = 100
REVIEW_RETENTION_SECONDS = 90 * 24 * 60 * 60
REVIEW_DORMANT_MS = 7 * 24 * 60 * 60 * 1000
REVIEW_LEDGER_SCHEMA = 1
OPAQUE_ID = re.compile(r"[A-Za-z0-9][A-Za-z0-9._-]{0,127}")
INSPECT_RESPONSE_HARD = 128 * 1024
INSPECT_ENV = {**os.environ, "GIT_OPTIONAL_LOCKS": "0", "GIT_NO_REPLACE_OBJECTS": "1"}
EVIDENCE_RAW_CAP = 1024 * 1024
EVIDENCE_SIDECAR_CAP = 256 * 1024
SECRET_OPTION = re.compile(r"(?:pass(?:word)?|secret|token|key|credential|auth(?:orization)?|cookie)", re.I)
SECRET_VALUE = re.compile(r"(?:op://|-----BEGIN [A-Z ]*PRIVATE KEY-----|\b(?:gh[pousr]_|AKIA)[A-Za-z0-9_=-]{16,}|\beyJ[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}|\bBearer\s+\S+|\b(?:authorization|password|secret|token|api[_-]?key)\s*[:=]\s*\S+|\w+://[^\s/@:]+:[^\s/@]+@)", re.I)
HIGH_ENTROPY = re.compile(r"(?<![A-Za-z0-9_-])[A-Za-z0-9_-]{32,}(?![A-Za-z0-9_-])")
SAFE_EVIDENCE_LINE = re.compile(r"(?:ok|pass(?:ed)?|success|succeeded|\d+ (?:passed|failed)(?:, \d+ skipped)?)", re.I)


def fail(message):
    raise RuntimeError(message)


def git(root, *args, check=True):
    result = subprocess.run(["git", *args], cwd=root, text=True, capture_output=True)
    if check and result.returncode:
        fail(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result


def git_read(root, *args, check=True):
    result = subprocess.run(
        ["git", *args], cwd=root, text=True, capture_output=True,
        env={**os.environ, "GIT_OPTIONAL_LOCKS": "0"},
    )
    if check and result.returncode:
        fail(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result


def inspect_git(root, *args, check=True):
    result = subprocess.run(["git", *args], cwd=root, text=True, capture_output=True, env=INSPECT_ENV)
    if check and result.returncode:
        fail(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result


def now():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def root_dir():
    result = subprocess.run(["git", "rev-parse", "--show-toplevel"], text=True, capture_output=True)
    if result.returncode:
        fail("not inside a Git repository")
    return Path(result.stdout.strip())


def git_dir(root):
    path = Path(git(root, "rev-parse", "--git-dir").stdout.strip())
    return path if path.is_absolute() else root / path


def common_git_dir(root):
    path = Path(git(root, "rev-parse", "--git-common-dir").stdout.strip())
    return path if path.is_absolute() else root / path


def worktree_id(root):
    return hashlib.sha256(str(root.resolve()).encode()).hexdigest()[:16]


def cycle_dir(root):
    return common_git_dir(root) / "dbsctr"


def active_path(root):
    return cycle_dir(root) / "worktrees" / worktree_id(root) / "active"


def legacy_cycle_dir(root):
    return git_dir(root) / "dbsctr"


def atomic_json(path, value):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False, encoding="utf-8") as handle:
        json.dump(value, handle, sort_keys=True, indent=2)
        handle.write("\n")
        temp = handle.name
    os.replace(temp, path)


def private_json(path, value):
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(path.parent, 0o700)
    descriptor, temporary = tempfile.mkstemp(dir=path.parent)
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            json.dump(value, handle, sort_keys=True, separators=(",", ":"))
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary, path)
        with contextlib.suppress(OSError):
            descriptor = os.open(path.parent, os.O_RDONLY)
            try:
                os.fsync(descriptor)
            finally:
                os.close(descriptor)
    finally:
        Path(temporary).unlink(missing_ok=True)


def fsync_directory(path):
    descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def review_root(value=None):
    return Path(value).expanduser() if value else Path.home() / ".local/state/dbsctr"


def review_unsafe(value):
    text = json.dumps(value, ensure_ascii=False) if not isinstance(value, str) else value
    return (SECRET_VALUE.search(text) or HIGH_ENTROPY.search(text) or
            re.search(r"\b[\w.+-]+@[\w.-]+\.[A-Za-z]{2,}\b", text) or
            re.search(r"\b(?:https?|ftp)://", text, re.I) or
            re.search(r"(?<![A-Za-z0-9._~-])(?:~|/)[^\s`)'\"\]}]+", text))


def review_digest(candidates, snapshot, session_ceiling=None, part_ceiling=None, database_digest=None):
    candidates = [{key: value for key, value in candidate.items() if not key.startswith("_")}
                  if isinstance(candidate, dict) else candidate for candidate in candidates]
    return hashlib.sha256(json.dumps({"candidates": candidates, "snapshot": snapshot,
                                      "session_ceiling": session_ceiling, "part_ceiling": part_ceiling,
                                      "database_digest": database_digest},
                                     separators=(",", ":"), sort_keys=True).encode()).hexdigest()


def session_id_digest(session_id):
    return hashlib.sha256(b"dbsctr-review-root\0" + session_id.encode()).hexdigest()


def review_lock(root):
    path = root / "reviews" / ".lock"
    if path.parent.is_symlink():
        fail("private review directory is unsafe")
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(path.parent, 0o700)
    private_path(path.parent, stat.S_IFDIR, 0o700, "review directory")
    flags = os.O_RDWR | os.O_CREAT | os.O_APPEND | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags, 0o600)
        details = os.fstat(descriptor)
        if stat.S_IFMT(details.st_mode) != stat.S_IFREG or details.st_uid != os.getuid():
            fail("private review lock is unsafe")
        os.fchmod(descriptor, 0o600)
        return os.fdopen(descriptor, "a+", encoding="utf-8")
    except Exception:
        if "descriptor" in locals():
            os.close(descriptor)
        raise


def excluded_review_family(connection, session, session_id):
    """Return the caller's connected parent/child family without exposing IDs."""
    sid = sqlite_name(connection, session, ("id",))
    parent = sqlite_name(connection, session, ("parentid", "parent")) if any(
        row[1].lower().replace("_", "") in ("parentid", "parent")
        for row in connection.execute(f'PRAGMA table_info("{session}")')
    ) else None
    if parent is None:
        return {session_id}
    return {str(row[0]) for row in connection.execute(f"""
        WITH RECURSIVE edges(source, target) AS (
            SELECT "{sid}", "{parent}" FROM "{session}" WHERE "{parent}" IS NOT NULL
            UNION SELECT "{parent}", "{sid}" FROM "{session}" WHERE "{parent}" IS NOT NULL
        ), excluded(session_id) AS (
            SELECT "{sid}" FROM "{session}" WHERE "{sid}" = ?
            UNION
            SELECT edges.target FROM edges JOIN excluded ON edges.source = excluded.session_id
        ) SELECT session_id FROM excluded
    """, (session_id,))} or {session_id}


def session_for_message(database_value, message_id):
    if not OPAQUE_ID.fullmatch(message_id):
        fail("invalid excluded message ID")
    database = Path(database_value).expanduser() if database_value else Path.home() / ".local/share/opencode/opencode.db"
    if not database.is_file():
        fail("OpenCode database is missing")
    try:
        connection = sqlite3.connect(f"file:{database}?mode=ro", uri=True)
        tables = {row[0].lower(): row[0] for row in connection.execute("SELECT name FROM sqlite_master WHERE type='table'")}
        if "message" not in tables:
            fail("OpenCode database lacks required message table")
        message = tables["message"]
        mid = sqlite_name(connection, message, ("id",))
        session = sqlite_name(connection, message, ("sessionid",))
        row = connection.execute(f'SELECT "{session}" FROM "{message}" WHERE "{mid}" = ?', (message_id,)).fetchone()
        if row is None or not isinstance(row[0], str) or not OPAQUE_ID.fullmatch(row[0]):
            fail("OpenCode message has no valid session")
        return row[0]
    except sqlite3.Error as error:
        fail(f"cannot read OpenCode database: {error}")
    finally:
        if 'connection' in locals():
            connection.close()


def historical_excluded_family(database_value, session_id, message_id=None):
    if session_id is None and message_id is None:
        return set()
    if session_id is not None and not OPAQUE_ID.fullmatch(session_id):
        fail("invalid excluded session ID")
    database = Path(database_value).expanduser() if database_value else Path.home() / ".local/share/opencode/opencode.db"
    if not database.is_file():
        fail("OpenCode database is missing")
    try:
        connection = sqlite3.connect(f"file:{database}?mode=ro", uri=True)
        tables = {row[0].lower(): row[0] for row in connection.execute("SELECT name FROM sqlite_master WHERE type='table'")}
        if "session" not in tables:
            fail("OpenCode database lacks required session table")
        roots = {value for value in (session_id, session_for_message(database_value, message_id)
                                     if message_id is not None else None) if value is not None}
        return set().union(*(excluded_review_family(connection, tables["session"], value) for value in roots))
    except sqlite3.Error as error:
        fail(f"cannot read OpenCode database: {error}")
    finally:
        if 'connection' in locals():
            connection.close()


def history_dir(root, name="", create=False):
    path = root / "reviews" / "history" / name
    if create:
        path.mkdir(parents=True, exist_ok=True, mode=0o700)
        os.chmod(path, 0o700)
    return path


def history_id(value, name="history ID"):
    if not isinstance(value, str) or not OPAQUE_ID.fullmatch(value):
        fail(f"invalid {name}")
    return value


def history_digest(value, name="digest"):
    if not isinstance(value, str) or not re.fullmatch(r"[0-9a-f]{64}", value):
        fail(f"invalid history {name}")
    return value


def ledger_path(root):
    return root / "reviews" / "ledger.sqlite3"


def ledger_exists(root):
    path = ledger_path(root)
    if path.exists() or path.is_symlink():
        private_path(path.parent, stat.S_IFDIR, 0o700, "review directory")
        private_path(path, stat.S_IFREG, 0o600, "review ledger")
    return path.is_file()


def private_path(path, kind, mode, name):
    try:
        details = path.lstat()
    except OSError as error:
        fail(f"cannot inspect private {name}: {error}")
    if stat.S_IFMT(details.st_mode) != kind or details.st_uid != os.getuid() or stat.S_IMODE(details.st_mode) != mode:
        fail(f"private {name} is unsafe")
    return path


def ledger_connection(root, write=False, path=None):
    path = path or ledger_path(root)
    private_path(path.parent, stat.S_IFDIR, 0o700, "ledger directory")
    private_path(path, stat.S_IFREG, 0o600, "review ledger")
    try:
        connection = sqlite3.connect(str(path) if write else f"file:{path}?mode=ro", uri=not write)
        connection.execute("PRAGMA foreign_keys=ON")
        connection.execute("PRAGMA busy_timeout=5000")
        if write:
            connection.execute("PRAGMA synchronous=FULL")
            connection.execute("PRAGMA journal_mode=DELETE")
        row = connection.execute("SELECT value FROM ledger_meta WHERE key='schema_version'").fetchone()
        if row != (str(REVIEW_LEDGER_SCHEMA),):
            fail("private review ledger has an unsupported schema")
        ledger_integrity(connection)
        return connection
    except (sqlite3.Error, RuntimeError):
        if "connection" in locals():
            connection.close()
        raise


def ledger_schema(connection):
    connection.executescript("""
        CREATE TABLE ledger_meta (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        ) WITHOUT ROWID;
        CREATE TABLE review_reports (
            report_id TEXT PRIMARY KEY,
            reviewed_at INTEGER NOT NULL,
            payload TEXT NOT NULL
        ) WITHOUT ROWID;
        CREATE TABLE review_report_sessions (
            report_id TEXT NOT NULL REFERENCES review_reports(report_id) ON DELETE CASCADE,
            position INTEGER NOT NULL,
            session_id TEXT NOT NULL,
            PRIMARY KEY (report_id, position),
            UNIQUE (report_id, session_id)
        ) WITHOUT ROWID;
        CREATE TABLE review_report_cycles (
            report_id TEXT NOT NULL REFERENCES review_reports(report_id) ON DELETE CASCADE,
            position INTEGER NOT NULL,
            cycle_id TEXT NOT NULL,
            PRIMARY KEY (report_id, position),
            UNIQUE (report_id, cycle_id)
        ) WITHOUT ROWID;
        CREATE TABLE review_tombstones (
            kind TEXT NOT NULL CHECK (kind IN ('session', 'cycle', 'forgotten_session')),
            item_id TEXT NOT NULL,
            timestamp INTEGER NOT NULL,
            PRIMARY KEY (kind, item_id)
        ) WITHOUT ROWID;
        CREATE TABLE history_evidence (
            session_id TEXT PRIMARY KEY,
            completed_at INTEGER NOT NULL,
            payload TEXT NOT NULL
        ) WITHOUT ROWID;
        CREATE TABLE history_reports (
            report_id TEXT PRIMARY KEY,
            kind TEXT NOT NULL CHECK (kind IN ('report', 'cohort')),
            payload TEXT NOT NULL
        ) WITHOUT ROWID;
        CREATE TABLE history_report_members (
            report_id TEXT NOT NULL REFERENCES history_reports(report_id) ON DELETE CASCADE,
            position INTEGER NOT NULL,
            session_id TEXT NOT NULL,
            PRIMARY KEY (report_id, position),
            UNIQUE (report_id, session_id)
        ) WITHOUT ROWID;
        CREATE TABLE ledger_entries (
            scope TEXT NOT NULL CHECK (scope IN ('operational', 'history')),
            report_id TEXT NOT NULL,
            category TEXT NOT NULL CHECK (category IN ('finding', 'scorecard', 'trend', 'proposal', 'caveat')),
            position INTEGER NOT NULL,
            text TEXT NOT NULL,
            PRIMARY KEY (scope, report_id, category, position)
        ) WITHOUT ROWID;
    """)
    connection.execute("INSERT INTO ledger_meta VALUES ('schema_version', ?)", (str(REVIEW_LEDGER_SCHEMA),))


def ledger_integrity(connection):
    if connection.execute("PRAGMA integrity_check").fetchone() != ("ok",):
        fail("private review ledger integrity check failed")
    if connection.execute("PRAGMA foreign_key_check").fetchone() is not None:
        fail("private review ledger foreign-key check failed")
    ledger_semantic_integrity(connection)


def ledger_semantic_integrity(connection):
    meta = dict(connection.execute("SELECT key, value FROM ledger_meta"))
    if (set(meta) - {"schema_version", "migration_digest", "pending_forget_cleanup"}
            or meta.get("schema_version") != str(REVIEW_LEDGER_SCHEMA)
            or "migration_digest" in meta and not re.fullmatch(r"[0-9a-f]{64}", meta["migration_digest"])
            or "pending_forget_cleanup" in meta
            and not re.fullmatch(r"\.forget-[0-9a-f]{32}", meta["pending_forget_cleanup"])):
        fail("private review ledger metadata is invalid")
    names = {"session": "sessions", "cycle": "cycles", "forgotten_session": "forgotten_sessions"}
    tombstones = {"schema_version": 1, "sessions": {}, "cycles": {}, "forgotten_sessions": {}}
    for kind, item_id, timestamp in connection.execute(
            "SELECT kind, item_id, timestamp FROM review_tombstones"):
        if kind not in names:
            fail("private review ledger contains an invalid tombstone")
        tombstones[names[kind]][item_id] = timestamp
    for values in (tombstones["sessions"], tombstones["cycles"], tombstones["forgotten_sessions"]):
        if not all(isinstance(key, str) and OPAQUE_ID.fullmatch(key) and isinstance(timestamp, int)
                   and timestamp >= REVIEW_START_MS for key, timestamp in values.items()):
            fail("private review ledger contains an invalid tombstone")
    expected_entries = set()
    categories = {"findings": "finding", "scorecards": "scorecard", "trends": "trend",
                  "proposals": "proposal", "caveats": "caveat"}
    for report_id, timestamp, payload in connection.execute(
            "SELECT report_id, reviewed_at, payload FROM review_reports"):
        report, _ = validate_review_report(json.loads(payload, object_pairs_hook=no_duplicate_keys),
                                           f"{report_id}.json", timestamp)
        sessions = [row[0] for row in connection.execute(
            "SELECT session_id FROM review_report_sessions WHERE report_id=? ORDER BY position", (report_id,))]
        cycles = [row[0] for row in connection.execute(
            "SELECT cycle_id FROM review_report_cycles WHERE report_id=? ORDER BY position", (report_id,))]
        if sessions != report["session_ids"] or cycles != report.get("cycle_ids", []):
            fail("private review ledger report membership mismatch")
        expected_entries.update(("operational", report_id, category, position, text)
                                for field, category in categories.items()
                                for position, text in enumerate(report.get(field, [])))
    for session_id, completed_at, payload in connection.execute(
            "SELECT session_id, completed_at, payload FROM history_evidence"):
        evidence = validate_history_evidence(json.loads(payload, object_pairs_hook=no_duplicate_keys))
        if evidence["session_id"] != session_id or int(evidence["completed_at"]) != completed_at:
            fail("private review ledger history evidence mismatch")
    for report_id, _, payload in connection.execute("SELECT report_id, kind, payload FROM history_reports"):
        report = validate_history_report(json.loads(payload, object_pairs_hook=no_duplicate_keys))
        members = [row[0] for row in connection.execute(
            "SELECT session_id FROM history_report_members WHERE report_id=? ORDER BY position", (report_id,))]
        if report["report_id"] != report_id or members != report["cohort"]:
            fail("private review ledger history membership mismatch")
        expected_entries.update(("history", report_id, category, position, text)
                                for field, category in categories.items()
                                for position, text in enumerate(report.get(field, [])))
    actual_entries = set(connection.execute(
        "SELECT scope, report_id, category, position, text FROM ledger_entries"))
    if actual_entries != expected_entries:
        fail("private review ledger entry mismatch")


def legacy_review_exists(root):
    directory = root / "reviews"
    if not directory.is_dir():
        return False
    history = directory / "history"
    return any(directory.glob("*.json")) or history.is_dir() and any(history.rglob("*.json"))


def create_empty_ledger(root):
    directory = root / "reviews"
    directory.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(directory, 0o700)
    descriptor, temporary = tempfile.mkstemp(prefix=".ledger-", suffix=".sqlite3", dir=directory)
    os.close(descriptor)
    temporary = Path(temporary)
    try:
        os.chmod(temporary, 0o600)
        connection = sqlite3.connect(temporary)
        connection.execute("PRAGMA foreign_keys=ON")
        connection.execute("PRAGMA synchronous=FULL")
        ledger_schema(connection)
        connection.commit()
        ledger_integrity(connection)
        connection.close()
        os.replace(temporary, ledger_path(root))
        os.chmod(ledger_path(root), 0o600)
    finally:
        temporary.unlink(missing_ok=True)


def ensure_ledger_for_write(root):
    if not ledger_exists(root):
        if legacy_review_exists(root):
            fail("legacy private review state requires review-migrate")
        create_empty_ledger(root)
    connection = ledger_connection(root, write=True)
    recover_forget_state(root, connection)
    return connection


def ledger_payload(value):
    return json.dumps(value, sort_keys=True, separators=(",", ":"), ensure_ascii=True)


def ledger_entries(connection, scope, report_id, report):
    names = {"findings": "finding", "scorecards": "scorecard", "trends": "trend",
             "proposals": "proposal", "caveats": "caveat"}
    connection.execute("DELETE FROM ledger_entries WHERE scope=? AND report_id=?", (scope, report_id))
    for field, category in names.items():
        connection.executemany(
            "INSERT INTO ledger_entries VALUES (?, ?, ?, ?, ?)",
            ((scope, report_id, category, position, text) for position, text in enumerate(report.get(field, []))),
        )


def ledger_put_review_report(connection, report_id, report):
    connection.execute("INSERT OR REPLACE INTO review_reports VALUES (?, ?, ?)",
                       (report_id, report["reviewed_at"], ledger_payload(report)))
    connection.execute("DELETE FROM review_report_sessions WHERE report_id=?", (report_id,))
    connection.execute("DELETE FROM review_report_cycles WHERE report_id=?", (report_id,))
    connection.executemany("INSERT INTO review_report_sessions VALUES (?, ?, ?)",
                           ((report_id, position, value) for position, value in enumerate(report["session_ids"])))
    connection.executemany("INSERT INTO review_report_cycles VALUES (?, ?, ?)",
                           ((report_id, position, value) for position, value in enumerate(report.get("cycle_ids", []))))
    ledger_entries(connection, "operational", report_id, report)


def ledger_put_history_evidence(connection, evidence):
    connection.execute("INSERT OR REPLACE INTO history_evidence VALUES (?, ?, ?)",
                       (evidence["session_id"], int(evidence["completed_at"]), ledger_payload(evidence)))


def ledger_put_history_report(connection, kind, report):
    report_id = report["report_id"]
    connection.execute("INSERT OR REPLACE INTO history_reports VALUES (?, ?, ?)",
                       (report_id, kind, ledger_payload(report)))
    connection.execute("DELETE FROM history_report_members WHERE report_id=?", (report_id,))
    connection.executemany("INSERT INTO history_report_members VALUES (?, ?, ?)",
                           ((report_id, position, value) for position, value in enumerate(report["cohort"])))
    ledger_entries(connection, "history", report_id, report)


def ledger_content(connection):
    tombstones = {"schema_version": 1, "sessions": {}, "cycles": {}, "forgotten_sessions": {}}
    names = {"session": "sessions", "cycle": "cycles", "forgotten_session": "forgotten_sessions"}
    for kind, item_id, timestamp in connection.execute(
            "SELECT kind, item_id, timestamp FROM review_tombstones ORDER BY kind, item_id"):
        tombstones[names[kind]][item_id] = timestamp
    def payloads(query):
        return [(key, json.loads(payload, object_pairs_hook=no_duplicate_keys))
                for key, payload in connection.execute(query)]
    return {
        "index": tombstones,
        "review_reports": payloads("SELECT report_id, payload FROM review_reports ORDER BY report_id"),
        "history_evidence": [value for _, value in payloads(
            "SELECT session_id, payload FROM history_evidence ORDER BY session_id")],
        "history_reports": payloads(
            "SELECT report_id, payload FROM history_reports WHERE kind='report' ORDER BY report_id"),
        "history_cohorts": payloads(
            "SELECT report_id, payload FROM history_reports WHERE kind='cohort' ORDER BY report_id"),
    }


def content_digest(value):
    return hashlib.sha256(ledger_payload(value).encode()).hexdigest()


def backup_directory(root):
    directory = root / "reviews" / "backups"
    private_path(directory.parent, stat.S_IFDIR, 0o700, "review directory")
    if directory.is_symlink():
        fail("private review backup directory is unsafe")
    directory.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(directory, 0o700)
    private_path(directory, stat.S_IFDIR, 0o700, "backup directory")
    return directory


def file_digest(path):
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def create_ledger_backup(root, prefix="ledger"):
    if not ledger_exists(root):
        fail("private review ledger is missing")
    name = f"{int(time.time() * 1000)}-{prefix}-{uuid.uuid4().hex[:8]}.sqlite3"
    target = backup_directory(root) / name
    source = ledger_connection(root)
    destination = sqlite3.connect(target)
    try:
        source.backup(destination)
        destination.commit()
    except sqlite3.Error as error:
        target.unlink(missing_ok=True)
        fail(f"cannot back up private review ledger: {error}")
    finally:
        source.close()
        destination.close()
    os.chmod(target, 0o600)
    with ledger_connection(root, path=target) as check:
        ledger_integrity(check)
    return name, file_digest(target)


def backup_legacy_json(root):
    reviews = root / "reviews"
    files = legacy_json_files(root)
    name = f"{int(time.time() * 1000)}-legacy-{uuid.uuid4().hex[:8]}"
    target = backup_directory(root) / name
    target.mkdir(mode=0o700)
    digest = hashlib.sha256()
    for source in files:
        if source.is_symlink() or not source.is_file():
            fail("legacy private review state contains an unsafe file")
        relative = source.relative_to(reviews)
        destination = target / relative
        destination.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
        os.chmod(destination.parent, 0o700)
        shutil.copyfile(source, destination)
        os.chmod(destination, 0o600)
        digest.update(relative.as_posix().encode() + b"\0" + source.read_bytes())
    return name, digest.hexdigest()


def legacy_json_files(root):
    reviews = root / "reviews"
    files = sorted([*reviews.glob("*.json"), *((reviews / "history").rglob("*.json")
                                               if (reviews / "history").is_dir() else [])])
    if any(path.is_symlink() or not path.is_file() for path in files):
        fail("legacy private review state contains an unsafe file")
    return files


def stage_pre_forget_state(root, name=None):
    reviews = root / "reviews"
    quarantine = reviews / (name or f".forget-{uuid.uuid4().hex}")
    quarantine.mkdir(mode=0o700)
    moved = []
    try:
        for source in legacy_json_files(root):
            destination = quarantine / "legacy" / source.relative_to(reviews)
            destination.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            os.chmod(destination.parent, 0o700)
            os.replace(source, destination)
            moved.append((source, destination))
        backups = reviews / "backups"
        if backups.is_symlink():
            fail("private review backup directory is unsafe")
        if backups.is_dir():
            destination = quarantine / "backups"
            os.replace(backups, destination)
            moved.append((backups, destination))
        fsync_directory(reviews)
        fsync_directory(quarantine)
        return quarantine, moved
    except Exception:
        restore_staged_forget(quarantine, moved)
        raise


def restore_staged_forget(quarantine, moved):
    for source, destination in reversed(moved):
        if destination.exists():
            source.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            os.replace(destination, source)
    shutil.rmtree(quarantine, ignore_errors=True)
    fsync_directory(quarantine.parent)


def discard_staged_forget(quarantine):
    shutil.rmtree(quarantine)
    fsync_directory(quarantine.parent)


def restore_forget_quarantine(quarantine):
    reviews = quarantine.parent
    moved = []
    legacy = quarantine / "legacy"
    if legacy.is_dir():
        for destination in sorted(legacy.rglob("*.json")):
            source = reviews / destination.relative_to(legacy)
            if source.exists() or source.is_symlink():
                fail("cannot recover staged private review state")
            moved.append((source, destination))
    staged_backups = quarantine / "backups"
    if staged_backups.is_dir():
        source = reviews / "backups"
        if source.exists() or source.is_symlink():
            fail("cannot recover staged private review backups")
        moved.append((source, staged_backups))
    restore_staged_forget(quarantine, moved)


def recover_forget_state(root, connection):
    reviews = root / "reviews"
    row = connection.execute("SELECT value FROM ledger_meta WHERE key='pending_forget_cleanup'").fetchone()
    pending = row[0] if row else None
    quarantines = sorted(reviews.glob(".forget-*")) if reviews.is_dir() else []
    for quarantine in quarantines:
        private_path(quarantine, stat.S_IFDIR, 0o700, "forget quarantine")
        if quarantine.name == pending:
            discard_staged_forget(quarantine)
        else:
            restore_forget_quarantine(quarantine)
    if pending is not None:
        connection.execute("DELETE FROM ledger_meta WHERE key='pending_forget_cleanup'")
        connection.commit()


def require_review_lock_safe(root):
    directory = root / "reviews"
    if (directory.is_dir() and (any(directory.glob("*.json")) or (directory / "history").exists()
                                or ledger_exists(root)) and not (directory / ".lock").is_file()):
        fail("retained review state is missing its lock")


@contextlib.contextmanager
def existing_review_lock(root, exclusive=False):
    path = root / "reviews" / ".lock"
    if path.is_file():
        with path.open("r", encoding="utf-8") as handle:
            fcntl.flock(handle, fcntl.LOCK_EX if exclusive else fcntl.LOCK_SH)
            yield
    else:
        yield


def exclusive_json(path, value):
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = None
    try:
        with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False, encoding="utf-8") as handle:
            temp = Path(handle.name)
            json.dump(value, handle, sort_keys=True, indent=2)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        try:
            os.link(temp, path)
        except FileExistsError:
            fail(f"cycle record already exists: {path.stem}")
    finally:
        if temp:
            temp.unlink(missing_ok=True)


def status_paths(root, read_only=False):
    env = {**os.environ, "GIT_OPTIONAL_LOCKS": "0"} if read_only else None
    result = subprocess.run(
        ["git", "status", "--porcelain=v1", "-z"], cwd=root, capture_output=True, env=env
    )
    if result.returncode:
        fail(result.stderr.decode(errors="replace").strip() or "git status failed")
    entries = result.stdout.split(b"\0")
    paths = []
    index = 0
    while index < len(entries):
        entry = entries[index]
        index += 1
        if not entry:
            continue
        paths.append(os.fsdecode(entry[3:]))
        if entry[0:1] in (b"R", b"C") or entry[1:2] in (b"R", b"C"):
            if index < len(entries) and entries[index]:
                paths.append(os.fsdecode(entries[index]))
                index += 1
    return paths


def branch(root):
    value = git(root, "symbolic-ref", "--quiet", "--short", "HEAD", check=False)
    return value.stdout.strip() or None


def upstream(root):
    value = git(root, "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}", check=False)
    return value.stdout.strip() or None


def ahead(root, upstream_name):
    if not upstream_name:
        return []
    return git(root, "rev-list", f"{upstream_name}..HEAD").stdout.splitlines()


def remote_destination(root, upstream_name):
    remote, _ = remote_for_upstream(root, upstream_name)
    if not remote:
        return {"name": None, "push_url": None}
    url = git(root, "remote", "get-url", "--push", remote, check=False)
    return {"name": remote, "push_url": url.stdout.strip() or None}


def remote_for_upstream(root, upstream_name):
    if not upstream_name:
        return None, None
    remotes = git(root, "remote").stdout.splitlines()
    matches = [name for name in remotes if upstream_name.startswith(name + "/")]
    if not matches:
        return None, None
    remote = max(matches, key=len)
    return remote, upstream_name[len(remote) + 1:]


def configured_upstream(root):
    current = branch(root)
    if not current:
        return None, None
    remote = git(root, "config", "--get", f"branch.{current}.remote", check=False).stdout.strip()
    merge = git(root, "config", "--get", f"branch.{current}.merge", check=False).stdout.strip()
    if not remote or not merge.startswith("refs/heads/"):
        return None, None
    return remote, merge.removeprefix("refs/heads/")


def load(root):
    active = active_path(root)
    records = cycle_dir(root) / "cycles"
    if not active.exists():
        active = legacy_cycle_dir(root) / "active"
        records = legacy_cycle_dir(root)
    if not active.exists():
        fail("no active DBSCTR cycle")
    cycle_id = active.read_text(encoding="utf-8").strip()
    path = records / f"{cycle_id}.json"
    if not cycle_id or not path.is_file():
        fail("active DBSCTR record is missing")
    record = json.loads(path.read_text(encoding="utf-8"))
    if "schema_version" in record and record["schema_version"] not in (1, 2, 3):
        fail(f"unsupported Cycle Record schema: {record['schema_version']}")
    return path, record


def save(path, record):
    atomic_json(path, record)


def require_active(record):
    if record["state"] != "active":
        fail(f"cycle is {record['state']}, not active")


def require_pushable(record):
    if record["state"] not in ("active", "finalizing"):
        fail(f"cycle is {record['state']}, not pushable")


def is_v32(record):
    return record.get("schema_version") in (1, 2, 3)


@contextlib.contextmanager
def target_lock(root, record):
    target = record.get("delivery", {}).get("lock_id")
    if not target:
        target = delivery_lock_id(record["git"]["remote"].get("push_url"), record["git"]["upstream"])
    path = cycle_dir(root) / "locks" / f"{target}.lock"
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a+", encoding="utf-8") as handle:
        try:
            fcntl.flock(handle, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            fail("delivery target is locked by another DBSCTR cycle")
        yield


@contextlib.contextmanager
def evidence_lock(root, cycle_id):
    path = cycle_dir(root) / "locks" / f"evidence-{cycle_id}.lock"
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle, fcntl.LOCK_EX)
        yield


def delivery_lock_id(push_url, upstream_name=None, remote_branch=None):
    if remote_branch is None:
        remote_branch = upstream_name.partition("/")[2] if upstream_name else ""
    return hashlib.sha256(f"{push_url or 'no-remote'}\0{remote_branch}".encode()).hexdigest()[:24]


def no_duplicate_keys(pairs):
    value = {}
    for key, item in pairs:
        if key in value:
            fail(f"duplicate JSON key in applicability plan: {key}")
        value[key] = item
    return value


def read_plan(source):
    try:
        text = sys.stdin.read() if source == "-" else Path(source).read_text(encoding="utf-8")
        value = json.loads(text, object_pairs_hook=no_duplicate_keys)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read applicability plan: {error}")
    if not isinstance(value, dict):
        fail("applicability plan must be a JSON object")
    return value


def validate_plan(root, context, intent, plan):
    expected_profile = f"docs/specs/{context}/README.md"
    if plan.get("profile") != expected_profile:
        fail(f"Engineering Profile must be {expected_profile}")
    if status := git(root, "status", "--porcelain=v1", "--", expected_profile).stdout.strip():
        fail(f"Engineering Profile must be tracked and committed: {status}")
    blob = git(root, "rev-parse", f"HEAD:{expected_profile}", check=False).stdout.strip()
    if not re.fullmatch(r"[0-9a-f]+", blob) or git(
        root, "cat-file", "-e", f"{blob}^{{blob}}", check=False
    ).returncode:
        fail("Engineering Profile is not committed at HEAD")
    gates = plan.get("gates")
    if not isinstance(gates, dict) or set(gates) != set(GATES):
        fail("applicability plan must define every gate exactly once")
    normalized = {}
    for name in GATES:
        item = gates[name]
        if not isinstance(item, dict) or item.get("applicability") not in ("required", "not_applicable"):
            fail(f"invalid applicability for gate: {name}")
        applicability = item["applicability"]
        if name in MANDATORY_GATES and applicability != "required":
            fail(f"gate is always required: {name}")
        normalized[name] = {"applicability": applicability}
        if applicability == "not_applicable":
            reason = item.get("reason")
            if not isinstance(reason, str) or not reason.strip():
                fail(f"not_applicable gate needs a reason: {name}")
            normalized[name].update({"result": "not_run", "reason": reason.strip()})
        else:
            normalized[name]["result"] = "pending"
    if intent == "release" and normalized["release"]["applicability"] != "required":
        fail("release delivery requires the release gate")
    if intent == "deploy" and normalized["deploy"]["applicability"] != "required":
        fail("deploy delivery requires the deploy gate")
    return expected_profile, blob, normalized


def disposed(gate):
    return (gate["applicability"] == "not_applicable" or gate["result"] == "passed"
            or gate["result"] in ("failed", "unavailable") and "exception" in gate)


def invalidate_later(record, gate_name):
    for name in GATES[GATES.index(gate_name) + 1:]:
        gate = record["gates"][name]
        if gate["applicability"] == "required" and gate["result"] == "passed":
            gate["result"] = "pending"
            gate.pop("evidence", None)
            gate.pop("exception", None)


def require_current_profile(root, record):
    if not is_v32(record):
        return
    profile = record["engineering_profile"]
    current = git(root, "rev-parse", f"HEAD:{profile['path']}", check=False).stdout.strip()
    if current != profile["blob"]:
        fail("Engineering Profile changed; update the applicability plan")


def apply_stricter_plan(root, record, plan):
    profile_path, profile_blob, gates = validate_plan(
        root, record["context"], record["delivery_intent"], plan
    )
    if profile_path != record["engineering_profile"]["path"]:
        fail("Engineering Profile path changed; start a new cycle")
    for name, new_gate in gates.items():
        if (record["gates"][name]["applicability"] == "required"
                and new_gate["applicability"] != "required"):
            fail(f"applicability plan cannot loosen gate: {name}")
    for name, new_gate in gates.items():
        old_gate = record["gates"][name]
        if old_gate["applicability"] == "not_applicable" and new_gate["applicability"] == "required":
            old_gate.update({"applicability": "required", "result": "pending"})
            old_gate.pop("reason", None)
            old_gate.pop("exception", None)
            invalidate_later(record, name)
    if profile_blob != record["engineering_profile"]["blob"]:
        record.setdefault("profile_history", []).append({
            "blob": record["engineering_profile"]["blob"], "replaced_at": now(),
        })
        record["engineering_profile"]["blob"] = profile_blob
    record["applicability_plan"] = {"profile": profile_path, "gates": {
        name: {key: value for key, value in gate.items() if key in ("applicability", "reason")}
        for name, gate in gates.items()
    }}


def artifact_check(record):
    reviews = record["artifact_reviews"]
    incomplete = [name for name in ARTIFACTS if reviews[name]["result"] == "pending"]
    if incomplete:
        fail("artifact reviews pending: " + ", ".join(incomplete))
    if not reviews["BACKLOG"]["reviewed_at"]:
        fail("BACKLOG review is incomplete")
    readme = reviews["README"]
    if readme["result"] == "unchanged" and not readme["reason"]:
        fail("README unchanged review requires a reason")
    if record["state"] in ("finalizing", "completed") and reviews["CHANGELOG"]["result"] == "pending":
        fail("CHANGELOG review is required when finalizing")


def completion_artifact_check(record):
    artifact_check(record)
    if record["artifact_reviews"]["CHANGELOG"]["result"] != "changed":
        fail("CHANGELOG must record the completed cycle before Final Push")
    changelog_path = record["artifact_reviews"]["CHANGELOG"].get("path")
    if not changelog_path:
        fail("changed CHANGELOG review needs its repository path")


def start_cycle(root, args, plan, created_by_dbsctr=False):
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]*", args.cycle_id):
        fail("cycle ID must be a simple filename")
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_-]*", args.context):
        fail("context must be a simple bounded-context name")
    directory = cycle_dir(root)
    active = active_path(root)
    if active.exists() or (legacy_cycle_dir(root) / "active").exists():
        fail("an active DBSCTR cycle already exists")
    record_path = directory / "cycles" / f"{args.cycle_id}.json"
    if record_path.exists():
        fail(f"cycle record already exists: {args.cycle_id}")
    dirty_paths = status_paths(root)
    if dirty_paths:
        fail("cycle must start with a clean worktree: " + ", ".join(dirty_paths))
    profile_path, profile_blob, gates = validate_plan(
        root, args.context, args.delivery_intent, plan
    )
    current_branch = branch(root)
    current_upstream = upstream(root)
    delivery_remote, delivery_branch = configured_upstream(root)
    record = {
        "method_revision": CURRENT_METHOD_REVISION, "schema_version": 3, "created_at": now(), "cycle_id": args.cycle_id,
        "context": args.context, "risk": args.risk, "delivery_intent": args.delivery_intent,
        "engineering_profile": {"path": profile_path, "blob": profile_blob},
        "applicability_plan": {"profile": profile_path, "gates": {
            name: {key: value for key, value in gate.items() if key in ("applicability", "reason")}
            for name, gate in gates.items()
        }},
        "git": {"head": git(root, "rev-parse", "HEAD").stdout.strip(), "branch": current_branch,
                "upstream": current_upstream, "dirty_paths": dirty_paths,
                "pre_cycle_ahead_commits": ahead(root, current_upstream),
                 "remote": remote_destination(root, current_upstream)},
        "worktree": {"id": worktree_id(root), "path": str(root.resolve()),
                     "git_dir": str(git_dir(root).resolve()), "branch": current_branch,
                     "base_commit": git(root, "rev-parse", "HEAD").stdout.strip(),
                     "created_by_dbsctr": created_by_dbsctr},
        "delivery": {"upstream": current_upstream, "remote": delivery_remote,
                     "branch": delivery_branch, "lock_id": delivery_lock_id(
            remote_destination(root, current_upstream).get("push_url"), remote_branch=delivery_branch
        )},
        "state": "active", "commits": [], "gates": gates, "evidence": {"version": 1, "items": {}},
        "artifact_reviews": {name: {"result": "pending", "reason": None, "reviewed_at": None}
                             for name in ARTIFACTS},
    }
    message_id = getattr(args, "opencode_message_id", None)
    session_id = (session_for_message(None, message_id) if message_id is not None
                  else getattr(args, "opencode_session_id", None))
    if session_id is not None:
        if (not OPAQUE_ID.fullmatch(session_id) or not getattr(args, "opencode_worktree", None)
                or not getattr(args, "opencode_directory", None)):
            fail("invalid OpenCode session ID")
        runtime_worktree = Path(args.opencode_worktree).resolve()
        runtime_directory = Path(args.opencode_directory).resolve()
        if not runtime_worktree.is_dir() or not runtime_directory.is_dir() or runtime_worktree not in runtime_directory.parents and runtime_directory != runtime_worktree:
            fail("invalid OpenCode runtime paths")
        record["runtime"] = {"opencode": {"session_ids": [session_id],
                                             "worktree": str(runtime_worktree),
                                             "directory": str(runtime_directory)}}
    elif getattr(args, "opencode_worktree", None) or getattr(args, "opencode_directory", None):
        fail("OpenCode runtime paths require a session ID")
    exclusive_json(record_path, record)
    try:
        active.parent.mkdir(parents=True, exist_ok=True)
        with open(active.with_suffix(".tmp"), "x", encoding="utf-8") as handle:
            handle.write(args.cycle_id + "\n")
        os.replace(active.with_suffix(".tmp"), active)
    except Exception:
        record_path.unlink(missing_ok=True)
        raise
    return record


def command_start(args):
    root = root_dir()
    record = start_cycle(root, args, read_plan(args.plan))
    print(record["cycle_id"])


def command_begin(args):
    source = root_dir()
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]*", args.cycle_id):
        fail("cycle ID must be a simple filename")
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_-]*", args.context):
        fail("context must be a simple bounded-context name")
    target = upstream(source)
    remote, remote_branch = configured_upstream(source)
    if not target or not remote or not remote_branch:
        fail("begin requires a configured remote upstream")
    source_record = {"path": str(source.resolve()), "branch": branch(source), "upstream": upstream(source),
                     "head": git(source, "rev-parse", "HEAD").stdout.strip(), "dirty_paths": status_paths(source),
                     "remote": remote_destination(source, upstream(source))}
    git(source, "fetch", remote, remote_branch)
    if ahead(source, target):
        fail("unknown commits are ahead of upstream; reconcile them before begin")
    branch_name = f"dbsctr/{args.context}/{args.cycle_id}"
    if git(source, "show-ref", "--verify", "--quiet", f"refs/heads/{branch_name}", check=False).returncode == 0:
        fail(f"cycle branch already exists: {branch_name}")
    common = common_git_dir(source).resolve()
    repo_id = f"{common.parent.name}-{hashlib.sha256(str(common).encode()).hexdigest()[:12]}"
    parent = Path(args.worktree_root).expanduser() if args.worktree_root else Path.home() / ".local/state/dbsctr/worktrees" / repo_id
    worktree = parent / args.cycle_id
    if worktree.exists():
        fail(f"cycle worktree already exists: {worktree}")
    parent.mkdir(parents=True, exist_ok=True)
    plan = read_plan(args.plan)
    git(source, "worktree", "add", "-b", branch_name, str(worktree), target)
    worktree = worktree.resolve()
    try:
        git(worktree, "branch", "--set-upstream-to", target, branch_name)
        if (source / ".dvc").exists() or (source / "dvc.yaml").exists():
            cache_result = subprocess.run(["dvc", "cache", "dir"], cwd=source, text=True, capture_output=True)
            if cache_result.returncode or not cache_result.stdout.strip():
                fail(cache_result.stderr.strip() or "cannot resolve source DVC cache")
            shared_cache = Path(cache_result.stdout.strip().splitlines()[-1]).expanduser()
            if not shared_cache.is_absolute():
                shared_cache = source / shared_cache
            shared_cache = shared_cache.resolve()
            result = subprocess.run(["dvc", "cache", "dir", "--local", str(shared_cache)],
                                    cwd=worktree, text=True, capture_output=True)
            if result.returncode:
                fail(result.stderr.strip() or "cannot configure linked DVC cache")
        record = start_cycle(worktree, args, plan, created_by_dbsctr=True)
        record["source"] = source_record
        save(cycle_dir(worktree) / "cycles" / f"{args.cycle_id}.json", record)
    except Exception:
        git(source, "worktree", "remove", str(worktree), check=False)
        git(source, "branch", "-D", branch_name, check=False)
        raise
    print(json.dumps({
        "cycle_id": record["cycle_id"], "branch": branch_name,
        "worktree": str(worktree), "upstream": target,
        "open": ["opencode", str(worktree)],
    }, sort_keys=True))


def command_cleanup(args):
    root = root_dir()
    path = cycle_dir(root) / "cycles" / f"{args.cycle_id}.json"
    if not path.is_file():
        fail(f"cycle record is missing: {args.cycle_id}")
    record = json.loads(path.read_text(encoding="utf-8"))
    if record.get("state") != "completed":
        fail("only a completed cycle can be cleaned up")
    if record.get("worktree", {}).get("created_by_dbsctr") is not True:
        fail("cleanup only removes DBSCTR-created worktrees")
    worktree = Path(record["worktree"]["path"])
    if worktree.resolve() == root.resolve():
        fail("run cleanup from another worktree")
    schema3 = record.get("schema_version") == 3
    if not worktree.is_dir() and not schema3:
        print("already removed " + str(worktree))
        return
    completed = datetime.fromisoformat(record["completed_at"].replace("Z", "+00:00"))
    if not args.now and datetime.now(timezone.utc) - completed < timedelta(hours=24):
        fail("successful worktrees are retained for 24 hours; use --now to remove earlier")
    if worktree.is_dir() and status_paths(worktree):
        fail("refusing to remove a dirty cycle worktree")
    if worktree.is_dir() and branch(worktree) != record["worktree"]["branch"]:
        fail("cycle worktree branch changed")
    recorded_commits = [entry["id"] for entry in record["commits"]]
    if worktree.is_dir() and recorded_commits and git(worktree, "rev-parse", "HEAD").stdout.strip() != recorded_commits[-1]:
        fail("cycle worktree HEAD changed")
    delivery = record.get("delivery", {})
    remote = delivery.get("remote")
    remote_branch = delivery.get("branch")
    if worktree.is_dir() and (not remote or not remote_branch):
        remote, remote_branch = remote_for_upstream(worktree, record["git"]["upstream"])
    expected = record["git"]["remote"]
    if worktree.is_dir() and expected != remote_destination(worktree, record["git"]["upstream"]):
        fail("remote push destination changed")
    if worktree.is_dir():
        git(worktree, "fetch", remote, remote_branch)
    target = record["git"]["upstream"]
    for entry in record["commits"]:
        if worktree.is_dir() and git(worktree, "merge-base", "--is-ancestor", entry["id"], target, check=False).returncode:
            fail("cycle commits are not all contained in the delivery target")
    branch_name = record["worktree"].get("branch")
    if worktree.is_dir():
        git(root, "worktree", "remove", str(worktree))
    if branch_name:
        git(root, "branch", "-d", branch_name, check=False)
    if schema3:
        evidence = cycle_dir(root) / "evidence" / args.cycle_id
        parked = evidence.with_name(evidence.name + ".cleanup")
        cleanup = record.get("cleanup")
        if cleanup:
            if cleanup.get("state") != "evidence_parked" or evidence.exists():
                fail("invalid evidence cleanup state")
        elif parked.exists():
            fail("untracked parked evidence directory")
        elif evidence.exists():
            os.replace(evidence, parked)
            record["cleanup"] = {"state": "evidence_parked", "parked_at": now()}
            save(path, record)
        else:
            record["cleanup"] = {"state": "evidence_parked", "parked_at": now()}
            save(path, record)
        if parked.exists():
            shutil.rmtree(parked)
        path.unlink()
    print("removed " + str(worktree))


def command_audit(args):
    root = root_dir()
    commit = git_read(root, "rev-parse", "--verify", f"{args.commit}^{{commit}}").stdout.strip()
    files = set(git_read(root, "ls-tree", "-r", "--name-only", commit).stdout.splitlines())
    contexts = {}
    for name in files:
        parts = PurePosixPath(name).parts
        if len(parts) == 4 and parts[:2] == ("docs", "specs") and parts[3] in (
            "README.md", "BACKLOG.md", "CHANGELOG.md"
        ):
            contexts.setdefault(parts[2], set()).add(parts[3])
    expected = {"README.md", "BACKLOG.md", "CHANGELOG.md"}
    findings = []
    inventory = []
    for context in sorted(contexts):
        present = contexts[context]
        missing = sorted(expected - present)
        inventory.append({"context": context, "present": sorted(present), "missing": missing})
        for artifact in missing:
            findings.append({
                "code": "missing_lifecycle_artifact", "severity": "medium", "context": context,
                "path": f"docs/specs/{context}/{artifact}",
            })
    graph_path = "graphify-out/GRAPH_REPORT.md"
    graph = {"present": graph_path in files, "built_from": None, "stale": None}
    if graph["present"]:
        report = git_read(root, "show", f"{commit}:{graph_path}").stdout
        match = re.search(r"Built from commit:\s*`([0-9a-f]+)`", report)
        object_format = git_read(root, "rev-parse", "--show-object-format").stdout.strip()
        expected_length = 64 if object_format == "sha256" else 40
        if match and len(match.group(1)) == expected_length:
            graph["built_from"] = match.group(1)
            resolved = git_read(root, "rev-parse", "--verify", f"{graph['built_from']}^{{commit}}", check=False)
            if resolved.returncode:
                findings.append({
                    "code": "unverified_graph_freshness", "severity": "medium", "path": graph_path,
                    "built_from": graph["built_from"],
                })
            else:
                graph["built_from"] = resolved.stdout.strip()
                graph["stale"] = graph["built_from"] != commit
                if graph["stale"]:
                    findings.append({
                        "code": "stale_graph", "severity": "low", "path": graph_path,
                        "built_from": graph["built_from"], "audited_commit": commit,
                    })
        else:
            findings.append({
                "code": "unverified_graph_freshness", "severity": "medium", "path": graph_path,
            })
    result = {
        "mode": "lifecycle_reconciliation_audit", "commit": commit,
        "dirty_overlay_excluded": status_paths(root, read_only=True), "contexts": inventory,
        "graph": graph, "findings": findings,
    }
    if args.json:
        print(json.dumps(result, sort_keys=True, separators=(",", ":")))
    else:
        print(f"{commit} contexts={len(inventory)} findings={len(findings)}")
        for finding in findings:
            print(f"{finding['severity']} {finding['code']} {finding['path']}")


def inspect_path(path, required=False):
    if path is None:
        if required:
            fail("--path is required for this inspect action")
        return None
    try:
        encoded = os.fsencode(path)
    except UnicodeEncodeError:
        fail("unsafe path")
    pure = PurePosixPath(path)
    if (not path or len(encoded) > 4096 or b"\0" in encoded or any(byte < 32 or byte == 127 for byte in encoded)
            or pure.is_absolute() or ".." in pure.parts or path.startswith("./")):
        fail("unsafe path")
    return path.rstrip("/")


def inspect_limit(value, default, hard, name):
    value = default if value is None else value
    if value < 1 or value > hard:
        fail(f"{name} must be between 1 and {hard}")
    return value


def inspect_object(root, commit, path):
    spec = commit if path is None else f"{commit}:{path}"
    kind = inspect_git(root, "cat-file", "-t", "--", spec, check=False)
    if kind.returncode or kind.stdout.strip() not in ("blob", "tree", "commit"):
        fail("path does not name a supported Git object at commit")
    object_id = inspect_git(root, "rev-parse", "--verify", "--end-of-options", spec).stdout.strip()
    return kind.stdout.strip(), object_id, spec


def inspect_blob_size(root, spec, strict=True):
    size = int(inspect_git(root, "cat-file", "-s", "--", spec).stdout)
    if size > 4 * 1024 * 1024:
        if strict:
            fail("blob exceeds 4194304 byte hard cap")
        return None
    return size


def inspect_text(root, spec, size):
    if size > 4 * 1024 * 1024:
        fail("blob exceeds 4194304 byte hard cap")
    data = subprocess.run(
        ["git", "cat-file", "blob", "--", spec], cwd=root, capture_output=True,
        env=INSPECT_ENV,
    )
    if data.returncode:
        fail(data.stderr.decode(errors="replace").strip() or "cannot read Git blob")
    return data.stdout


def inspect_emit(result):
    encoded = json.dumps(result, sort_keys=True, separators=(",", ":"), ensure_ascii=True).encode("utf-8")
    if len(encoded) > INSPECT_RESPONSE_HARD:
        fail("inspect response exceeds 131072 bytes")
    print(encoded.decode("utf-8"))


def inspect_page(result, key, items, cursor, limit):
    selected = items[cursor:cursor + limit]
    while selected:
        next_cursor = cursor + len(selected)
        result.update({key: selected, "truncated": next_cursor < len(items),
                       "continuation": {"cursor": next_cursor} if next_cursor < len(items) else None})
        if len(json.dumps(result, sort_keys=True, separators=(",", ":"), ensure_ascii=True).encode("utf-8")) <= INSPECT_RESPONSE_HARD:
            return
        selected.pop()
    result.update({key: [], "truncated": cursor < len(items),
                   "continuation": {"cursor": cursor} if cursor < len(items) else None})


def inspect_tree_rows(root, *args):
    with tempfile.TemporaryFile() as stderr:
        process = subprocess.Popen(["git", "ls-tree", "-z", *args], cwd=root, stdout=subprocess.PIPE,
                                   stderr=stderr, env=INSPECT_ENV)
        buffer = b""
        complete = False
        try:
            while block := process.stdout.read(4096):
                buffer += block
                while b"\0" in buffer:
                    row, buffer = buffer.split(b"\0", 1)
                    if row:
                        metadata, name = row.split(b"\t", 1)
                        yield metadata.decode("ascii").split(), os.fsdecode(name)
            complete = True
        finally:
            if not complete and process.poll() is None:
                process.terminate()
            process.wait()
            if complete and process.returncode:
                stderr.seek(0)
                fail(stderr.read(8192).decode(errors="replace").strip() or "cannot list Git tree")


def inspect_overlay(root):
    with tempfile.TemporaryFile() as stderr:
        process = subprocess.Popen(
            ["git", "status", "--porcelain=v1", "-z", "--untracked-files=all"], cwd=root,
            stdout=subprocess.PIPE, stderr=stderr, env=INSPECT_ENV,
        )
        paths, total, retained_bytes, rename = [], 0, 0, False

        def record_path(raw_path):
            nonlocal total, retained_bytes
            path = os.fsdecode(raw_path)
            total += 1
            size = len(json.dumps(path, ensure_ascii=True).encode("utf-8")) + 1
            if len(paths) < 100 and retained_bytes + size <= 64 * 1024:
                paths.append(path)
                retained_bytes += size

        buffer = b""
        while block := process.stdout.read(4096):
            buffer += block
            while b"\0" in buffer:
                record, buffer = buffer.split(b"\0", 1)
                if not record:
                    continue
                if rename:
                    record_path(record)
                    rename = False
                else:
                    status, raw_path = record[:2], record[3:]
                    rename = status[:1] in b"RC" or status[1:2] in b"RC"
                    record_path(raw_path)
        process.wait()
        if process.returncode:
            stderr.seek(0)
            fail(stderr.read(8192).decode(errors="replace").strip() or "cannot inspect dirty overlay")
    return paths, total, total > len(paths)


def inspect_utf8_page(data, offset, limit):
    try:
        data.decode("utf-8")
    except UnicodeDecodeError:
        return None, len(data)
    try:
        data[:offset].decode("utf-8")
    except UnicodeDecodeError:
        fail("offset is not a UTF-8 boundary")
    end = min(offset + limit, len(data))
    while end > offset:
        try:
            return data[offset:end].decode("utf-8"), end
        except UnicodeDecodeError as error:
            if error.reason != "unexpected end of data":
                fail("offset is not a UTF-8 boundary")
            end -= 1
    if offset < len(data):
        fail("limit does not reach a UTF-8 boundary")
    return "", end


def inspect_excerpt(line, limit):
    encoded = line.encode("utf-8")
    end = min(limit, len(encoded))
    while end:
        try:
            return encoded[:end].decode("utf-8"), len(encoded) > end
        except UnicodeDecodeError:
            end -= 1
    return "", bool(encoded)


def inspect_arguments(args):
    allowed = {
        "read": {"path", "limit", "offset"}, "tree": {"path", "limit", "cursor"},
        "search": {"path", "query", "limit", "cursor", "excerpt"}, "object": {"path"},
    }[args.action]
    for name in ("path", "query", "limit", "offset", "cursor", "excerpt"):
        if getattr(args, name) is not None and name not in allowed:
            fail(f"--{name} is not valid for inspect {args.action}")


def command_inspect(args):
    root = root_dir()
    inspect_arguments(args)
    commit = inspect_git(root, "rev-parse", "--verify", "--end-of-options", f"{args.commit}^{{commit}}", check=False)
    if commit.returncode:
        fail("--commit must resolve to a commit")
    commit = commit.stdout.strip()
    if args.cursor is not None and args.cursor < 0:
        fail("cursor must be non-negative")
    path = inspect_path(args.path, args.action == "read")
    overlay, overlay_total, overlay_truncated = inspect_overlay(root)
    result = {"action": args.action, "commit": commit, "dirty_overlay_excluded": overlay,
              "dirty_overlay_total": overlay_total, "dirty_overlay_truncated": overlay_truncated}
    if args.action == "object":
        kind, object_id, _ = inspect_object(root, commit, path)
        result.update({"path": path, "object": object_id, "type": kind,
                       "size": int(inspect_git(root, "cat-file", "-s", "--", object_id).stdout)})
    elif args.action == "read":
        kind, object_id, spec = inspect_object(root, commit, path)
        if kind != "blob":
            fail("read requires a blob path")
        size = inspect_blob_size(root, spec)
        data = inspect_text(root, spec, size)
        limit = inspect_limit(args.limit, 32768, 65536, "read limit")
        offset = args.offset or 0
        if offset < 0 or offset > len(data):
            fail("offset is outside blob")
        content, end = inspect_utf8_page(data, offset, limit)
        binary = b"\0" in data or content is None
        result.update({"path": path, "object": object_id, "binary": binary, "size": size,
                       "truncated": False if binary else end < len(data),
                       "continuation": {"offset": end} if not binary and end < len(data) else None})
        if not binary:
            result["content"] = content
    elif args.action == "tree":
        if path is None:
            object_id = inspect_git(root, "rev-parse", "--verify", "--end-of-options", f"{commit}^{{tree}}").stdout.strip()
            rows = inspect_tree_rows(root, commit)
        else:
            kind, object_id, spec = inspect_object(root, commit, path)
            if kind != "tree":
                fail("tree requires a tree path")
            rows = inspect_tree_rows(root, spec)
        limit = inspect_limit(args.limit, 50, 100, "tree limit")
        cursor = args.cursor or 0
        entries = []
        try:
            for metadata, name in rows:
                if len(entries) <= cursor + limit:
                    mode, entry_kind, entry_object = metadata
                    entries.append({"path": f"{path}/{name}" if path else name, "mode": mode,
                                    "object": entry_object, "type": entry_kind})
                else:
                    break
        finally:
            rows.close()
        if cursor > len(entries) or (cursor == len(entries) and entries):
            fail("cursor is outside available entries")
        result.update({"path": path, "object": object_id})
        inspect_page(result, "entries", entries, cursor, limit)
    else:
        if not args.query:
            fail("--query is required for search")
        if len(os.fsencode(args.query)) > 256 or any(ord(char) < 32 or ord(char) == 127 for char in args.query):
            fail("unsafe query")
        limit = inspect_limit(args.limit, 25, 100, "search limit")
        excerpt = inspect_limit(args.excerpt, 1024, 2048, "excerpt limit")
        cursor = args.cursor or 0
        matches = []
        if path is None:
            rows = inspect_tree_rows(root, "-r", commit)
            scope_is_tree = False
        else:
            kind, scoped_object, spec = inspect_object(root, commit, path)
            if kind == "blob":
                rows = iter([(["100644", "blob", scoped_object], path)])
                scope_is_tree = False
            elif kind == "tree":
                rows = inspect_tree_rows(root, "-r", spec)
                scope_is_tree = True
            else:
                fail("search path must be a blob or tree")
        try:
            for (_, kind, object_id), name in rows:
                if kind != "blob" or len(matches) > cursor + limit:
                    if len(matches) > cursor + limit:
                        break
                    continue
                size = inspect_blob_size(root, object_id, strict=False)
                if size is None:
                    continue
                data = inspect_text(root, object_id, size)
                if b"\0" in data:
                    continue
                try:
                    text = data.decode("utf-8")
                except UnicodeDecodeError:
                    continue
                for number, line in enumerate(text.splitlines(), 1):
                    if args.query in line:
                        excerpt_text, excerpt_truncated = inspect_excerpt(line, excerpt)
                        matches.append({"path": f"{path}/{name}" if path and scope_is_tree else name,
                                        "line": number, "object": object_id, "excerpt": excerpt_text,
                                        "excerpt_truncated": excerpt_truncated})
                        if len(matches) > cursor + limit:
                            break
        finally:
            close = getattr(rows, "close", None)
            if close:
                close()
        if cursor > len(matches) or (cursor == len(matches) and matches):
            fail("cursor is outside available matches")
        result["query"] = args.query
        inspect_page(result, "matches", matches, cursor, limit)
    inspect_emit(result)


def command_status(args):
    root = root_dir()
    active = active_path(root)
    if not active.exists():
        active = legacy_cycle_dir(root) / "active"
    if not active.exists() and args.json:
        print("null")
        return
    _, record = load(root)
    if args.json:
        print(json.dumps(record, sort_keys=True, separators=(",", ":")))
    else:
        print(f"{record['cycle_id']} {record['state']} {record['risk']} {record['delivery_intent']}")


def command_attach_runtime(args):
    root = root_dir().resolve()
    session_id = (session_for_message(None, args.opencode_message_id)
                  if args.opencode_message_id is not None else args.opencode_session_id)
    if not OPAQUE_ID.fullmatch(session_id):
        fail("invalid OpenCode session ID")
    runtime_worktree = Path(args.opencode_worktree).resolve()
    runtime_directory = Path(args.opencode_directory).resolve()
    if (not runtime_worktree.is_dir() or not runtime_directory.is_dir()
            or runtime_worktree not in runtime_directory.parents and runtime_directory != runtime_worktree):
        fail("invalid OpenCode runtime paths")
    path, record = load(root)
    cycle_id = record["cycle_id"]
    with evidence_lock(root, cycle_id):
        path, record = load(root)
        if record["cycle_id"] != cycle_id:
            fail("active DBSCTR cycle changed during runtime attachment")
        require_active(record)
        recorded_worktree = Path(record.get("worktree", {}).get("path", "")).resolve()
        if runtime_worktree != root or runtime_worktree != recorded_worktree:
            fail("OpenCode runtime must match the recorded cycle worktree")
        opencode = record.setdefault("runtime", {}).setdefault("opencode", {})
        session_ids = opencode.setdefault("session_ids", [])
        if (not isinstance(session_ids, list) or len(session_ids) > REVIEW_MAX_LIMIT
                or not all(isinstance(value, str) and OPAQUE_ID.fullmatch(value) for value in session_ids)):
            fail("Cycle Record contains invalid OpenCode runtime metadata")
        attached = session_id not in session_ids
        if attached:
            if len(session_ids) == REVIEW_MAX_LIMIT:
                fail("Cycle Record OpenCode runtime limit reached")
            session_ids.append(session_id)
        opencode["worktree"] = str(runtime_worktree)
        save(path, record)
    print(json.dumps({"cycle_id": record["cycle_id"], "attached": attached}, sort_keys=True,
                     separators=(",", ":")))


def sqlite_name(connection, table, choices):
    columns = {row[1].lower().replace("_", ""): row[1] for row in connection.execute(f"PRAGMA table_info({table})")}
    for choice in choices:
        if choice in columns:
            return columns[choice]
    fail(f"OpenCode {table} table lacks required columns")


def review_index(root):
    if ledger_exists(root):
        with ledger_connection(root) as connection:
            value = {"schema_version": 1, "sessions": {}, "cycles": {}, "forgotten_sessions": {}}
            names = {"session": "sessions", "cycle": "cycles", "forgotten_session": "forgotten_sessions"}
            for kind, item_id, timestamp in connection.execute(
                    "SELECT kind, item_id, timestamp FROM review_tombstones"):
                value[names[kind]][item_id] = timestamp
    else:
        path = root / "reviews" / "reviewed.json"
        if not path.exists():
            value = {"schema_version": 1, "sessions": {}, "cycles": {}, "forgotten_sessions": {}}
        else:
            try:
                value = json.loads(path.read_text(encoding="utf-8"), object_pairs_hook=no_duplicate_keys)
            except (OSError, json.JSONDecodeError) as error:
                fail(f"cannot read reviewed tombstones: {error}")
    if (not isinstance(value, dict) or set(value) != {"schema_version", "sessions", "cycles", "forgotten_sessions"}
            or value["schema_version"] != 1 or not isinstance(value["sessions"], dict)
            or not isinstance(value["cycles"], dict) or not isinstance(value["forgotten_sessions"], dict)):
        fail("reviewed tombstones have an invalid schema")
    for values in (value["sessions"], value["cycles"], value["forgotten_sessions"]):
        if not all(isinstance(key, str) and re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]{0,127}", key)
                   and isinstance(timestamp, int) and timestamp >= REVIEW_START_MS
                   for key, timestamp in values.items()):
            fail("reviewed tombstones contain invalid entries")
    return value


def validate_review_report(report, marker_name, timestamp):
    path = Path(marker_name)
    text_fields = ("findings", "scorecards", "trends", "proposals", "caveats")
    allowed = {"session_ids", "cycle_ids", "scan_digest", "snapshot", "session_ceiling", "part_ceiling", "database_digest",
               "limit", "cursor", "decision", "notes", "reviewed_at", *text_fields}
    required = {"session_ids", "scan_digest", "limit", "cursor", "decision"}
    if (not isinstance(report, dict) or set(report) - allowed or not required <= set(report)
            or not isinstance(report.get("session_ids"), list)
            or not isinstance(report.get("cycle_ids", []), list)
            or not 1 <= len(report["session_ids"]) <= REVIEW_MAX_LIMIT
            or len(report.get("cycle_ids", [])) > REVIEW_MAX_LIMIT
            or not all(isinstance(value, str) and OPAQUE_ID.fullmatch(value)
                       for value in report["session_ids"] + report.get("cycle_ids", []))
            or len(set(report["session_ids"])) != len(report["session_ids"])
            or len(set(report.get("cycle_ids", []))) != len(report.get("cycle_ids", []))
            or not isinstance(report.get("scan_digest"), str)
            or not re.fullmatch(r"[0-9a-f]{64}", report["scan_digest"])
            or not isinstance(report.get("decision"), str) or not 1 <= len(report["decision"].encode()) <= 256
            or report.get("notes") is not None and (not isinstance(report["notes"], str)
                                                     or len(report["notes"].encode()) > 2048)):
        fail("retained review report has an invalid schema")
    if (type(report["limit"]) is not int or not 1 <= report["limit"] <= REVIEW_MAX_LIMIT
            or type(report["cursor"]) is not int or report["cursor"] < 0):
        fail("retained review report has an invalid schema")
    for name in ("snapshot", "session_ceiling", "part_ceiling"):
        if name in report and (type(report[name]) is not int or report[name] < 0):
            fail("retained review report has an invalid schema")
    current = {"session_ceiling", "part_ceiling", "database_digest"} & set(report)
    if current and not {"reviewed_at", "snapshot", "session_ceiling", "part_ceiling", "database_digest"} <= set(report):
        fail("retained review report has an invalid schema")
    if "reviewed_at" in report and not current:
        fail("retained review report has an invalid schema")
    for name in text_fields:
        values = report.get(name, [])
        if not isinstance(values, list) or len(values) > 50 or not all(
                isinstance(value, str) and 1 <= len(value) <= 512 for value in values):
            fail("retained review report has an invalid schema")
    human = [str(report.get(name, "")) for name in ("decision", "notes")]
    human.extend(value for name in text_fields for value in report.get(name, []))
    if review_unsafe(" ".join(human)):
        fail("retained review report contains unsafe content")
    if not re.fullmatch(r"[0-9a-f]{24}\.json", path.name):
        fail("retained review report has an invalid marker name")
    expected = hashlib.sha256((report["scan_digest"] + "\0" + json.dumps(report, sort_keys=True)).encode()).hexdigest()[:24]
    if path.stem != expected:
        fail("retained review report marker does not match its content")
    if (not isinstance(timestamp, int) or timestamp < REVIEW_START_MS
            or timestamp > int(datetime.now(timezone.utc).timestamp() * 1000) + 1000):
        fail("retained review report has an invalid review timestamp")
    return report, timestamp


def read_review_report(path):
    try:
        report = json.loads(path.read_text(encoding="utf-8"), object_pairs_hook=no_duplicate_keys)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read retained review report: {error}")
    return validate_review_report(report, path.name, report.get("reviewed_at", path.stat().st_mtime_ns // 1_000_000))


def review_reports(root):
    if ledger_exists(root):
        reports = []
        with ledger_connection(root) as connection:
            for report_id, payload, timestamp in connection.execute(
                    "SELECT report_id, payload, reviewed_at FROM review_reports ORDER BY report_id"):
                try:
                    report = json.loads(payload, object_pairs_hook=no_duplicate_keys)
                except json.JSONDecodeError as error:
                    fail(f"cannot read retained review report: {error}")
                report, timestamp = validate_review_report(report, f"{report_id}.json", timestamp)
                reports.append((None, report, timestamp))
        return reports
    directory = root / "reviews"
    if not directory.is_dir():
        return []
    reports = []
    for path in directory.glob("*.json"):
        if path.name == "reviewed.json":
            continue
        report, timestamp = read_review_report(path)
        reports.append((path, report, timestamp))
    return reports


def reviewed_ids_unlocked(root, cutoff=None):
    index = review_index(root)
    session_times = dict(index["sessions"])
    cycle_times = dict(index["cycles"])
    for _, report, timestamp in review_reports(root):
        for key in report["session_ids"]:
            session_times[key] = max(session_times.get(key, 0), timestamp)
        for key in report.get("cycle_ids", []):
            cycle_times[key] = max(cycle_times.get(key, 0), timestamp)
    sessions = {key for key, timestamp in session_times.items()
                if (cutoff is None or timestamp <= cutoff)
                and timestamp > (index["forgotten_sessions"].get(key, 0)
                                 if cutoff is None or index["forgotten_sessions"].get(key, 0) <= cutoff else 0)}
    cycles = {key for key, timestamp in cycle_times.items() if cutoff is None or timestamp <= cutoff}
    return sessions, cycles


def reviewed_ids(state_root, cutoff=None, lock=True):
    root = review_root(state_root)
    lock_path = root / "reviews" / ".lock"
    review_state = root / "reviews"
    if lock and review_state.is_dir() and (any(review_state.glob("*.json")) or ledger_exists(root)) and not lock_path.is_file():
        fail("retained review state is missing its lock")
    if lock and lock_path.is_file():
        with lock_path.open("r", encoding="utf-8") as handle:
            fcntl.flock(handle, fcntl.LOCK_SH)
            return reviewed_ids_unlocked(root, cutoff)
    return reviewed_ids_unlocked(root, cutoff)


def update_review_index(root, sessions=(), cycles=(), timestamp=None, connection=None):
    value = review_index(root)
    timestamp = timestamp or int(datetime.now(timezone.utc).timestamp() * 1000)
    for key in sessions:
        value["sessions"][key] = max(value["sessions"].get(key, 0), timestamp)
    for key in cycles:
        value["cycles"][key] = max(value["cycles"].get(key, 0), timestamp)
    if ledger_exists(root):
        owned = connection is None
        connection = connection or ledger_connection(root, write=True)
        connection.executemany(
            "INSERT INTO review_tombstones VALUES (?, ?, ?) ON CONFLICT(kind, item_id) DO UPDATE SET timestamp=max(timestamp, excluded.timestamp)",
            [("session", key, value["sessions"][key]) for key in sessions]
            + [("cycle", key, value["cycles"][key]) for key in cycles],
        )
        if owned:
            connection.commit()
            connection.close()
    else:
        private_json(root / "reviews" / "reviewed.json", value)
    return value


def prune_review_reports(root, connection=None):
    cutoff_ms = int((time.time() - REVIEW_RETENTION_SECONDS) * 1000)
    if ledger_exists(root):
        owned = connection is None
        connection = connection or ledger_connection(root, write=True)
        expired = list(connection.execute(
            "SELECT report_id, payload, reviewed_at FROM review_reports WHERE reviewed_at <= ?", (cutoff_ms,)))
        for report_id, payload, timestamp in expired:
            report, _ = validate_review_report(json.loads(payload, object_pairs_hook=no_duplicate_keys),
                                               f"{report_id}.json", timestamp)
            update_review_index(root, report.get("session_ids", []), report.get("cycle_ids", []), timestamp,
                                connection=connection)
            connection.execute("DELETE FROM ledger_entries WHERE scope='operational' AND report_id=?", (report_id,))
            connection.execute("DELETE FROM review_reports WHERE report_id=?", (report_id,))
        if owned:
            connection.commit()
            connection.close()
        return len(expired)
    reports, malformed_expired = [], []
    directory = root / "reviews"
    for path in directory.glob("*.json") if directory.is_dir() else ():
        if path.name == "reviewed.json":
            continue
        try:
            report, timestamp = read_review_report(path)
            reports.append((path, report, timestamp))
        except RuntimeError:
            if path.stat().st_mtime_ns // 1_000_000 > cutoff_ms:
                raise
            malformed_expired.append(path)
    index = review_index(root)
    for _, report, timestamp in reports:
        for key in report.get("session_ids", []):
            index["sessions"][key] = max(index["sessions"].get(key, 0), timestamp)
        for key in report.get("cycle_ids", []):
            index["cycles"][key] = max(index["cycles"].get(key, 0), timestamp)
    index_path = root / "reviews" / "reviewed.json"
    if reports or index_path.exists():
        private_json(index_path, index)
    removed = 0
    for path, _, timestamp in reports:
        if timestamp <= cutoff_ms:
            path.unlink()
            removed += 1
    for path in malformed_expired:
        path.unlink()
        removed += 1
    if removed:
        descriptor = os.open(directory, os.O_RDONLY)
        try:
            os.fsync(descriptor)
        finally:
            os.close(descriptor)
    return removed


def valid_gate_exception(gate):
    exception = gate.get("exception")
    if (not isinstance(exception, dict)
            or exception.get("kind") not in ("deferred", "accepted_risk")
            or not all(isinstance(exception.get(name), str) and exception[name].strip()
                       for name in ("rationale", "owner", "review_condition", "approved_at"))):
        return False
    try:
        approved_at = datetime.fromisoformat(exception["approved_at"].replace("Z", "+00:00"))
    except ValueError:
        return False
    return approved_at.utcoffset() == timedelta(0)


def correlated_cycles(directory, hinted_ids, session_ids=(), cache=None, exact_session_id=None,
                      with_quality=False):
    cache_key = str(directory or "")
    cached = cache.get(cache_key) if cache is not None else None
    if cached is None:
        record_dirs, resolved = [], None
        worktree = Path(directory) if directory else None
        if worktree and worktree.is_dir():
            common_result = git(worktree, "rev-parse", "--git-common-dir", check=False)
            top_result = git(worktree, "rev-parse", "--show-toplevel", check=False)
            if not common_result.returncode and not top_result.returncode:
                common = Path(common_result.stdout.strip())
                if not common.is_absolute():
                    common = worktree / common
                record_dirs.append(common.resolve() / "dbsctr/cycles")
                resolved = Path(top_result.stdout.strip()).resolve()
        try:
            current_records = common_git_dir(root_dir()).resolve() / "dbsctr/cycles"
            if current_records not in record_dirs:
                record_dirs.append(current_records)
        except RuntimeError:
            pass
        records = []
        paths = sorted({path for directory_path in record_dirs if directory_path.is_dir()
                        for path in directory_path.glob("*.json")})
        for path in paths:
            try:
                record = json.loads(path.read_text(encoding="utf-8"))
                cycle_id = record.get("cycle_id")
                if not isinstance(cycle_id, str) or not OPAQUE_ID.fullmatch(cycle_id):
                    fail("Cycle Record contains an invalid cycle ID")
                records.append(record)
            except (OSError, json.JSONDecodeError):
                continue
        cached = (resolved, records)
        if cache is not None:
            cache[cache_key] = cached
    resolved, records = cached
    def runtime_ids(record):
        values = record.get("runtime", {}).get("opencode", {}).get("session_ids", [])
        return set(values) if isinstance(values, list) else set()

    def unique(matches, quality):
        return (matches, quality) if len(matches) == 1 else ([], "ambiguous" if matches else None)

    exact_ids = {exact_session_id} if exact_session_id is not None else set(session_ids)
    exact = [record for record in records if exact_ids.intersection(runtime_ids(record))]
    hinted = [record for record in records if record["cycle_id"] in hinted_ids]
    if exact:
        matched, quality = unique(exact, "exact")
    elif hinted:
        matched, quality = unique(hinted, "exact")
    else:
        family_ids = set(session_ids) - exact_ids
        family, family_quality = unique(
            [record for record in records if family_ids.intersection(runtime_ids(record))], "family"
        )
        worktrees = [record for record in records if resolved is not None
                     and record.get("worktree", {}).get("path")
                     and Path(record["worktree"]["path"]).resolve() == resolved]
        worktree, worktree_quality = unique(worktrees, "worktree")
        sources = [record for record in records if resolved is not None
                   and isinstance(record.get("source"), dict) and record["source"].get("path")
                   and Path(record["source"]["path"]).resolve() == resolved]
        source, source_quality = unique(sources, "source")
        matched, quality = next(((items, value) for items, value in (
            (family, family_quality), (worktree, worktree_quality), (source, source_quality)
        ) if items), ([], "ambiguous" if "ambiguous" in (family_quality, worktree_quality, source_quality)
                       else "unavailable"))
    if not matched:
        return ([], quality) if with_quality else []
    output = []
    for record in matched:
        gates = record.get("gates", {}).values()
        if any(gate.get("applicability") == "required"
               and gate.get("result") in ("failed", "unavailable")
               and not valid_gate_exception(gate) for gate in gates):
            state = "blocked"
        elif record.get("state") == "completed":
            state = "completed"
        elif record.get("state") == "active" and (not record.get("worktree", {}).get("path")
                                                   or not Path(record["worktree"]["path"]).is_dir()):
            state = "abandoned"
        else:
            state = "active"
        output.append({"cycle_id": record["cycle_id"], "state": state})
    output = sorted(output, key=lambda item: item["cycle_id"])
    return (output, quality) if with_quality else output


def session_family_map(rows):
    adjacency = {}
    for row in rows:
        session_id, parent_id = str(row[0]), str(row[1]) if row[1] else None
        adjacency.setdefault(session_id, set())
        if parent_id:
            adjacency[session_id].add(parent_id)
            adjacency.setdefault(parent_id, set()).add(session_id)
    families, remaining = {}, set(adjacency)
    while remaining:
        member = remaining.pop()
        family, pending = {member}, [member]
        while pending:
            current = pending.pop()
            new = adjacency[current] - family
            family.update(new)
            pending.extend(new)
        remaining.difference_update(family)
        for session_id in family:
            families[session_id] = family
    return families


def review_attention(cycles, timestamp, snapshot):
    return (["dormant"] if any(item["state"] == "active" for item in cycles)
            and snapshot - timestamp >= REVIEW_DORMANT_MS else [])


def review_priority(item):
    rank = {"blocked": 0, "abandoned": 1, "completed": 3, "active": 4}
    values = [rank[cycle["state"]] for cycle in item["cycles"]]
    if "dormant" in item["attention"]:
        values.append(2)
    return min(values, default=5)


def review_scan(args):
    if args.limit < 1 or args.limit > REVIEW_MAX_LIMIT or args.cursor < 0:
        fail("review scan limit must be 1 through 100 and cursor non-negative")
    current_ms = int(datetime.now(timezone.utc).timestamp() * 1000)
    continuation = args.snapshot is not None
    snapshot = current_ms if args.snapshot is None else args.snapshot
    if not isinstance(snapshot, int) or snapshot < REVIEW_START_MS or snapshot > current_ms:
        fail("review scan snapshot must be a valid non-future millisecond cutoff")
    database = Path(args.database).expanduser() if args.database else Path.home() / ".local/share/opencode/opencode.db"
    if not database.is_file():
        fail("OpenCode database is missing")
    excluded_session_id = getattr(args, "excluded_session_id", None)
    if excluded_session_id is not None and not OPAQUE_ID.fullmatch(excluded_session_id):
        fail("invalid excluded session ID")
    excluded_message_id = getattr(args, "excluded_message_id", None)
    if excluded_message_id is not None and not OPAQUE_ID.fullmatch(excluded_message_id):
        fail("invalid excluded message ID")
    try:
        connection = sqlite3.connect(f"file:{database}?mode=ro", uri=True)
        connection.execute("BEGIN")
        tables = {row[0].lower(): row[0] for row in connection.execute("SELECT name FROM sqlite_master WHERE type='table'")}
        if not {"session", "message", "part"} <= set(tables):
            fail("OpenCode database lacks required session/message/part tables")
        session, message, part = (tables[name] for name in ("session", "message", "part"))
        exclusion_digest = getattr(args, "exclusion_digest", None)
        if exclusion_digest is not None and not re.fullmatch(r"[0-9a-f]{64}", exclusion_digest):
            fail("invalid review exclusion digest")
        session_columns = {row[1].lower().replace("_", ""): row[1]
                           for row in connection.execute(f'PRAGMA table_info("{session}")')}
        session_ceiling = args.session_ceiling
        part_ceiling = args.part_ceiling
        if continuation and (session_ceiling is None or part_ceiling is None):
            fail("review scan continuation requires row ceilings")
        if session_ceiling is None:
            session_ceiling = connection.execute(f'SELECT COALESCE(MAX(rowid), 0) FROM "{session}"').fetchone()[0]
        if part_ceiling is None:
            part_ceiling = connection.execute(f'SELECT COALESCE(MAX(rowid), 0) FROM "{part}"').fetchone()[0]
        if (type(session_ceiling) is not int or not 0 <= session_ceiling <= 2**63 - 1
                or type(part_ceiling) is not int or not 0 <= part_ceiling <= 2**63 - 1):
            fail("review scan row ceilings must be non-negative integers")
        sid = sqlite_name(connection, session, ("id",))
        pid = sqlite_name(connection, part, ("id",))
        parent = sqlite_name(connection, session, ("parentid", "parent")) if any(
            row[1].lower().replace("_", "") in ("parentid", "parent") for row in connection.execute(f"PRAGMA table_info({session})")
        ) else None
        created = sqlite_name(connection, session, ("timecreated", "createdat", "time", "timestamp"))
        directory = sqlite_name(connection, session, ("directory",)) if any(
            row[1].lower().replace("_", "") == "directory" for row in connection.execute(f"PRAGMA table_info({session})")
        ) else None
        agent = sqlite_name(connection, session, ("agent",)) if any(
            row[1].lower().replace("_", "") == "agent" for row in connection.execute(f"PRAGMA table_info({session})")
        ) else None
        mid, msession = sqlite_name(connection, message, ("id",)), sqlite_name(connection, message, ("sessionid",))
        pmessage = sqlite_name(connection, part, ("messageid",))
        pbody = sqlite_name(connection, part, ("data", "text", "content"))
        part_time = sqlite_name(connection, part, ("timecreated", "createdat", "time", "timestamp"))
        part_columns = {row[1].lower().replace("_", ""): row[1]
                        for row in connection.execute(f'PRAGMA table_info("{part}")')}
        part_updated = part_columns.get("timeupdated")
        if exclusion_digest is not None:
            root = next((str(row[0]) for row in connection.execute(f'SELECT "{sid}" FROM "{session}"')
                         if session_id_digest(str(row[0])) == exclusion_digest), None)
            if root is None:
                fail("review exclusion digest does not match a session")
        else:
            root = (session_for_message(args.database, excluded_message_id)
                    if excluded_message_id is not None else excluded_session_id)
            exclusion_digest = session_id_digest(root) if root is not None else None
        excluded_sessions = excluded_review_family(connection, session, root) if root is not None else set()
        excluded = tuple(sorted(excluded_sessions))
        session_exclusion = (f' AND "{sid}" NOT IN ({",".join("?" for _ in excluded)})' if excluded else "")
        message_exclusion = (f' AND (m."{msession}" NOT IN ({",".join("?" for _ in excluded)}) '
                             f'OR m."{msession}" IS NULL)' if excluded else "")
        identity = hashlib.sha256()
        if exclusion_digest is not None:
            identity.update(b"excluded\0" + exclusion_digest.encode())
        session_identity_columns = [sid, created]
        for value in (parent, directory, agent, session_columns.get("projectid"), session_columns.get("cost"),
                      *(session_columns.get(name) for name in (
                          "tokensinput", "tokensoutput", "tokensreasoning", "tokenscacheread", "tokenscachewrite"
                      ))):
            if value and value not in session_identity_columns:
                session_identity_columns.append(value)
        selected = ", ".join(f'"{value}"' for value in session_identity_columns)
        for row in connection.execute(
                f'SELECT {selected} FROM "{session}" WHERE "{created}" BETWEEN ? AND ? '
                f'AND rowid <= ?{session_exclusion} ORDER BY "{sid}"',
                (REVIEW_START_MS, snapshot, session_ceiling, *excluded)):
            identity.update(b"s\0")
            identity.update(json.dumps(row, sort_keys=True, default=str).encode())
        part_identity_values = f'p."{pbody}"' + (f', p."{part_updated}"' if part_updated else '')
        part_identity_query = (
            f'SELECT p."{pid}", p."{part_time}", {part_identity_values} FROM "{part}" p '
            f'LEFT JOIN "{message}" m ON p."{pmessage}"=m."{mid}" '
            f'WHERE p."{part_time}" BETWEEN ? AND ? AND p.rowid <= ?{message_exclusion} ORDER BY p."{pid}"'
            if excluded else
            f'SELECT "{pid}", "{part_time}", "{pbody}"'
            f'{", \"" + part_updated + "\"" if part_updated else ""} FROM "{part}" '
            f'WHERE "{part_time}" BETWEEN ? AND ? AND rowid <= ? ORDER BY "{pid}"'
        )
        for row in connection.execute(
                part_identity_query,
                (REVIEW_START_MS, snapshot, part_ceiling, *excluded)):
            part_id, part_timestamp, *part_values = row
            identity.update(f"p\0{part_id}\0{part_timestamp}\0".encode())
            for part_value in part_values:
                identity.update(hashlib.sha256(str(part_value).encode()).digest())
        database_digest = identity.hexdigest()
        for table, column in ((session, created), (part, part_time)):
            invalid = connection.execute(
                f'SELECT 1 FROM "{table}" WHERE "{column}" IS NOT NULL '
                f'AND (typeof("{column}") != \'integer\' OR "{column}" < 100000000000) LIMIT 1'
            ).fetchone()
            if invalid:
                fail(f"OpenCode {table} timestamps must be integer milliseconds")
        parent_value = f's."{parent}"' if parent else "NULL"
        created_value = f's."{created}"'
        directory_value = f's."{directory}"' if directory else "NULL"
        agent_value = f's."{agent}"' if agent else "''"
        child_exclusion = (f' AND c."{sid}" NOT IN ({",".join("?" for _ in excluded)})' if excluded else "")
        children = (f'(SELECT group_concat(c."{sid}", ",") FROM "{session}" c '
                    f'WHERE c."{parent}"=content.session_id AND c."{created}" <= ? AND c.rowid <= ?{child_exclusion})') if parent else "NULL"
        time_filter = f'(typeof(s."{created}") = \'integer\' AND s."{created}" BETWEEN ? AND ? AND s.rowid <= ?)'
        part_order = f'p."{part_time}" DESC'
        part_source = (f'SELECT substr(p."{pbody}", 1, 2048) body FROM "{message}" m '
                       f'JOIN "{part}" p ON p."{pmessage}"=m."{mid}" WHERE m."{msession}"=s."{sid}" '
                       f'AND p."{part_time}" <= ? AND p.rowid <= ?')
        body = (f'(SELECT group_concat(body, "\\n") FROM ('
                f'SELECT body FROM ({part_source} ORDER BY {part_order.replace(" DESC", " ASC")} LIMIT 16) '
                 f'UNION ALL SELECT body FROM ({part_source} ORDER BY {part_order} LIMIT 16)))')
        last_activity = (f'MAX({created_value}, COALESCE((SELECT MAX(p."{part_time}") FROM "{message}" m '
                         f'JOIN "{part}" p ON p."{pmessage}"=m."{mid}" WHERE m."{msession}"=s."{sid}" '
                         f'AND p."{part_time}" <= ? AND p.rowid <= ?), {created_value}))')
        query = f"""
            WITH RECURSIVE content AS (
                SELECT s."{sid}" session_id, {parent_value} parent_id,
                       {created_value} created_at, {last_activity} last_activity,
                       {directory_value} directory,
                       {agent_value} agent, COALESCE({body}, '') body
                FROM "{session}" s
                WHERE {time_filter}{session_exclusion}
            ), seeds AS (
                SELECT session_id FROM content
                WHERE lower(body) LIKE '%dbsctr%'
                   OR lower(body) LIKE '%/discovery%'
                   OR lower(body) LIKE '%/qa%'
                   OR lower(agent) IN ('reviewer-openai', 'builder-openai', 'builder-bedrock')
            ), edges(source, target) AS (
                SELECT session_id, parent_id FROM content WHERE parent_id IS NOT NULL
                UNION SELECT parent_id, session_id FROM content WHERE parent_id IS NOT NULL
            ), expanded(session_id) AS (
                SELECT session_id FROM seeds
                UNION SELECT edges.target FROM edges JOIN expanded ON edges.source=expanded.session_id
            )
            SELECT content.session_id, content.parent_id, content.created_at, content.last_activity,
                   {children}, content.body, content.directory
            FROM content JOIN expanded ON expanded.session_id=content.session_id
            ORDER BY content.created_at, content.session_id
        """
        parameters = (snapshot, part_ceiling, snapshot, part_ceiling, snapshot, part_ceiling,
                      REVIEW_START_MS, snapshot, session_ceiling, *excluded,
                      *((snapshot, session_ceiling, *excluded) if parent else ()))
        rows = connection.execute(query, parameters).fetchall()
        history_metrics = {}
        if getattr(args, "history_metrics", False):
            wanted_sessions = {str(row[0]) for row in rows}
            project_column = session_columns.get("projectid")
            cost_column = session_columns.get("cost")
            token_columns = [session_columns[name] for name in (
                "tokensinput", "tokensoutput", "tokensreasoning", "tokenscacheread", "tokenscachewrite"
            ) if name in session_columns]
            scalar_columns = [value for value in (project_column, cost_column, *token_columns) if value]
            scalar_values = {}
            if scalar_columns:
                selected = ", ".join(f's."{value}"' for value in scalar_columns)
                scalar_sql = (f'SELECT s."{sid}", {selected} FROM "{session}" s '
                              f'WHERE {time_filter}')
                for scalar_row in connection.execute(scalar_sql + session_exclusion,
                                                     (REVIEW_START_MS, snapshot, session_ceiling, *excluded)):
                    if str(scalar_row[0]) in wanted_sessions:
                        scalar_values[str(scalar_row[0])] = dict(zip(scalar_columns, scalar_row[1:]))
            for session_id in wanted_sessions:
                scalar = scalar_values.get(session_id, {})
                project_value = scalar.get(project_column) if project_column else None
                project_digest = (hashlib.sha256(str(project_value).encode()).hexdigest()
                                  if isinstance(project_value, str) and project_value else "unavailable")
                cost = scalar.get(cost_column) if cost_column else None
                cost_total = (cost if isinstance(cost, (int, float)) and not isinstance(cost, bool)
                              and math.isfinite(cost) and cost >= 0 else "unavailable")
                tokens = [scalar.get(name) for name in token_columns]
                token_total = (sum(tokens) if tokens and all(type(value) is int and value >= 0 for value in tokens)
                               else "unavailable")
                history_metrics[session_id] = {
                    "project_digest": project_digest, "tool_count": "unavailable",
                    "tool_call_count": "unavailable", "tool_error_count": "unavailable",
                    "cost_total": cost_total, "token_total": token_total,
                }
            tool_case = (f'CASE WHEN json_valid(p."{pbody}") THEN '
                         f'CASE WHEN json_extract(p."{pbody}", \'$.type\')=\'tool\' THEN 1 ELSE 0 END ELSE 0 END')
            error_case = (f'CASE WHEN json_valid(p."{pbody}") THEN CASE WHEN '
                          f'json_extract(p."{pbody}", \'$.type\')=\'tool\' AND '
                          f'json_extract(p."{pbody}", \'$.state.status\') IN (\'error\',\'failed\') '
                          f'THEN 1 ELSE 0 END ELSE 0 END')
            if wanted_sessions:
                placeholders = ",".join("?" for _ in wanted_sessions)
                metric_sql = (f'SELECT m."{msession}", SUM({tool_case}), SUM({error_case}) '
                              f'FROM "{message}" m JOIN "{part}" p ON p."{pmessage}"=m."{mid}" '
                              f'WHERE m."{msession}" IN ({placeholders}) AND p."{part_time}" BETWEEN ? AND ? '
                               f'AND p.rowid <= ?{message_exclusion} GROUP BY m."{msession}"')
                metric_args = (*sorted(wanted_sessions), REVIEW_START_MS, snapshot, part_ceiling, *excluded)
                for session_value, tool_calls, tool_errors in connection.execute(metric_sql, metric_args):
                    session_id = str(session_value)
                    if session_id in history_metrics:
                        history_metrics[session_id].update({
                            "tool_count": int(tool_calls or 0), "tool_call_count": int(tool_calls or 0),
                            "tool_error_count": int(tool_errors or 0),
                        })
    except sqlite3.Error as error:
        fail(f"cannot read OpenCode database: {error}")
    finally:
        if 'connection' in locals():
            connection.close()
    reviewed_sessions, _ = reviewed_ids(args.state_root, snapshot if continuation else None,
                                         lock=not getattr(args, "lock_held", False))
    eligible, cycle_cache, identity_cache = [], {}, {}
    families = session_family_map(rows)
    for session_id, parent_id, timestamp, last_activity, child_ids, text, directory in rows:
        session_id = str(session_id)
        parent_id = str(parent_id) if parent_id else None
        children_values = sorted(str(child_ids).split(","))[:16] if child_ids else []
        if (not OPAQUE_ID.fullmatch(session_id) or parent_id is not None and not OPAQUE_ID.fullmatch(parent_id)
                or not all(OPAQUE_ID.fullmatch(value) for value in children_values)):
            fail("OpenCode session metadata contains an invalid opaque ID")
        reviewed = session_id in reviewed_sessions
        if reviewed and not getattr(args, "include_reviewed", False):
            continue
        related_ids = families.get(session_id, {session_id})
        cycles, correlation_quality = correlated_cycles(
            directory, set(), related_ids, cycle_cache, exact_session_id=session_id, with_quality=True,
        )
        attention = review_attention(cycles, last_activity, snapshot)
        candidate = {"session_id": session_id, "parent_session_id": parent_id,
                         "child_session_ids": children_values,
                          "timestamp": str(timestamp)[:64] if timestamp is not None else None,
                          "last_activity": str(last_activity)[:64] if last_activity is not None else None,
                          "cycles": cycles, "attention": attention,
                           "correlation_quality": correlation_quality,
                           "reviewed_status": "reviewed" if reviewed else "unreviewed"}
        if getattr(args, "history_metrics", False):
            metrics = history_metrics.get(session_id, {})
            candidate["_history_metrics"] = metrics
            candidate["_history_identity"] = history_identity(
                cycles, directory, related_ids, metrics.get("project_digest", "unavailable"), identity_cache,
            )
        eligible.append(candidate)
    manifest = []
    for item in eligible:
        value = {key: field for key, field in item.items() if not key.startswith("_")}
        if getattr(args, "bind_history", False):
            value["history_identity"] = item.get("_history_identity", {})
            value["history_metrics"] = item.get("_history_metrics", {})
        manifest.append(value)
    database_digest = hashlib.sha256(
        (database_digest + "\0" + json.dumps(manifest, sort_keys=True, separators=(",", ":"))).encode()
    ).hexdigest()
    if continuation and args.database_digest != database_digest:
        fail("OpenCode database changed within the review snapshot")
    if getattr(args, "include_reviewed", False):
        eligible.sort(key=lambda item: (item["last_activity"] or "", item["session_id"]), reverse=True)
    candidates = eligible if getattr(args, "history_all", False) else eligible[args.cursor:args.cursor + args.limit]
    candidates.sort(key=lambda item: (review_priority(item), item["timestamp"] or "", item["session_id"]))
    session_ids = [item["session_id"] for item in candidates]
    cycle_ids = sorted({cycle["cycle_id"] for item in candidates for cycle in item["cycles"]})
    states = [cycle["state"] for item in candidates for cycle in item["cycles"]]
    result = {"schema_version": 2, "candidates": candidates, "scorecard": {
        "active": states.count("active"), "blocked": states.count("blocked"),
        "abandoned": states.count("abandoned"),
        "dormant": sum("dormant" in item["attention"] for item in candidates),
        "completed": states.count("completed"),
        "unknown": sum(not item["cycles"] for item in candidates)},
        "session_ids": session_ids, "cycle_ids": cycle_ids,
        "digest": review_digest(candidates, snapshot, session_ceiling, part_ceiling, database_digest),
        "limit": args.limit, "cursor": args.cursor, "snapshot": snapshot,
        "session_ceiling": session_ceiling, "part_ceiling": part_ceiling,
        "database_digest": database_digest,
        "exclusion_digest": exclusion_digest,
        "continuation": {"cursor": args.cursor + args.limit, "snapshot": snapshot,
                          "session_ceiling": session_ceiling, "part_ceiling": part_ceiling,
                          "database_digest": database_digest, "exclusion_digest": exclusion_digest}
         if not getattr(args, "history_all", False) and len(eligible) > args.cursor + args.limit else None}
    result["_excluded_session_ids"] = sorted(excluded_sessions)
    encoded = json.dumps(result, sort_keys=True, separators=(",", ":"), ensure_ascii=True)
    if not getattr(args, "history_metrics", False) and len(encoded.encode()) > REVIEW_SCAN_HARD:
        fail("review scan response exceeds bound")
    return result


def command_review_scan(args):
    scan = review_scan(args)
    scan.pop("_excluded_session_ids", None)
    print(json.dumps(scan, sort_keys=True, separators=(",", ":"), ensure_ascii=True))


def validate_history_evidence(value):
    allowed = {"schema_version", "session_id", "completed_at", "method_revision", "context",
               "project_digest", "cycles", "aggregates", "snapshot", "session_ceiling",
               "part_ceiling", "database_digest", "reviewed_status", "correlation_quality"}
    if (not isinstance(value, dict) or set(value) - allowed or value.get("schema_version") != 1
            or not isinstance(value.get("completed_at"), str) or not value["completed_at"].isdigit()
            or int(value["completed_at"]) < REVIEW_START_MS
            or not isinstance(value.get("method_revision"), str) or (value["method_revision"] != "unavailable" and not re.fullmatch(r"3\.\d+", value["method_revision"]))
            or not isinstance(value.get("context"), str) or (value["context"] != "unavailable" and not OPAQUE_ID.fullmatch(value["context"]))
            or not isinstance(value.get("project_digest"), str)
            or value.get("reviewed_status", "reviewed") not in ("reviewed", "unreviewed")
            or value.get("correlation_quality", "unavailable") not in (
                "exact", "family", "worktree", "source", "ambiguous", "unavailable")):
        fail("review history evidence has an invalid schema")
    history_id(value.get("session_id"), "history session ID")
    if value["project_digest"] != "unavailable":
        history_digest(value["project_digest"], "project digest")
    if not isinstance(value.get("cycles"), list) or len(value["cycles"]) > REVIEW_MAX_LIMIT:
        fail("review history evidence has an invalid schema")
    for cycle in value["cycles"]:
        if (not isinstance(cycle, dict) or set(cycle) != {"cycle_id", "state"}
                or cycle["state"] not in ("active", "blocked", "abandoned", "completed", "unknown")):
            fail("review history evidence has an invalid schema")
        history_id(cycle.get("cycle_id"), "history cycle ID")
    aggregate_names = {"candidate_count", "cycle_count", "child_count", "elapsed_ms", "tool_count", "tool_call_count",
                       "tool_error_count", "approval_count", "retry_count", "cost_total", "token_total",
                       "cycle_active_count", "cycle_blocked_count", "cycle_abandoned_count", "cycle_completed_count", "cycle_unknown_count"}
    if not isinstance(value.get("aggregates"), dict) or set(value["aggregates"]) - aggregate_names:
        fail("review history evidence has an invalid schema")
    if not all(((isinstance(item, (int, float)) and not isinstance(item, bool)
                  and math.isfinite(item) and 0 <= item <= 2**63 - 1) or item == "unavailable")
               for item in value["aggregates"].values()):
        fail("review history evidence has an invalid schema")
    for name in ("snapshot", "session_ceiling", "part_ceiling"):
        if name in value and (type(value[name]) is not int or value[name] < 0):
            fail("review history evidence has an invalid schema")
    if "database_digest" in value:
        history_digest(value["database_digest"], "database digest")
    return {**value, "correlation_quality": value.get("correlation_quality", "unavailable")}


def read_history_evidence(path):
    try:
        value = json.loads(path.read_text(encoding="utf-8"), object_pairs_hook=no_duplicate_keys)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read review history evidence: {error}")
    return validate_history_evidence(value)


def history_evidence(root):
    if ledger_exists(root):
        records = {}
        with ledger_connection(root) as connection:
            for payload, in connection.execute("SELECT payload FROM history_evidence ORDER BY session_id"):
                record = validate_history_evidence(json.loads(payload, object_pairs_hook=no_duplicate_keys))
                records[record["session_id"]] = record
            for payload, in connection.execute("SELECT payload FROM history_reports WHERE kind='report' ORDER BY report_id"):
                for record in validate_history_report(json.loads(payload, object_pairs_hook=no_duplicate_keys))["evidence"]:
                    records.setdefault(record["session_id"], record)
        return list(records.values())
    directory = history_dir(root)
    records = {}
    if directory.is_dir():
        for path in sorted(directory.glob("*.json")):
            record = read_history_evidence(path)
            if path.name != f"{record['session_id']}.json":
                fail("review history evidence marker does not match its content")
            records[record["session_id"]] = record
    reports = history_dir(root, "reports")
    if reports.is_dir():
        for path in sorted(reports.glob("*.json")):
            for record in history_report(path)["evidence"]:
                records.setdefault(record["session_id"], record)
    return list(records.values())


def archive_review_candidates(root, scan, mark_reviewed=True, connection=None):
    if connection is not None:
        for candidate in scan["candidates"]:
            ledger_put_history_evidence(connection, candidate_history_evidence(candidate, scan, mark_reviewed))
        return
    directory = history_dir(root, create=True)
    for candidate in scan["candidates"]:
        evidence = candidate_history_evidence(candidate, scan, mark_reviewed)
        private_json(directory / f"{evidence['session_id']}.json", evidence)


def candidate_history_evidence(candidate, scan, mark_reviewed=True):
    session_id = history_id(candidate["session_id"], "history session ID")
    cycles = candidate["cycles"]
    identity = candidate.get("_history_identity") or history_identity(cycles)
    return validate_history_evidence({
        "schema_version": 1, "session_id": session_id,
        "completed_at": str(candidate["last_activity"]), **identity, "cycles": cycles,
        "correlation_quality": candidate.get("correlation_quality", "unavailable"),
        "aggregates": history_aggregates(candidate), "snapshot": scan["snapshot"],
        "session_ceiling": scan["session_ceiling"], "part_ceiling": scan["part_ceiling"],
        "database_digest": scan["database_digest"],
        "reviewed_status": "reviewed" if mark_reviewed else candidate.get("reviewed_status", "unreviewed"),
    })


def history_aggregates(candidate):
    states = [item["state"] for item in candidate["cycles"]]
    created, activity = candidate.get("timestamp"), candidate.get("last_activity")
    elapsed = int(activity) - int(created) if str(created).isdigit() and str(activity).isdigit() else "unavailable"
    structural = candidate.get("_history_metrics") if isinstance(candidate.get("_history_metrics"), dict) else {}
    return {"candidate_count": 1, "cycle_count": len(states), "child_count": len(candidate.get("child_session_ids", [])),
            "elapsed_ms": elapsed if isinstance(elapsed, int) and elapsed >= 0 else "unavailable",
            "tool_count": structural.get("tool_count", "unavailable"),
            "tool_call_count": structural.get("tool_call_count", "unavailable"),
            "tool_error_count": structural.get("tool_error_count", "unavailable"),
            "approval_count": "unavailable", "retry_count": "unavailable",
            "cost_total": structural.get("cost_total", "unavailable"),
            "token_total": structural.get("token_total", "unavailable"),
            **{f"cycle_{state}_count": states.count(state) for state in ("active", "blocked", "abandoned", "completed", "unknown")}}


def history_identity(cycles, session_directory=None, session_ids=(), project_digest="unavailable", cache=None):
    """Use only unambiguous Cycle Record structure; never session prose or paths."""
    cache_key = (str(session_directory or ""), tuple(item["cycle_id"] for item in cycles))
    if cache is not None and cache_key in cache:
        return {**cache[cache_key], "project_digest": project_digest}
    directories = []
    worktree = Path(session_directory) if session_directory else None
    if worktree and worktree.is_dir():
        result = git(worktree, "rev-parse", "--git-common-dir", check=False)
        if not result.returncode:
            directory = Path(result.stdout.strip())
            directories.append((directory if directory.is_absolute() else worktree / directory).resolve() / "dbsctr/cycles")
    try:
        current = common_git_dir(root_dir()).resolve() / "dbsctr/cycles"
        if current not in directories:
            directories.append(current)
    except RuntimeError:
        pass
    wanted = {item["cycle_id"] for item in cycles}
    records = []
    paths = sorted({path for directory in directories if directory.is_dir() for path in directory.glob("*.json")})
    for path in paths:
        try:
            value = json.loads(path.read_text(encoding="utf-8"), object_pairs_hook=no_duplicate_keys)
            runtime_ids = value.get("runtime", {}).get("opencode", {}).get("session_ids", [])
            if value.get("cycle_id") in wanted or set(session_ids).intersection(runtime_ids):
                records.append(value)
        except (OSError, json.JSONDecodeError):
            continue
    def same(name, valid):
        values = {item.get(name) for item in records if valid(item.get(name))}
        return values.pop() if len(values) == 1 and len(records) == len(wanted) else "unavailable"
    result = {"method_revision": same("method_revision", lambda value: isinstance(value, str) and re.fullmatch(r"3\.\d+", value)),
              "context": same("context", lambda value: isinstance(value, str) and OPAQUE_ID.fullmatch(value))}
    if cache is not None:
        cache[cache_key] = result
    return {**result, "project_digest": project_digest}


def validate_history_report(value, path=None):
    text_fields = {"findings", "scorecards", "trends", "proposals", "caveats"}
    allowed = {"schema_version", "report_id", "cohort", "evidence", "query_digest", "rubric", *text_fields}
    rubric = value.get("rubric") if isinstance(value, dict) else None
    if (not isinstance(value, dict) or set(value) - allowed or not {"schema_version", "report_id", "cohort", "evidence", "query_digest", "rubric", "findings"} <= set(value) or value.get("schema_version") != 1
            or not isinstance(value.get("report_id"), str) or not isinstance(value.get("cohort"), list)
            or not isinstance(value.get("evidence"), list) or len(value["cohort"]) != len(value["evidence"])
            or len(value["cohort"]) < 1 or len(value["cohort"]) > REVIEW_MAX_LIMIT
            or not isinstance(rubric, dict) or set(rubric) != {"name", "version", "digest"}
            or not all(isinstance(rubric.get(name), str) and rubric[name] for name in ("name", "version"))
            or any(not isinstance(value.get(name, []), list) or len(value.get(name, [])) > 50
                   for name in text_fields)):
        fail("review history report has an invalid schema")
    history_digest(value.get("query_digest"), "query digest")
    history_digest(rubric.get("digest"), "rubric digest")
    def valid_text(item, limit):
        return isinstance(item, str) and 1 <= len(item.encode()) <= limit and not any(ord(char) < 32 or ord(char) == 127 for char in item)
    if not valid_text(rubric["name"], 256) or not valid_text(rubric["version"], 256) or not all(
            valid_text(item, 512) for name in text_fields for item in value.get(name, [])):
        fail("review history report has an invalid schema")
    if review_unsafe(" ".join([rubric["name"], rubric["version"], *(item for name in text_fields for item in value.get(name, []))])):
        fail("review history report contains unsafe content")
    expected = hashlib.sha256(json.dumps({key: value[key] for key in value if key != "report_id"}, sort_keys=True,
                                         separators=(",", ":")).encode()).hexdigest()[:24]
    if value["report_id"] != expected or path is not None and path.name != f"{expected}.json":
        fail("review history report marker does not match its content")
    ids = [history_id(item, "history cohort ID") for item in value["cohort"]]
    if len(set(ids)) != len(ids):
        fail("review history report has duplicate cohort IDs")
    records = [validate_history_evidence(item) for item in value["evidence"]]
    if [item["session_id"] for item in records] != ids:
        fail("review history report evidence does not match its cohort")
    return value


def history_report(path):
    try:
        value = json.loads(path.read_text(encoding="utf-8"), object_pairs_hook=no_duplicate_keys)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"invalid review history report: {error}")
    return validate_history_report(value, path)


def history_reports(root):
    if ledger_exists(root):
        with ledger_connection(root) as connection:
            return [validate_history_report(json.loads(payload, object_pairs_hook=no_duplicate_keys))
                    for payload, in connection.execute(
                        "SELECT payload FROM history_reports WHERE kind='report' ORDER BY report_id")]
    directory = history_dir(root, "reports")
    if not directory.is_dir():
        return []
    return [history_report(path) for path in sorted(directory.glob("*.json"))]


def history_cohorts(root):
    if ledger_exists(root):
        with ledger_connection(root) as connection:
            return [validate_history_report(json.loads(payload, object_pairs_hook=no_duplicate_keys))
                    for payload, in connection.execute(
                        "SELECT payload FROM history_reports WHERE kind='cohort' ORDER BY report_id")]
    directory = history_dir(root, "cohorts")
    if not directory.is_dir():
        return []
    return [history_report(path) for path in sorted(directory.glob("*.json"))]


def validate_history_report_input(value):
    text_fields = ("findings", "scorecards", "trends", "proposals", "caveats")
    scan_fields = ("snapshot", "session_ceiling", "part_ceiling", "database_digest")
    allowed = {"schema_version", "cohort", "query_digest", "rubric", *text_fields, *scan_fields}
    if (not isinstance(value, dict) or set(value) - allowed
            or not {"schema_version", "cohort", "query_digest", "rubric", "findings"} <= set(value)
            or value.get("schema_version") != 1):
        fail("review history report has an invalid schema")
    cohort = value["cohort"]
    if not isinstance(cohort, list) or not 1 <= len(cohort) <= REVIEW_MAX_LIMIT:
        fail("review history report has an invalid cohort")
    ids = [history_id(item, "history cohort ID") for item in cohort]
    if len(set(ids)) != len(ids):
        fail("review history report has duplicate cohort IDs")
    history_digest(value.get("query_digest"), "query digest")
    rubric = value.get("rubric")
    if not isinstance(rubric, dict) or set(rubric) != {"name", "version", "digest"}:
        fail("review history report has an invalid schema")
    history_digest(rubric.get("digest"), "rubric digest")
    def valid_text(item, limit):
        return (isinstance(item, str) and 1 <= len(item.encode()) <= limit
                and not any(ord(char) < 32 or ord(char) == 127 for char in item))
    if not valid_text(rubric.get("name"), 256) or not valid_text(rubric.get("version"), 256):
        fail("review history report has an invalid schema")
    for name in text_fields:
        items = value.get(name, [])
        if (not isinstance(items, list) or len(items) > 50
                or not all(valid_text(item, 512) for item in items)):
            fail("review history report has an invalid schema")
    if review_unsafe(" ".join([rubric["name"], rubric["version"],
                               *(item for name in text_fields for item in value.get(name, []))])):
        fail("review history report contains unsafe content")
    present_scan = {name for name in scan_fields if name in value}
    if present_scan and present_scan != set(scan_fields):
        fail("review history report has incomplete scan identity")
    if present_scan:
        if any(type(value[name]) is not int or value[name] < 0 for name in scan_fields[:3]):
            fail("review history report has invalid scan identity")
        history_digest(value["database_digest"], "database digest")
    return {**value, **{name: value.get(name, []) for name in text_fields}}


def command_review_history(args):
    root = review_root(args.state_root)
    excluded_family = historical_excluded_family(args.database, args.excluded_session_id,
                                                 args.excluded_message_id)
    if args.limit < 1 or args.limit > REVIEW_MAX_LIMIT or args.cursor < 0:
        fail("review history limit must be 1 through 100 and cursor non-negative")
    require_review_lock_safe(root)
    with existing_review_lock(root):
        records = history_evidence(root)
        reports = history_reports(root)
        history_cohorts(root)  # Fail closed on malformed retained replay evidence.
        if args.replay:
            report = next((item for item in reports if item["report_id"] == args.replay), None)
            if report is None:
                fail("review history replay report is missing")
            if set(report["cohort"]).intersection(excluded_family):
                fail("review history replay intersects the excluded session family")
            records = report["evidence"]
        elif not args.archive_only:
            live = review_scan(argparse.Namespace(database=args.database, state_root=args.state_root,
                               limit=REVIEW_MAX_LIMIT, cursor=0, snapshot=args.snapshot,
                               session_ceiling=args.session_ceiling, part_ceiling=args.part_ceiling,
                                database_digest=args.database_digest, lock_held=True,
                                 include_reviewed=True, history_metrics=True, history_all=True, bind_history=True,
                                  excluded_session_id=args.excluded_session_id,
                                  excluded_message_id=args.excluded_message_id,
                                  exclusion_digest=args.exclusion_digest))
            live_candidates = live["candidates"]
            live_records = [{"schema_version": 1, "session_id": item["session_id"],
                            "completed_at": str(item["last_activity"]),
                            **item.get("_history_identity", history_identity(item["cycles"])),
                             "cycles": item["cycles"],
                             "correlation_quality": item.get("correlation_quality", "unavailable"),
                             "aggregates": history_aggregates(item),
                            "snapshot": live["snapshot"], "session_ceiling": live["session_ceiling"],
                            "part_ceiling": live["part_ceiling"], "database_digest": live["database_digest"],
                            "reviewed_status": item["reviewed_status"]} for item in live_candidates]
            archived = {item["session_id"]: item for item in records}
            records = [{**archived.get(item["session_id"], {}), **item} for item in live_records]
            records.extend(item for key, item in archived.items() if key not in {row["session_id"] for row in live_records})
            records = [item for item in records if item["session_id"] not in excluded_family]
        else:
            records = [item for item in records if item["session_id"] not in excluded_family]
        for name, value in (("after", args.after), ("before", args.before)):
            if value is not None and value < REVIEW_START_MS:
                fail(f"review history {name} must be a valid millisecond cutoff")
        if args.after is not None and args.before is not None and args.after > args.before:
            fail("review history after must not exceed before")
        def include(record):
            timestamp = int(record["completed_at"])
            return ((args.after is None or timestamp >= args.after) and (args.before is None or timestamp <= args.before)
                    and (args.method_revision is None or record["method_revision"] == args.method_revision)
                    and (args.context is None or record["context"] == args.context)
                    and (args.project_digest is None or record["project_digest"] == args.project_digest)
                    and (args.reviewed_status is None or record.get("reviewed_status", "reviewed") == args.reviewed_status)
                    and (args.cycle_id is None or any(cycle["cycle_id"] == args.cycle_id for cycle in record["cycles"]))
                    and (args.state is None or any(cycle["state"] == args.state for cycle in record["cycles"])))
        records = sorted((record for record in records if include(record)),
                         key=lambda item: (int(item["completed_at"]), item["session_id"]), reverse=True)
        page = records[args.cursor:args.cursor + args.limit]
        metadata = ({} if args.replay else live if not args.archive_only else
                    (page[-1] if page else (records[-1] if records else {})))
        result = {"schema_version": 1, "candidates": page, "session_ids": [item["session_id"] for item in page],
                  "limit": args.limit, "cursor": args.cursor,
                  "continuation": args.cursor + args.limit if len(records) > args.cursor + args.limit else None,
                  "snapshot": metadata.get("snapshot"), "session_ceiling": metadata.get("session_ceiling"),
                   "part_ceiling": metadata.get("part_ceiling"), "database_digest": metadata.get("database_digest"),
                   "exclusion_digest": metadata.get("exclusion_digest")}
        result["digest"] = review_digest(page, result["snapshot"], result["session_ceiling"],
                                         result["part_ceiling"], result["database_digest"])
        for name in ("snapshot", "session_ceiling", "part_ceiling", "database_digest", "exclusion_digest"):
            supplied = getattr(args, name)
            if args.replay and supplied is not None:
                fail("review history replay uses its report ID and cursor, not a live snapshot")
            if supplied is not None and supplied != result[name]:
                fail("review history replay does not match its immutable snapshot")
    encoded = json.dumps(result, sort_keys=True, separators=(",", ":"), ensure_ascii=True)
    if len(encoded.encode()) > HISTORY_SCAN_HARD:
        fail("review history response exceeds bound")
    print(encoded)


def command_review_migrate(args):
    root = review_root(args.state_root)
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        if ledger_exists(root):
            with ledger_connection(root, write=True) as connection:
                recover_forget_state(root, connection)
                ledger_integrity(connection)
                digest = content_digest(ledger_content(connection))
            print(json.dumps({"migrated": False, "digest": digest}, sort_keys=True))
            return
        legacy_json_files(root)
        index = review_index(root)
        reports = [(path.stem, report) for path, report, _ in review_reports(root)]
        evidence = sorted(history_evidence(root), key=lambda item: item["session_id"])
        saved_reports = sorted(((item["report_id"], item) for item in history_reports(root)))
        cohorts = sorted(((item["report_id"], item) for item in history_cohorts(root)))
        source = {"index": index, "review_reports": reports, "history_evidence": evidence,
                  "history_reports": saved_reports, "history_cohorts": cohorts}
        source_digest = content_digest(source)
        backup_name, backup_digest = backup_legacy_json(root)
        directory = root / "reviews"
        descriptor, temporary = tempfile.mkstemp(prefix=".ledger-migrate-", suffix=".sqlite3", dir=directory)
        os.close(descriptor)
        temporary = Path(temporary)
        try:
            os.chmod(temporary, 0o600)
            connection = sqlite3.connect(temporary)
            connection.execute("PRAGMA foreign_keys=ON")
            connection.execute("PRAGMA synchronous=FULL")
            ledger_schema(connection)
            connection.commit()
            connection.execute("BEGIN IMMEDIATE")
            names = {"sessions": "session", "cycles": "cycle", "forgotten_sessions": "forgotten_session"}
            for field, kind in names.items():
                connection.executemany("INSERT INTO review_tombstones VALUES (?, ?, ?)",
                                       ((kind, key, value) for key, value in index[field].items()))
            for report_id, report in reports:
                ledger_put_review_report(connection, report_id, report)
            for item in evidence:
                ledger_put_history_evidence(connection, item)
            for _, item in saved_reports:
                ledger_put_history_report(connection, "report", item)
            for _, item in cohorts:
                ledger_put_history_report(connection, "cohort", item)
            connection.execute("INSERT INTO ledger_meta VALUES ('migration_digest', ?)", (source_digest,))
            connection.commit()
            ledger_integrity(connection)
            if content_digest(ledger_content(connection)) != source_digest:
                fail("private review ledger migration content mismatch")
            connection.close()
            os.replace(temporary, ledger_path(root))
            os.chmod(ledger_path(root), 0o600)
        except Exception:
            if "connection" in locals():
                connection.close()
            raise
        finally:
            temporary.unlink(missing_ok=True)
    print(json.dumps({"migrated": True, "digest": source_digest, "backup": backup_name,
                      "backup_digest": backup_digest}, sort_keys=True))


def command_review_backup(args):
    root = review_root(args.state_root)
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        connection = ledger_connection(root, write=True)
        recover_forget_state(root, connection)
        connection.close()
        name, digest = create_ledger_backup(root)
    print(json.dumps({"backup": name, "digest": digest}, sort_keys=True))


def command_review_restore(args):
    root = review_root(args.state_root)
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]{0,127}\.sqlite3", args.backup):
        fail("invalid private review backup name")
    source_path = root / "reviews" / "backups" / args.backup
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        connection = ledger_connection(root, write=True)
        recover_forget_state(root, connection)
        connection.close()
        if source_path.is_symlink() or not source_path.is_file():
            fail("private review backup is missing or unsafe")
        if source_path.stat().st_mode & 0o077:
            fail("private review backup permissions are too broad")
        forgotten = review_index(root)["forgotten_sessions"]
        with ledger_connection(root, path=source_path) as source:
            ledger_integrity(source)
        rollback, _ = create_ledger_backup(root, prefix="rollback")
        directory = root / "reviews"
        descriptor, temporary = tempfile.mkstemp(prefix=".ledger-restore-", suffix=".sqlite3", dir=directory)
        os.close(descriptor)
        temporary = Path(temporary)
        try:
            os.chmod(temporary, 0o600)
            source = ledger_connection(root, path=source_path)
            destination = sqlite3.connect(temporary)
            source.backup(destination)
            destination.commit()
            source.close()
            destination.close()
            restored = ledger_connection(root, write=True, path=temporary)
            try:
                restored.execute("BEGIN IMMEDIATE")
                for session_id, timestamp in forgotten.items():
                    dependent = [row[0] for row in restored.execute(
                        "SELECT report_id FROM history_report_members WHERE session_id=?", (session_id,))]
                    restored.execute("DELETE FROM history_evidence WHERE session_id=?", (session_id,))
                    for report_id in dependent:
                        restored.execute("DELETE FROM ledger_entries WHERE scope='history' AND report_id=?", (report_id,))
                        restored.execute("DELETE FROM history_reports WHERE report_id=?", (report_id,))
                    restored.execute(
                        "INSERT INTO review_tombstones VALUES ('forgotten_session', ?, ?) "
                        "ON CONFLICT(kind, item_id) DO UPDATE SET timestamp=max(timestamp, excluded.timestamp)",
                        (session_id, timestamp),
                    )
                restored.commit()
            except Exception:
                restored.rollback()
                raise
            finally:
                restored.close()
            with ledger_connection(root, path=temporary) as check:
                ledger_integrity(check)
            os.replace(temporary, ledger_path(root))
            os.chmod(ledger_path(root), 0o600)
        finally:
            temporary.unlink(missing_ok=True)
    print(json.dumps({"restored": args.backup, "rollback": rollback}, sort_keys=True))


def command_review_history_save(args):
    try:
        report = validate_history_report_input(json.loads(args.report_json, object_pairs_hook=no_duplicate_keys))
    except json.JSONDecodeError as error:
        fail(f"cannot read review history report: {error}")
    root = review_root(args.state_root)
    excluded_family = historical_excluded_family(args.database, args.excluded_session_id,
                                                 args.excluded_message_id)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        connection = ensure_ledger_for_write(root)
        records = {item["session_id"]: item for item in history_evidence(root)}
        text_fields = {"findings", "scorecards", "trends", "proposals", "caveats"}
        scan_fields = {"snapshot", "session_ceiling", "part_ceiling", "database_digest"}
        cohort = report["cohort"]
        ids = [history_id(item, "history cohort ID") for item in cohort]
        if set(ids).intersection(excluded_family):
            fail("review history report cohort contains an excluded session")
        missing = [item for item in ids if item not in records]
        if missing:
            if (any(type(report.get(name)) is not int for name in ("snapshot", "session_ceiling", "part_ceiling"))
                    or not isinstance(report.get("database_digest"), str)):
                fail("review history report cohort evidence is unavailable")
            history_digest(report["database_digest"], "database digest")
            scan = review_scan(argparse.Namespace(
                database=args.database, state_root=args.state_root, limit=REVIEW_MAX_LIMIT,
                cursor=0, snapshot=report["snapshot"],
                session_ceiling=report["session_ceiling"], part_ceiling=report["part_ceiling"],
                database_digest=report["database_digest"], lock_held=True,
                include_reviewed=True, history_metrics=True, history_all=True, bind_history=True,
                 excluded_session_id=args.excluded_session_id,
                 excluded_message_id=args.excluded_message_id,
            ))
            candidates = scan["candidates"]
            if set(ids).intersection(scan["_excluded_session_ids"]):
                fail("review history report cohort contains an excluded session")
            selected = {item["session_id"]: item for item in candidates if item["session_id"] in missing}
            if set(selected) != set(missing):
                fail("review history report cohort evidence is unavailable")
            archive = {"snapshot": report["snapshot"], "session_ceiling": report["session_ceiling"],
                       "part_ceiling": report["part_ceiling"], "database_digest": report["database_digest"]}
            captured = {key: candidate_history_evidence(value, archive, mark_reviewed=False)
                        for key, value in selected.items()}
            records.update(captured)
        else:
            captured = {}
        stored = {key: value for key, value in report.items() if key not in scan_fields}
        stored.update({name: report.get(name, []) for name in text_fields})
        stored["evidence"] = [records[item] for item in ids]
        report_id = hashlib.sha256(json.dumps(stored, sort_keys=True, separators=(",", ":")).encode()).hexdigest()[:24]
        stored["report_id"] = report_id
        history_report_value = validate_history_report(stored)
        try:
            connection.execute("BEGIN IMMEDIATE")
            ledger_put_history_report(connection, "report", history_report_value)
            connection.commit()
        except Exception:
            connection.rollback()
            raise
        finally:
            connection.close()
    print(json.dumps({"report_id": report_id}, sort_keys=True))


def command_review_complete(args):
    try:
        raw_report = args.report_json if args.report_json is not None else Path(args.report).read_text(encoding="utf-8")
        report = json.loads(raw_report, object_pairs_hook=no_duplicate_keys)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read review report: {error}")
    text_fields = ("findings", "scorecards", "trends", "proposals", "caveats")
    allowed = {"session_ids", "cycle_ids", "scan_digest", "snapshot", "session_ceiling", "part_ceiling", "database_digest",
               "exclusion_digest", "limit", "cursor", "decision", "notes", *text_fields}
    if not isinstance(report, dict) or set(report) - allowed:
        fail("review report has an invalid schema")
    sessions, cycles = report.get("session_ids"), report.get("cycle_ids", [])
    if (not isinstance(sessions, list) or not sessions or not isinstance(cycles, list)
            or not all(isinstance(value, str) and re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]{0,127}", value)
                       for value in sessions + cycles)
            or len(sessions) > REVIEW_MAX_LIMIT or len(cycles) > REVIEW_MAX_LIMIT):
        fail("review report has invalid IDs")
    if len(set(sessions)) != len(sessions) or len(set(cycles)) != len(cycles):
        fail("review report IDs must be unique")
    decision, notes = report.get("decision"), report.get("notes")
    if not isinstance(decision, str) or not 1 <= len(decision.encode()) <= 256:
        fail("review report has invalid decision")
    if notes is not None and (not isinstance(notes, str) or len(notes.encode()) > 2048):
        fail("review report has invalid notes")
    digest = report.get("scan_digest")
    if not isinstance(digest, str) or args.scan_digest != digest:
        fail("review report does not match scan digest")
    if (type(report.get("snapshot")) is not int or type(report.get("session_ceiling")) is not int
            or type(report.get("part_ceiling")) is not int or type(report.get("limit")) is not int
            or type(report.get("cursor")) is not int or not 1 <= report["limit"] <= REVIEW_MAX_LIMIT
            or report["cursor"] < 0 or not 0 <= report["session_ceiling"] <= 2**63 - 1
            or not 0 <= report["part_ceiling"] <= 2**63 - 1
            or not isinstance(report.get("database_digest"), str)
            or not re.fullmatch(r"[0-9a-f]{64}", report["database_digest"])
            or report.get("exclusion_digest") is not None
            and not re.fullmatch(r"[0-9a-f]{64}", report["exclusion_digest"])):
        fail("review report requires its scan snapshot, limit, and cursor")
    for name in text_fields:
        values = report.get(name, [])
        if (not isinstance(values, list) or len(values) > 50
                or not all(isinstance(value, str) and 1 <= len(value) <= 512 for value in values)):
            fail(f"review report has invalid {name}")
    # Digests and opaque OpenCode IDs can be high entropy by design; inspect only human text.
    human_text = [str(report.get(name, "")) for name in ("decision", "notes")]
    human_text.extend(value for name in text_fields for value in report.get(name, []))
    if review_unsafe(" ".join(human_text)):
        fail("review report contains unsafe content")
    root = review_root(args.state_root)
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        current_sessions, _ = reviewed_ids(args.state_root, lock=False)
        if current_sessions.intersection(sessions):
            fail("review page was already completed")
        expected = review_scan(argparse.Namespace(
            database=args.database, state_root=args.state_root,
            limit=report["limit"], cursor=report["cursor"], snapshot=report["snapshot"],
            session_ceiling=report["session_ceiling"], part_ceiling=report["part_ceiling"],
            database_digest=report["database_digest"],
            lock_held=True,
            history_metrics=True,
            excluded_session_id=args.excluded_session_id,
            excluded_message_id=args.excluded_message_id,
            exclusion_digest=report.get("exclusion_digest"),
        ))
        if (expected["session_ids"] != sessions or expected["cycle_ids"] != cycles
                or expected["digest"] != digest):
            fail("review report does not match the current scan page")
        forgotten = review_index(root)["forgotten_sessions"]
        reviewed_at = max(int(datetime.now(timezone.utc).timestamp() * 1000), report["snapshot"] + 1,
                          *(forgotten.get(value, 0) + 1 for value in sessions))
        persisted = {key: value for key, value in report.items() if key != "exclusion_digest"}
        persisted.update({"cycle_ids": cycles, "reviewed_at": reviewed_at})
        name = hashlib.sha256((digest + "\0" + json.dumps(persisted, sort_keys=True)).encode()).hexdigest()[:24]
        connection = ensure_ledger_for_write(root)
        try:
            connection.execute("BEGIN IMMEDIATE")
            pruned = prune_review_reports(root, connection=connection)
            archive_review_candidates(root, expected, connection=connection)
            ledger_put_review_report(connection, name, persisted)
            connection.commit()
        except Exception:
            connection.rollback()
            raise
        finally:
            connection.close()
    print(json.dumps({"digest": digest, "reviewed_sessions": len(sessions),
                      "reviewed_cycles": len(cycles), "pruned_reports": pruned}, sort_keys=True))


def command_review_prune(args):
    root = review_root(args.state_root)
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        connection = ensure_ledger_for_write(root)
        try:
            connection.execute("BEGIN IMMEDIATE")
            removed = prune_review_reports(root, connection=connection)
            connection.commit()
        except Exception:
            connection.rollback()
            raise
        finally:
            connection.close()
    print(json.dumps({"pruned_reports": removed}, sort_keys=True))


def command_review_forget(args):
    root = review_root(args.state_root)
    if not OPAQUE_ID.fullmatch(args.session_id):
        fail("invalid review forget ID")
    require_review_lock_safe(root)
    with review_lock(root) as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        connection = ensure_ledger_for_write(root)
        history_evidence(root)
        reports = history_reports(root)
        cohorts = history_cohorts(root)
        dependent = {item["report_id"] for item in reports + cohorts if args.session_id in item["cohort"]}
        value = review_index(root)
        session_times = [timestamp for _, report, timestamp in review_reports(root)
                         if args.session_id in report["session_ids"]]
        session_times.append(value["sessions"].get(args.session_id, 0))
        removed = args.session_id in reviewed_ids_unlocked(root)[0]
        forgotten_at = max(int(datetime.now(timezone.utc).timestamp() * 1000), max(session_times) + 1)
        staged = None
        quarantine_name = f".forget-{uuid.uuid4().hex}"
        try:
            connection.execute("BEGIN IMMEDIATE")
            prune_review_reports(root, connection=connection)
            connection.execute("DELETE FROM history_evidence WHERE session_id=?", (args.session_id,))
            for report_id in dependent:
                connection.execute("DELETE FROM ledger_entries WHERE scope='history' AND report_id=?", (report_id,))
                connection.execute("DELETE FROM history_reports WHERE report_id=?", (report_id,))
            connection.execute(
                "INSERT INTO review_tombstones VALUES ('forgotten_session', ?, ?) "
                "ON CONFLICT(kind, item_id) DO UPDATE SET timestamp=max(timestamp, excluded.timestamp)",
                (args.session_id, forgotten_at),
            )
            connection.execute("INSERT INTO ledger_meta VALUES ('pending_forget_cleanup', ?)",
                               (quarantine_name,))
            staged = stage_pre_forget_state(root, quarantine_name)
            connection.commit()
        except Exception:
            connection.rollback()
            if staged is not None:
                restore_staged_forget(*staged)
            connection.close()
            raise
        recover_forget_state(root, connection)
        connection.close()
    print(json.dumps({"forgotten": removed}, sort_keys=True))


def command_review(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    if args.result == "changed" and not args.path:
        fail("changed artifact review requires --path")
    if args.path:
        expected = f"docs/specs/{record['context']}/{args.name}.md"
        if args.path != expected:
            fail(f"{args.name} path must be {expected}")
        safe_paths(root, [args.path])
    record["artifact_reviews"][args.name] = {
        "result": args.result, "reason": args.reason, "path": args.path,
        "reviewed_at": now()
    }
    save(path, record)


def evidence_text(value, limit, name):
    try:
        raw = value.encode("utf-8")
    except UnicodeEncodeError:
        fail(f"{name} must be UTF-8")
    if not value or len(raw) > limit or any(ord(char) < 32 or ord(char) == 127 for char in value):
        fail(f"invalid {name}")
    if SECRET_VALUE.search(value) or HIGH_ENTROPY.search(value):
        fail(f"unsafe {name}")
    return value


def redact_argument(value):
    if SECRET_VALUE.search(value) or HIGH_ENTROPY.search(value) or value.startswith("op://"):
        return "[REDACTED]"
    if "://" in value and re.search(r"://[^/@:]+:[^/@]+@", value):
        return "[REDACTED]"
    return value


def sanitized_argv(argv):
    if not argv or len(argv) > 64:
        fail("argv must contain 1 through 64 entries")
    output = []
    for index, value in enumerate(argv):
        if not isinstance(value, str) or "\0" in value:
            fail("invalid argv")
        if index == 0:
            name = Path(value).name
            output.append(name if name and not SECRET_VALUE.search(name) and not HIGH_ENTROPY.search(name) else "[REDACTED]")
        elif value.startswith("--"):
            output.append(value.partition("=")[0] + ("=[REDACTED]" if "=" in value else ""))
        elif value in ("-q", "-v", "-s", "-x", "-n"):
            output.append(value)
        else:
            output.append("[REDACTED]")
    if len(json.dumps(output, ensure_ascii=True, separators=(",", ":")).encode()) > 4096:
        fail("serialized argv exceeds 4096 bytes")
    return output


def safe_output(raw):
    if not raw:
        return {"status": "no_content"}, None
    try:
        text = raw.decode("utf-8")
    except UnicodeDecodeError:
        return {"status": "withheld", "reason": "non_utf8"}, None
    if (SECRET_VALUE.search(text) or HIGH_ENTROPY.search(text) or "://" in text
            or re.search(r"(?:^|\s)(?:/|~)[^\s]+", text) or any(ord(char) < 32 and char not in "\n\r\t" for char in text)):
        return {"status": "withheld", "reason": "unclassified"}, None
    lines = [line for line in text.splitlines() if line]
    if not lines or not all(SAFE_EVIDENCE_LINE.fullmatch(line) for line in lines):
        return {"status": "withheld", "reason": "unclassified"}, None
    return None, text.encode("utf-8")


def write_sidecar(root, cycle_id, data):
    digest = hashlib.sha256(data).hexdigest()
    parent = common_git_dir(root) / "dbsctr" / "evidence"
    directory = parent / cycle_id
    for candidate in (parent, directory):
        if candidate.is_symlink():
            fail("unsafe evidence directory")
        candidate.mkdir(parents=True, exist_ok=True, mode=0o700)
        os.chmod(candidate, 0o700)
        candidate_stat = candidate.stat()
        if candidate_stat.st_uid != os.getuid() or candidate_stat.st_mode & 0o777 != 0o700:
            fail("unsafe evidence directory")
    target = directory / digest
    if target.exists() or target.is_symlink():
        stat = target.lstat()
        if (not target.is_file() or target.is_symlink() or stat.st_uid != os.getuid()
                or stat.st_mode & 0o777 != 0o600 or stat.st_size != len(data)
                or hashlib.sha256(target.read_bytes()).hexdigest() != digest):
            fail("unsafe evidence sidecar")
        return digest
    descriptor, temporary = tempfile.mkstemp(dir=directory)
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "wb") as handle:
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
        try:
            os.link(temporary, target)
        except FileExistsError:
            pass
    finally:
        Path(temporary).unlink(missing_ok=True)
    return digest


def verify_envelope(root, record, gate_name, require_bound=False, require_head=True):
    gate = record["gates"][gate_name]
    evidence_id = gate.get("evidence")
    item = record.get("evidence", {}).get("items", {}).get(evidence_id)
    if not item or item.get("gate") != gate_name or item.get("result") != gate.get("result"):
        fail(f"invalid evidence for gate: {gate_name}")
    if require_head and item.get("head") != git(root, "rev-parse", "HEAD").stdout.strip():
        fail(f"evidence HEAD is stale: {gate_name}")
    if require_bound and not item.get("commit"):
        fail(f"evidence is not bound to a commit: {gate_name}")
    content = item.get("content", {})
    if content.get("status") == "sidecar":
        if content.get("path") != f"evidence/{record['cycle_id']}/{content.get('sha256')}":
            fail("invalid evidence sidecar path")
        target = common_git_dir(root) / "dbsctr" / content["path"]
        if (not target.exists() or target.is_symlink() or not target.is_file() or target.stat().st_uid != os.getuid()
                or target.stat().st_mode & 0o777 != 0o600 or target.stat().st_size != content.get("byte_count")
                or hashlib.sha256(target.read_bytes()).hexdigest() != content.get("sha256")):
            fail("invalid evidence sidecar")
    elif content.get("status") not in ("withheld", "no_content"):
        fail("invalid evidence content")
    return item


def evidence_path_blobs(root, paths, index=False, commit=None):
    if not paths:
        return {}
    result = {}
    for name in paths if index or commit else safe_paths(root, paths):
        if commit:
            value = git(root, "rev-parse", "--verify", f"{commit}:{name}", check=False)
        elif index:
            value = git(root, "rev-parse", "--verify", f":{name}", check=False)
        elif os.path.lexists(root / name):
            value = git(root, "hash-object", "--path", name, "--", name, check=False)
        else:
            value = None
        result[name] = value.stdout.strip() if value and value.returncode == 0 else None
    return result


def command_record_evidence(args):
    root = root_dir()
    authority = evidence_text(args.authority, 128, "authority")
    argv, sanitized = list(args.program), sanitized_argv(args.program)
    path_blobs = evidence_path_blobs(root, args.path or [])
    with evidence_lock(root, active_path(root).read_text(encoding="utf-8").strip()):
        path, record = load(root)
        require_active(record)
        if record.get("schema_version") != 3:
            fail("record-evidence requires a schema 3 Cycle Record")
        gate = record["gates"][args.gate]
        if gate["applicability"] != "required":
            fail("evidence gate is not required")
        started, observed, cutoff, start_error = now(), 0, None, False
        raw = bytearray()
        try:
            process = subprocess.Popen(argv, cwd=root, stdin=subprocess.DEVNULL, stdout=subprocess.PIPE,
                                       stderr=subprocess.STDOUT, shell=False, start_new_session=True)
            selector = selectors.DefaultSelector()
            selector.register(process.stdout, selectors.EVENT_READ)
            deadline = datetime.now(timezone.utc).timestamp() + args.timeout
            while selector.get_map() and not cutoff:
                remaining = deadline - datetime.now(timezone.utc).timestamp()
                if remaining <= 0:
                    cutoff = "timeout"
                    break
                for key, _ in selector.select(remaining):
                    block = os.read(key.fd, 65536)
                    if not block:
                        selector.unregister(key.fileobj)
                        continue
                    observed += len(block)
                    raw.extend(block[:max(0, EVIDENCE_RAW_CAP - len(raw))])
                    if observed > EVIDENCE_RAW_CAP:
                        cutoff = "overflow"
                        break
            if cutoff:
                os.killpg(process.pid, signal.SIGTERM)
                try:
                    process.wait(timeout=1)
                except subprocess.TimeoutExpired:
                    pass
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except ProcessLookupError:
                    pass
            process.wait(timeout=2)
            selector.close()
        except subprocess.TimeoutExpired:
            cutoff = "timeout"
            if process:
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except ProcessLookupError:
                    pass
                process.wait()
        except OSError:
            start_error, process = True, None
        finished = now()
        result = "unavailable" if start_error or cutoff else "passed" if process.returncode == 0 else "failed"
        if result == "passed":
            incomplete = [name for name in GATES[:GATES.index(args.gate)] if not disposed(record["gates"][name])]
            if incomplete:
                fail("gate predecessors are incomplete: " + ", ".join(incomplete))
        content, retained = ({"status": "withheld", "reason": cutoff or "start_failed"}, None) if (cutoff or start_error) else safe_output(bytes(raw))
        envelope = {"id": "ev-" + uuid.uuid4().hex, "gate": args.gate, "authority": authority,
                    "argv": sanitized, "paths": path_blobs,
                    "head": git(root, "rev-parse", "HEAD").stdout.strip(),
                    "started_at": started, "finished_at": finished, "result": result,
                    "raw": {"byte_count": observed, "lower_bound": bool(cutoff), "truncated": bool(cutoff)},
                    "summary": "passed" if result == "passed" else "failed" if result == "failed" else "unavailable", "urls": []}
        if retained is not None:
            retained, truncated = retained[:EVIDENCE_SIDECAR_CAP], len(retained) > EVIDENCE_SIDECAR_CAP
            digest = write_sidecar(root, record["cycle_id"], retained)
            content = {"status": "sidecar", "path": f"evidence/{record['cycle_id']}/{digest}", "sha256": digest,
                       "byte_count": len(retained), "truncated": truncated}
        envelope["content"] = content
        evidence_id = envelope["id"]
        record["evidence"]["items"][evidence_id] = envelope
        gate.pop("exception", None)
        gate.update({"result": result, "evidence": evidence_id})
        save(path, record)
        print(evidence_id)


def command_set_gate(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    gate = record["gates"][args.gate]
    if record.get("schema_version") == 3 and args.evidence is not None:
        item = record["evidence"]["items"].get(args.evidence)
        if not item or item["gate"] != args.gate or item["result"] != args.result:
            fail("schema 3 evidence must be a matching stored evidence ID")
        if item["head"] != git(root, "rev-parse", "HEAD").stdout.strip():
            fail("schema 3 evidence HEAD is stale")
    if is_v32(record) and args.result == "passed":
        incomplete = [name for name in GATES[:GATES.index(args.gate)] if not disposed(record["gates"][name])]
        if incomplete:
            fail("gate predecessors are incomplete: " + ", ".join(incomplete))
    if gate["applicability"] == "required" and args.result == "not_run":
        fail("required gates cannot use not_run")
    if gate["applicability"] == "not_applicable" and args.result != "not_run":
        fail("not_applicable gates can only use not_run")
    if gate["applicability"] == "required" and args.result in ("passed", "failed", "unavailable") and not args.evidence:
        fail(f"{args.result} required gate needs evidence")
    was_disposed = disposed(gate)
    gate.pop("exception", None)
    gate["result"] = args.result
    if args.evidence is not None:
        gate["evidence"] = args.evidence
    elif args.result == "pending":
        gate.pop("evidence", None)
    if is_v32(record) and was_disposed and not disposed(gate):
        invalidate_later(record, args.gate)
    save(path, record)


def command_set_applicability(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    gate = record["gates"][args.gate]
    if is_v32(record):
        if args.value != "required" or gate["applicability"] != "not_applicable":
            fail("V3.2 applicability may only tighten from not_applicable to required")
        gate.update({"applicability": "required", "result": "pending"})
        gate.pop("reason", None)
        gate.pop("exception", None)
        invalidate_later(record, args.gate)
        record["applicability_plan"]["gates"][args.gate] = {"applicability": "required"}
        save(path, record)
        return
    gate["applicability"] = args.value
    if args.value == "not_applicable":
        if not args.reason:
            fail("not_applicable needs a reason")
        gate.update({"result": "not_run", "reason": args.reason})
    else:
        gate.update({"result": "pending"})
        gate.pop("reason", None)
    gate.pop("exception", None)
    save(path, record)


def command_raise_risk(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    if not is_v32(record):
        fail("raise-risk requires a V3.2 Cycle Record")
    if RISK_RANK[args.to] <= RISK_RANK[record["risk"]]:
        fail("risk may only increase")
    previous = record["risk"]
    apply_stricter_plan(root, record, read_plan(args.plan))
    record["risk"] = args.to
    record.setdefault("risk_history", []).append({
        "from": previous, "to": args.to, "reason": args.reason, "raised_at": now(),
    })
    save(path, record)


def command_update_plan(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    if not is_v32(record):
        fail("update-plan requires a V3.2 Cycle Record")
    apply_stricter_plan(root, record, read_plan(args.plan))
    save(path, record)


def command_approve_exception(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    gate = record["gates"][args.gate]
    if gate["applicability"] != "required" or gate["result"] not in ("failed", "unavailable"):
        fail("only a failed or unavailable required gate can receive an exception")
    gate["exception"] = {
        "kind": args.kind, "rationale": args.rationale, "owner": args.owner,
        "review_condition": args.review_condition, "approved_at": now(),
    }
    save(path, record)


def command_record_dvc_push(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    if not ((root / ".dvc").exists() or (root / "dvc.yaml").exists()):
        fail("repository does not use DVC")
    head = git(root, "rev-parse", "HEAD").stdout.strip()
    if args.head != head:
        fail("DVC push evidence must match current HEAD")
    record["dvc_push"] = {"head": head, "evidence": args.evidence, "recorded_at": now()}
    save(path, record)


def safe_paths(root, paths):
    if not paths:
        fail("at least one path is required")
    cleaned = []
    for name in paths:
        pure = PurePosixPath(name)
        if pure.is_absolute() or ".." in pure.parts or name.startswith(".") and name == ".":
            fail(f"path must be repo-relative: {name}")
        basename = pure.name.lower()
        if basename == ".env" or basename.startswith(".env.") or basename in SECRET_NAMES or pure.suffix.lower() in (".key", ".pem"):
            fail(f"refusing possible secret path: {name}")
        tracked = git(root, "ls-files", "--error-unmatch", "--", name, check=False).returncode == 0
        if not (root / pure).is_file() and not tracked:
            fail(f"path does not exist: {name}")
        if git(root, "check-ignore", "--quiet", "--", name, check=False).returncode == 0:
            fail(f"path is ignored: {name}")
        cleaned.append(name)
    return cleaned


def command_gate_commit(args):
    root = root_dir()
    path, record = load(root)
    require_active(record)
    require_current_profile(root, record)
    schema3_items = []
    for name in args.gates:
        gate = record["gates"][name]
        complete = gate["applicability"] == "not_applicable" or gate["result"] == "passed" or "exception" in gate
        if not complete:
            fail(f"gate is not complete: {name}")
        if record.get("schema_version") == 3 and gate["result"] in ("passed", "failed", "unavailable"):
            item = verify_envelope(root, record, name)
            if set(item.get("paths", {})) != set(args.paths):
                fail(f"evidence paths differ from commit paths: {name}")
            if evidence_path_blobs(root, args.paths) != item["paths"]:
                fail(f"evidence paths changed after validation: {name}")
            schema3_items.append((name, item))
    paths = safe_paths(root, args.paths)
    staged = git(root, "diff", "--cached", "--name-only").stdout.splitlines()
    if staged and set(staged) != set(paths):
        fail("unrelated staged paths present: " + ", ".join(staged))
    if git(root, "diff", "--check", check=False).returncode:
        fail("git diff --check failed")
    git(root, "add", "--", *paths)
    for name, item in schema3_items:
        if evidence_path_blobs(root, args.paths, index=True) != item["paths"]:
            fail(f"staged paths differ from evidence: {name}")
    if git(root, "diff", "--cached", "--check", check=False).returncode:
        fail("staged git diff --check failed")
    staged = git(root, "diff", "--cached", "--name-only").stdout.splitlines()
    if set(staged) != set(paths):
        fail("staged paths differ from requested paths")
    if not staged or not git(root, "diff", "--cached", "--quiet", check=False).returncode:
        fail("staged diff is empty")
    git(root, "commit", "-m", args.message)
    commit = git(root, "rev-parse", "HEAD").stdout.strip()
    if record.get("schema_version") == 3:
        for name, item in schema3_items:
            if evidence_path_blobs(root, args.paths, commit=commit) != item["paths"]:
                fail(f"committed paths differ from evidence: {name}")
        for name in args.gates:
            gate = record["gates"][name]
            if gate.get("evidence"):
                record["evidence"]["items"][gate["evidence"]]["commit"] = commit
    record["commits"].append({"id": commit, "gates": args.gates})
    save(path, record)
    print(commit)


def command_check(args):
    root = root_dir()
    _, record = load(root)
    if args.subject == "artifacts":
        artifact_check(record)


def sync_source_checkout(record, remote, remote_branch):
    source = record.get("source")
    if not source:
        return {"status": "not_applicable", "reason": "no_recorded_source"}
    try:
        checkout = Path(source["path"])
        if not checkout.is_dir():
            return {"status": "skipped", "reason": "missing"}
        if status_paths(checkout):
            return {"status": "skipped", "reason": "dirty"}
        if branch(checkout) != source.get("branch"):
            return {"status": "skipped", "reason": "branch_changed"}
        if upstream(checkout) != source.get("upstream"):
            return {"status": "skipped", "reason": "upstream_changed"}
        if remote_destination(checkout, source.get("upstream")) != source.get("remote"):
            return {"status": "skipped", "reason": "target_changed"}
        git(checkout, "fetch", remote, remote_branch)
        target = source["upstream"]
        if git(checkout, "merge-base", "--is-ancestor", "HEAD", target, check=False).returncode:
            return {"status": "skipped", "reason": "diverged"}
        git(checkout, "merge", "--ff-only", target)
        return {"status": "updated", "reason": "fast_forward"}
    except (OSError, RuntimeError, KeyError):
        return {"status": "skipped", "reason": "sync_failed"}


def finish_push(root, path, record):
    pointer = active_path(root)
    if not pointer.exists():
        pointer = legacy_cycle_dir(root) / "active"
    if record["state"] == "completed":
        pointer.unlink(missing_ok=True)
        print("pushed " + " ".join(entry["id"] for entry in record["commits"]))
        return
    require_pushable(record)
    require_current_profile(root, record)
    if record.get("schema_version") == 3:
        final_head = git(root, "rev-parse", "HEAD").stdout.strip()
        for name, gate in record["gates"].items():
            if gate["applicability"] == "required" and gate["result"] in ("passed", "failed", "unavailable"):
                item = verify_envelope(root, record, name, require_head=False)
                gate_commits = {entry["id"] for entry in record["commits"] if name in entry["gates"]}
                if item.get("commit") and item["commit"] not in gate_commits:
                    fail(f"evidence commit is not bound to its gate: {name}")
                if not item.get("commit") and item.get("head") != final_head:
                    fail(f"uncommitted gate evidence HEAD is stale: {name}")
    if any(gate["applicability"] == "required" and gate["result"] != "passed" and "exception" not in gate
           for gate in record["gates"].values()):
        fail("required gates have not all passed")
    completion_artifact_check(record)
    if status_paths(root):
        fail("worktree is not clean")
    baseline = record["git"]
    if not baseline["branch"] or branch(root) != baseline["branch"]:
        fail("HEAD is detached or not on the original branch")
    current_upstream = upstream(root)
    if not baseline["upstream"] or current_upstream != baseline["upstream"]:
        fail("upstream is missing or changed")
    if baseline["pre_cycle_ahead_commits"]:
        fail("pre-cycle ahead commits would be pushed")
    delivery = record.get("delivery", {})
    remote = delivery.get("remote")
    remote_branch = delivery.get("branch")
    if not remote or not remote_branch:
        remote, remote_branch = remote_for_upstream(root, current_upstream)
    if not remote or not remote_branch:
        fail("upstream is not a remote branch")
    if baseline.get("remote") != remote_destination(root, current_upstream):
        fail("remote push destination changed")
    git(root, "fetch", remote, remote_branch)
    cycle_base = baseline["head"]
    target_head = git(root, "rev-parse", current_upstream).stdout.strip()
    recorded_commits = [entry["id"] for entry in record["commits"]]
    reconciled = False
    if target_head != cycle_base:
        if (git(root, "merge-base", "--is-ancestor", cycle_base, target_head, check=False).returncode
                or git(root, "merge-base", "--is-ancestor", target_head, "HEAD", check=False).returncode):
            fail("delivery target advanced outside the cycle lineage")
        reconciled = True
    current_ahead = git(root, "rev-list", "--reverse", f"{current_upstream}..HEAD").stdout.splitlines()
    if current_ahead != recorded_commits:
        if not (record["state"] == "finalizing" and not current_ahead and reconciled
                and git(root, "rev-list", "--reverse", f"{cycle_base}..{target_head}").stdout.splitlines()[-len(recorded_commits):]
                    == recorded_commits):
            fail("ahead commits are not exactly the recorded cycle commits")
    if not current_ahead and record["state"] != "finalizing":
        fail("ahead commits are not exactly the recorded cycle commits")
    changed = set(git(root, "diff", "--name-only", f"{cycle_base}..HEAD").stdout.splitlines())
    changelog_path = record["artifact_reviews"]["CHANGELOG"]["path"]
    if changelog_path not in changed:
        fail("reviewed CHANGELOG path is not committed in this cycle")
    dvc_relevant = any(name.endswith(".dvc") or name in ("dvc.yaml", "dvc.lock", ".dvc/config", ".dvcignore")
                       for name in changed)
    if dvc_relevant:
        dvc_targets = sorted(name for name in changed if name.endswith(".dvc"))
        if any(name in changed for name in ("dvc.yaml", "dvc.lock")):
            dvc_targets.append("dvc.yaml")
        if dvc_targets:
            dvc_status = subprocess.run(["dvc", "status", *dvc_targets], cwd=root, text=True, capture_output=True)
            if dvc_status.returncode:
                fail(dvc_status.stderr.strip() or "dvc status failed")
            if "Data and pipelines are up to date." not in dvc_status.stdout:
                fail("dvc status reports changed or missing data")
        dvc_push = record.get("dvc_push")
        if not dvc_push or dvc_push["head"] != git(root, "rev-parse", "HEAD").stdout.strip():
            fail("DVC repository requires separately approved `dvc push` evidence at current HEAD")
    if current_ahead:
        record["state"] = "finalizing"
        save(path, record)
        git(root, "push", remote, f"HEAD:{remote_branch}")
    if git(root, "rev-parse", "HEAD").stdout.strip() != git(root, "rev-parse", current_upstream).stdout.strip():
        fail("push did not synchronize upstream")
    if reconciled:
        baseline["head"] = target_head
        baseline["reconciled_at"] = now()
    record["state"] = "completed"
    record["completed_at"] = now()
    save(path, record)
    source_sync = sync_source_checkout(record, remote, remote_branch)
    record["source_sync"] = source_sync
    save(path, record)
    pointer.unlink()
    print("pushed " + " ".join(recorded_commits) + " source_sync=" + source_sync["status"])


def command_final_push(args):
    root = root_dir()
    path, record = load(root)
    with target_lock(root, record):
        finish_push(root, path, record)


