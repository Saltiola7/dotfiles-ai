DBSCTRCTL = os.environ.get("DBSCTRCTL", {{ printf "%s/.local/bin/dbsctrctl" .chezmoi.homeDir | quote }})
HERDR = os.environ.get("HERDR", {{ .dotfiles_ai.herdr.executable | quote }})
GH = os.environ.get("GH", "gh")
OPENCODE = os.environ.get("OPENCODE_BIN", "opencode")
REVIEW_WORKDIR = Path({{ .dotfiles_ai.rnd.review_workdir | quote }}).resolve()
WORKSPACE_LABEL = {{ .dotfiles_ai.rnd.workspace_label | quote }}
GITHUB_ACCOUNT = {{ .dotfiles_ai.rnd.github_account | quote }}
GITHUB_REPOSITORY = {{ .dotfiles_ai.rnd.github_repository | quote }}
MANAGED_PATH = {{ printf "%s/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" .chezmoi.homeDir | quote }}
TERMINAL = {"merged", "closed", "abandoned"}
LOCK = Path(os.environ.get("DBSCTR_RND_LOCK", {{ printf "%s/.local/state/dotfiles-ai/dbsctr-rnd-watchdog.lock" .chezmoi.homeDir | quote }}))
STATE = Path(os.environ.get("DBSCTR_RND_STATE", str(LOCK.with_name("dbsctr-rnd.sqlite3"))))
SESSION_POLLS = int(os.environ.get("DBSCTR_RND_SESSION_POLLS", "60"))
CADENCES = ("weekly", "twice_weekly", "daily")
CADENCE_SECONDS = {"weekly": 7 * 86400, "twice_weekly": 7 * 86400 // 2, "daily": 86400}
MONTH_SECONDS = 30 * 86400
NONTERMINAL = {"reviewing", "claimed", "discovery", "implementing", "draft_pr", "blocked"}


def command(argv, *, parse=True, env=None):
    result = subprocess.run(argv, check=True, text=True, capture_output=True, env=env)
    return json.loads(result.stdout) if parse else result.stdout


def result(value):
    return value.get("result", value)


def safe_id(value):
    allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._-"
    return (isinstance(value, str) and 1 <= len(value) <= 128
            and value[0] in allowed[:-3] and all(character in allowed for character in value))


def records(value, key):
    found = result(value).get(key, [])
    if not isinstance(found, list):
        raise RuntimeError(f"invalid {key} response")
    return found


def required_id(value, key):
    found = set()

    def visit(item):
        if isinstance(item, dict):
            if isinstance(item.get(key), str) and item[key]:
                found.add(item[key])
            for child in item.values():
                visit(child)
        elif isinstance(item, list):
            for child in item:
                visit(child)

    visit(result(value))
    if len(found) != 1:
        raise RuntimeError(f"missing or ambiguous {key} in command response")
    return found.pop()


def required_path(value, *keys):
    item = result(value)
    for key in keys:
        item = item.get(key) if isinstance(item, dict) else None
    if not isinstance(item, str) or not item:
        raise RuntimeError(f"missing {'.'.join(keys)} in command response")
    return item


def state_connection():
    if STATE.parent.is_symlink():
        raise RuntimeError("scheduler state directory is unsafe")
    STATE.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(STATE.parent, 0o700)
    parent = STATE.parent.lstat()
    if (stat.S_IFMT(parent.st_mode) != stat.S_IFDIR or parent.st_uid != os.getuid()
            or STATE.is_symlink()):
        raise RuntimeError("scheduler state path is unsafe")
    if STATE.exists():
        details = STATE.lstat()
        if stat.S_IFMT(details.st_mode) != stat.S_IFREG or details.st_uid != os.getuid():
            raise RuntimeError("scheduler state path is unsafe")
    connection = sqlite3.connect(STATE, timeout=5)
    connection.execute("PRAGMA foreign_keys=ON")
    connection.execute("PRAGMA busy_timeout=5000")
    connection.execute("PRAGMA synchronous=FULL")
    connection.execute("PRAGMA journal_mode=DELETE")
    connection.executescript("""
        CREATE TABLE IF NOT EXISTS scheduler_meta (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        ) WITHOUT ROWID;
        CREATE TABLE IF NOT EXISTS scheduler_state (
            singleton INTEGER PRIMARY KEY CHECK (singleton=1),
            cadence TEXT NOT NULL CHECK (cadence IN ('weekly','twice_weekly','daily')),
            last_evaluation INTEGER NOT NULL,
            cutoff_time INTEGER NOT NULL,
            cutoff_id TEXT NOT NULL,
            halt_reason TEXT,
            halt_reset_at INTEGER NOT NULL,
            next_eligible_at INTEGER NOT NULL
        );
        CREATE TABLE IF NOT EXISTS spawn_reservations (
            reservation_id TEXT PRIMARY KEY,
            created_at INTEGER NOT NULL,
            worker_id TEXT UNIQUE
        ) WITHOUT ROWID;
        CREATE TABLE IF NOT EXISTS outcome_events (
            event_id TEXT PRIMARY KEY,
            attempt_id TEXT NOT NULL,
            kind TEXT NOT NULL CHECK (kind IN ('failed','merged','effect_finalized')),
            classification TEXT,
            reason TEXT NOT NULL,
            recorded_at INTEGER NOT NULL,
            benchmark_id TEXT,
            definition_version TEXT,
            activation_identity TEXT,
            merge_event_id TEXT REFERENCES outcome_events(event_id),
            merge_identity TEXT,
            cost TEXT,
            UNIQUE (attempt_id, definition_version, activation_identity)
        ) WITHOUT ROWID;
        CREATE UNIQUE INDEX IF NOT EXISTS unique_terminal_attempt
            ON outcome_events(attempt_id,kind) WHERE kind!='effect_finalized';
    """)
    version = connection.execute("SELECT value FROM scheduler_meta WHERE key='schema_version'").fetchone()
    if version is None:
        connection.execute("INSERT INTO scheduler_meta VALUES ('schema_version','1')")
        connection.execute("INSERT INTO scheduler_state VALUES (1,'weekly',0,0,'',NULL,0,0)")
        connection.commit()
    elif version != ("1",):
        connection.close()
        persist_malformed_halt()
        raise RuntimeError("scheduler state has an unsupported schema")
    os.chmod(STATE, 0o600)
    if connection.execute("PRAGMA integrity_check").fetchone() != ("ok",):
        connection.close()
        persist_malformed_halt()
        raise RuntimeError("scheduler state integrity check failed")
    if connection.execute("PRAGMA foreign_key_check").fetchone() is not None:
        connection.close()
        persist_malformed_halt()
        raise RuntimeError("scheduler state foreign-key check failed")
    row = connection.execute(
        "SELECT cadence,last_evaluation,cutoff_time,cutoff_id,halt_reason,halt_reset_at,next_eligible_at "
        "FROM scheduler_state"
    ).fetchall()
    if (len(row) != 1 or row[0][0] not in CADENCES
            or any(type(item) is not int or item < 0 for item in (*row[0][1:3], *row[0][5:7]))
            or not isinstance(row[0][3], str)
            or row[0][4] is not None and not safe_id(row[0][4])):
        connection.close()
        persist_malformed_halt()
        raise RuntimeError("scheduler state is malformed")
    for reservation, created_at, worker_id in connection.execute(
            "SELECT reservation_id,created_at,worker_id FROM spawn_reservations"):
        if (not safe_id(reservation) or type(created_at) is not int or created_at < 0
                or worker_id is not None and not safe_id(worker_id)):
            connection.close()
            persist_malformed_halt()
            raise RuntimeError("scheduler state is malformed")
    for event in connection.execute(
            "SELECT event_id,attempt_id,kind,classification,reason,recorded_at,benchmark_id,"
            "definition_version,activation_identity,merge_event_id,merge_identity,cost FROM outcome_events"):
        (identifier, attempt, kind, classification, reason, recorded_at, benchmark_id,
         definition_version, activation_identity, merge_event_id, merge_identity, cost) = event
        try:
            decoded_cost = json.loads(cost)
        except (TypeError, json.JSONDecodeError):
            decoded_cost = None
        if (not safe_id(identifier) or not safe_id(attempt)
                or kind not in {"failed", "merged", "effect_finalized"}
                or classification not in {None, "improved", "neutral", "regressed", "insufficient"}
                or not safe_id(reason) or type(recorded_at) is not int or recorded_at < 0
                or any(value is not None and not safe_id(value) for value in (
                    benchmark_id, definition_version, activation_identity, merge_event_id))
                or merge_identity is not None and (len(merge_identity) not in (40, 64)
                    or any(character not in "0123456789abcdef" for character in merge_identity))
                or decoded_cost != "unavailable" and (not isinstance(decoded_cost, (int, float))
                    or isinstance(decoded_cost, bool) or decoded_cost < 0 or decoded_cost != decoded_cost)
                or identifier != event_id(attempt, kind, definition_version or "", activation_identity or "")
                or kind == "failed" and (classification is not None or reason not in {
                    "blocked", "abandoned", "closed", "reverted"} or any(value is not None for value in (
                        benchmark_id, definition_version, activation_identity, merge_event_id, merge_identity)))
                or kind == "merged" and (classification is not None or reason != "merged"
                    or merge_identity is None or any(value is not None for value in (
                        benchmark_id, definition_version, activation_identity, merge_event_id)))
                or kind == "effect_finalized" and (classification is None or reason != classification
                    or any(value is None for value in (
                        benchmark_id, definition_version, activation_identity, merge_event_id, merge_identity)))):
            connection.close()
            persist_malformed_halt()
            raise RuntimeError("scheduler state is malformed")
    if connection.execute(
            "SELECT 1 FROM outcome_events e LEFT JOIN outcome_events m ON m.event_id=e.merge_event_id "
            "WHERE e.kind='effect_finalized' AND (m.kind!='merged' OR m.attempt_id!=e.attempt_id "
            "OR m.merge_identity!=e.merge_identity) LIMIT 1").fetchone() is not None:
        connection.close()
        persist_malformed_halt()
        raise RuntimeError("scheduler state is malformed")
    return connection


def event_id(*values):
    return hashlib.sha256("\0".join(str(value) for value in values).encode()).hexdigest()[:24]


def halt_scheduler(reason):
    connection = state_connection()
    try:
        connection.execute("UPDATE scheduler_state SET halt_reason=? WHERE singleton=1", (reason,))
        connection.commit()
    finally:
        connection.close()


def validated_workers(value):
    workers = value.get("workers") if isinstance(value, dict) else None
    states = NONTERMINAL | TERMINAL
    if (not isinstance(workers, list) or any(not isinstance(worker, dict)
            or not safe_id(worker.get("worker_id")) or worker.get("state") not in states
            for worker in workers)):
        halt_scheduler("malformed_state")
        raise RuntimeError("invalid improvement status response")
    return workers


def append_event(connection, attempt_id, kind, reason, recorded_at, **values):
    if not safe_id(attempt_id) or type(recorded_at) is not int or recorded_at < 0:
        raise RuntimeError("invalid scheduler outcome")
    identifier = event_id(attempt_id, kind, values.get("definition_version", ""),
                          values.get("activation_identity", ""))
    payload = (identifier, attempt_id, kind, values.get("classification"), reason, recorded_at,
               values.get("benchmark_id"), values.get("definition_version"),
               values.get("activation_identity"), values.get("merge_event_id"),
               values.get("merge_identity"), json.dumps(values.get("cost", "unavailable")))
    existing = connection.execute("SELECT * FROM outcome_events WHERE event_id=?", (identifier,)).fetchone()
    if existing is None:
        connection.execute("INSERT INTO outcome_events VALUES (?,?,?,?,?,?,?,?,?,?,?,?)", payload)
    elif kind == "failed":
        return identifier
    elif existing[:5] + existing[6:] != payload[:5] + payload[6:]:
        raise RuntimeError("immutable scheduler outcome conflicts with retained evidence")
    return identifier


def sync_worker_outcomes(connection, workers, now, merge_identities=None):
    merge_identities = merge_identities or {}
    for worker in workers:
        if not isinstance(worker, dict) or not isinstance(worker.get("worker_id"), str):
            raise RuntimeError("invalid improvement worker state")
        attempt, state = worker["worker_id"], worker.get("state")
        if state in {"blocked", "abandoned", "closed"}:
            append_event(connection, attempt, "failed", state, now)
        elif state == "merged" and attempt in merge_identities:
            append_event(connection, attempt, "merged", "merged", now,
                         merge_identity=merge_identities[attempt])
    reset_at = connection.execute("SELECT halt_reset_at FROM scheduler_state WHERE singleton=1").fetchone()[0]
    outcomes = connection.execute(
        "SELECT kind,reason FROM outcome_events WHERE kind IN ('failed','effect_finalized') "
        "AND recorded_at>? ORDER BY recorded_at DESC,event_id DESC LIMIT 3", (reset_at,)).fetchall()
    if len(outcomes) == 3 and all(kind == "failed" and reason in {"blocked", "abandoned", "reverted"}
                                  for kind, reason in outcomes):
        connection.execute("UPDATE scheduler_state SET halt_reason='three_consecutive_failures' WHERE singleton=1")


def reserve_spawn(workers, now):
    connection = state_connection()
    try:
        connection.execute("BEGIN IMMEDIATE")
        worker_ids = [worker.get("worker_id") for worker in workers
                      if isinstance(worker, dict) and isinstance(worker.get("worker_id"), str)]
        if len(worker_ids) != len(workers):
            raise RuntimeError("invalid improvement worker state")
        if worker_ids:
            connection.execute(
                f"DELETE FROM spawn_reservations WHERE worker_id IN ({','.join('?' for _ in worker_ids)})",
                worker_ids)
        sync_worker_outcomes(connection, workers, now)
        evaluate_month(connection, now)
        active_workers = sum(worker.get("state") in NONTERMINAL for worker in workers)
        cadence, halt_reason, next_eligible = connection.execute(
            "SELECT cadence,halt_reason,next_eligible_at FROM scheduler_state WHERE singleton=1").fetchone()
        reservations = connection.execute("SELECT COUNT(*) FROM spawn_reservations").fetchone()[0]
        if halt_reason:
            connection.commit()
            return None, "halted"
        if active_workers + reservations >= 3:
            connection.commit()
            return None, "worker_cap"
        if now < next_eligible:
            connection.commit()
            return None, "cadence_not_due"
        reservation = f"reservation-{uuid.uuid4().hex}"
        connection.execute("INSERT INTO spawn_reservations VALUES (?,?,NULL)", (reservation, now))
        connection.execute("UPDATE scheduler_state SET next_eligible_at=? WHERE singleton=1",
                           (now + CADENCE_SECONDS[cadence],))
        connection.commit()
        return reservation, "reserved"
    finally:
        connection.close()


def release_reservation(reservation):
    if reservation is None:
        return
    connection = state_connection()
    try:
        connection.execute("DELETE FROM spawn_reservations WHERE reservation_id=?", (reservation,))
        connection.commit()
    finally:
        connection.close()


def complete_reservation(reservation, worker_id):
    connection = state_connection()
    try:
        connection.execute("UPDATE spawn_reservations SET worker_id=? WHERE reservation_id=?",
                           (worker_id, reservation))
        if connection.total_changes != 1:
            raise RuntimeError("spawn reservation is missing")
        connection.commit()
    finally:
        connection.close()


def finalize_effect(connection, request, benchmark, now):
    if (not isinstance(request, dict) or set(request) != {"attempt_id", "benchmark_id"}
            or not all(safe_id(request[name]) for name in request)):
        raise RuntimeError("invalid effect finalization request")
    if benchmark.get("benchmark_id") != request["benchmark_id"]:
        raise RuntimeError("benchmark identity mismatch")
    inputs, definition, outcome = (benchmark.get(name) for name in ("inputs", "definition", "result"))
    if not all(isinstance(value, dict) for value in (inputs, definition, outcome)):
        raise RuntimeError("invalid benchmark response")
    activation = inputs.get("activation_identity")
    activated_at = inputs.get("activated_at")
    if (inputs.get("activation_status") != "verified" or not safe_id(activation)
            or type(activated_at) is not int or type(benchmark.get("evaluated_at")) is not int
            or benchmark["evaluated_at"] < activated_at + 30 * 86400 * 1000):
        raise RuntimeError("benchmark activation window is incomplete")
    classification = outcome.get("classification")
    if (classification not in {"improved", "neutral", "regressed", "insufficient"}
            or not safe_id(definition.get("version"))):
        raise RuntimeError("invalid benchmark classification")
    merge = connection.execute(
        "SELECT event_id,merge_identity FROM outcome_events WHERE attempt_id=? AND kind='merged'",
        (request["attempt_id"],)).fetchone()
    if merge is None or merge[1] != inputs.get("merge_identity"):
        raise RuntimeError("benchmark does not reference the retained merge event")
    metric = definition.get("metric")
    cost = outcome.get("observation_value") if metric == "cost_total" else "unavailable"
    if (cost != "unavailable" and (not isinstance(cost, (int, float))
            or isinstance(cost, bool) or cost < 0 or cost != cost)):
        raise RuntimeError("invalid benchmark cost")
    return append_event(
        connection, request["attempt_id"], "effect_finalized", classification, now,
        classification=classification, benchmark_id=request["benchmark_id"],
        definition_version=definition.get("version"), activation_identity=activation,
        merge_event_id=merge[0], merge_identity=merge[1], cost=cost,
    )


def evaluate_month(connection, now):
    cadence, last_evaluation, cutoff_time, cutoff_id = connection.execute(
        "SELECT cadence,last_evaluation,cutoff_time,cutoff_id FROM scheduler_state WHERE singleton=1").fetchone()
    events = connection.execute(
        "SELECT event_id,attempt_id,kind,classification,reason,cost FROM outcome_events "
        "WHERE (recorded_at>? OR (recorded_at=? AND event_id>?)) AND recorded_at<=? "
        "ORDER BY recorded_at,event_id", (cutoff_time, cutoff_time, cutoff_id, now)).fetchall()
    counts = {name: 0 for name in (
        "improved", "neutral", "regressed", "failed", "insufficient", "pending", "active")}
    costs = []
    finalized_attempts = {attempt for _, attempt, kind, *_ in events if kind == "effect_finalized"}
    for _, attempt, kind, classification, _, encoded_cost in events:
        if kind == "failed":
            counts["failed"] += 1
        elif kind == "merged" and attempt not in finalized_attempts:
            counts["pending"] += 1
        elif classification in counts:
            counts[classification] += 1
        cost = json.loads(encoded_cost)
        if isinstance(cost, (int, float)) and not isinstance(cost, bool) and cost >= 0:
            costs.append(cost)
    changed = False
    if last_evaluation == 0 or now - last_evaluation >= MONTH_SECONDS:
        denominator = sum(counts[name] for name in ("improved", "neutral", "regressed", "failed"))
        target = cadence
        if denominator and (counts["regressed"] or counts["failed"] / denominator >= 0.5):
            target = CADENCES[max(0, CADENCES.index(cadence) - 1)]
        elif (counts["improved"] >= 2 and not counts["regressed"]
              and denominator and counts["failed"] / denominator <= 0.2):
            target = CADENCES[min(len(CADENCES) - 1, CADENCES.index(cadence) + 1)]
        changed = target != cadence
        cadence = target
        connection.execute(
            "UPDATE scheduler_state SET cadence=?,last_evaluation=?,cutoff_time=?,cutoff_id='~',"
            "next_eligible_at=CASE WHEN ? THEN ? ELSE next_eligible_at END WHERE singleton=1",
            (cadence, now, now, changed, now + CADENCE_SECONDS[cadence]))
    return cadence, changed, counts, sum(costs) if costs else "unavailable"


def analytics(now, json_output=False, finalize_request=None, failure_request=None):
    if type(now) is not int or now < 0:
        raise RuntimeError("invalid analytics cutoff")
    workers = validated_workers(command([DBSCTRCTL, "improvement-status"]))
    if (finalize_request is not None and (not isinstance(finalize_request, dict)
            or set(finalize_request) != {"attempt_id", "benchmark_id"}
            or not all(safe_id(value) for value in finalize_request.values()))):
        raise RuntimeError("invalid effect finalization request")
    if (failure_request is not None and (not isinstance(failure_request, dict)
            or set(failure_request) != {"attempt_id", "reason"}
            or not safe_id(failure_request.get("attempt_id"))
            or failure_request.get("reason") not in {"blocked", "abandoned", "closed", "reverted"})):
        raise RuntimeError("invalid failure outcome request")
    if failure_request is not None:
        matching = [worker for worker in workers if worker.get("worker_id") == failure_request["attempt_id"]]
        expected_state = "merged" if failure_request["reason"] == "reverted" else failure_request["reason"]
        if len(matching) != 1 or matching[0].get("state") != expected_state:
            raise RuntimeError("failure outcome does not match authoritative worker state")
    benchmark = (command([DBSCTRCTL, "benchmark", "--benchmark-id", finalize_request["benchmark_id"]])
                 if finalize_request is not None else None)
    connection = state_connection()
    try:
        connection.execute("BEGIN IMMEDIATE")
        sync_worker_outcomes(connection, workers, now)
        if failure_request is not None:
            append_event(connection, failure_request["attempt_id"], "failed",
                         failure_request["reason"], now)
        finalized = (finalize_effect(connection, finalize_request, benchmark, now)
                     if finalize_request is not None else None)
        cadence, changed, counts, cost = evaluate_month(connection, now)
        finalized_attempts = {row[0] for row in connection.execute(
            "SELECT DISTINCT attempt_id FROM outcome_events WHERE kind='effect_finalized'")}
        failed_attempts = {row[0] for row in connection.execute(
            "SELECT DISTINCT attempt_id FROM outcome_events WHERE kind='failed'")}
        pending_attempts = ({worker["worker_id"] for worker in workers if worker.get("state") == "merged"}
                            | {row[0] for row in connection.execute(
                                "SELECT DISTINCT attempt_id FROM outcome_events WHERE kind='merged'")})
        counts["pending"] = len(pending_attempts - finalized_attempts - failed_attempts)
        counts["active"] = sum(worker.get("state") in NONTERMINAL - {"blocked"} for worker in workers)
        halt_reason, next_eligible = connection.execute(
            "SELECT halt_reason,next_eligible_at FROM scheduler_state WHERE singleton=1").fetchone()
        connection.commit()
    except Exception:
        connection.rollback()
        raise
    finally:
        connection.close()
    report = {"cadence": cadence, "changed": changed, "halt_reason": halt_reason,
              "next_eligible_at": next_eligible, "counts": counts, "cost_total": cost,
              "finalized_event_id": finalized}
    if json_output:
        print(json.dumps(report, sort_keys=True, separators=(",", ":")))
    else:
        print(f"cadence={cadence} changed={str(changed).lower()} halt={halt_reason or 'none'} ")
        print(" ".join(f"{name}={counts[name]}" for name in counts) + f" cost={cost}")


def reset_schedule():
    connection = state_connection()
    try:
        connection.execute("BEGIN IMMEDIATE")
        connection.execute("UPDATE scheduler_state SET halt_reason=NULL,halt_reset_at=?,next_eligible_at=0 "
                           "WHERE singleton=1", (int(time.time()),))
        connection.execute("DELETE FROM spawn_reservations")
        connection.commit()
    finally:
        connection.close()
    print('{"status":"reset"}')


def panes(workspace_id):
    return records(command([HERDR, "pane", "list", "--workspace", workspace_id]), "panes")


def close_unchanged_staging(workspace_id, tab_id, shell_pane_id):
    current = [pane.get("pane_id") for pane in panes(workspace_id) if pane.get("tab_id") == tab_id]
    if current == [shell_pane_id]:
        command([HERDR, "tab", "close", tab_id], parse=False)


def workspace():
    matches = [item for item in records(command([HERDR, "workspace", "list"]), "workspaces")
               if item.get("label") == WORKSPACE_LABEL]
    if len(matches) > 1:
        raise RuntimeError(f"multiple Herdr workspaces named {WORKSPACE_LABEL!r}")
    if matches:
        return required_id(matches[0], "workspace_id")
    created = command([
        HERDR, "workspace", "create", "--cwd", str(REVIEW_WORKDIR),
        "--label", WORKSPACE_LABEL, "--no-focus",
    ])
    return required_id(created, "workspace_id")


def session_ids():
    value = command([OPENCODE, "session", "list", "--format", "json", "-n", "100"])
    if not isinstance(value, list):
        raise RuntimeError("invalid OpenCode session list")
    return {item["id"] for item in value
            if isinstance(item, dict) and item.get("directory") == str(REVIEW_WORKDIR)
            and isinstance(item.get("id"), str)}


def pane_runs(pane_id, expected_argv):
    info = result(command([HERDR, "pane", "process-info", "--pane", pane_id]))
    processes = info.get("process_info", {}).get("foreground_processes", [])
    return len(processes) == 1 and processes[0].get("argv") == expected_argv


def wait_for_session(pane_id, expected=None, before=None, expected_argv=None):
    for _ in range(SESSION_POLLS):
        matches = [agent for agent in records(command([HERDR, "agent", "list"]), "agents")
                   if agent.get("pane_id") == pane_id]
        if len(matches) == 1:
            session = matches[0].get("agent_session", {}).get("value")
            if isinstance(session, str) and session and (expected is None or session == expected):
                return session
        if expected_argv and pane_runs(pane_id, expected_argv):
            current = session_ids()
            if expected and expected in current:
                return expected
            created = current - (before or set())
            if expected is None and len(created) == 1:
                return created.pop()
        time.sleep(0.5)
    raise RuntimeError("OpenCode session identity did not become available")


def launch(workspace_id, worker_id, session_id=None):
    before = session_ids() if session_id is None else None
    staging = command([
        HERDR, "tab", "create", "--workspace", workspace_id,
        "--cwd", str(REVIEW_WORKDIR), "--label", f"{worker_id}-staging", "--no-focus",
    ])
    staging_tab = required_path(staging, "tab", "tab_id")
    shell_pane = required_path(staging, "root_pane", "pane_id")
    agent_pane = worker_tab = None
    try:
        argv = (["opencode", "-s", session_id, "--agent", "build"] if session_id else
                ["opencode", "run", "--agent", "build", "--command", "dbsctr-improve", "--interactive"])
        started = command([
            HERDR, "agent", "start", worker_id, "--cwd", str(REVIEW_WORKDIR),
            "--tab", staging_tab, "--env", f"PATH={MANAGED_PATH}", "--no-focus", "--", *argv,
        ])
        agent_pane = required_id(started, "pane_id")
        moved = command([
            HERDR, "pane", "move", agent_pane, "--new-tab", "--workspace", workspace_id,
            "--label", f"R&D {worker_id[-8:]}", "--no-focus",
        ])
        worker_tab = required_path(moved, "move_result", "created_tab", "tab_id")
        destination = [pane.get("pane_id") for pane in panes(workspace_id)
                       if pane.get("tab_id") == worker_tab]
        if destination != [agent_pane]:
            raise RuntimeError("worker destination tab is not single-pane")
        close_unchanged_staging(workspace_id, staging_tab, shell_pane)
        actual_session = wait_for_session(agent_pane, session_id, before, argv)
        return actual_session, worker_tab, agent_pane
    except Exception:
        try:
            if agent_pane and worker_tab:
                close_pending_launch(workspace_id, worker_tab, agent_pane)
            close_unchanged_staging(workspace_id, staging_tab, shell_pane)
        except Exception:
            pass
        raise


def close_pending_launch(workspace_id, tab_id, pane_id):
    current = [pane.get("pane_id") for pane in panes(workspace_id) if pane.get("tab_id") == tab_id]
    if current == [pane_id]:
        command([HERDR, "tab", "close", tab_id], parse=False)
        return True
    return False


def spawn():
    if not REVIEW_WORKDIR.is_dir():
        raise RuntimeError(f"review workdir does not exist: {REVIEW_WORKDIR}")
    workers = validated_workers(command([DBSCTRCTL, "improvement-status"]))
    reservation, reason = reserve_spawn(workers, int(time.time()))
    if reservation is None:
        print(json.dumps({"status": "no_op", "reason": reason}, separators=(",", ":")))
        return
    worker_id = f"dbsctr-{uuid.uuid4().hex[:8]}"
    workspace_id = tab_id = pane_id = None
    try:
        workspace_id = workspace()
        session_id, tab_id, pane_id = launch(workspace_id, worker_id)
        worker = command([
            DBSCTRCTL, "improvement-register", "--worker-id", worker_id,
            "--session-id", session_id, "--workspace-id", workspace_id,
            "--tab-id", tab_id, "--pane-id", pane_id,
        ])
        if not isinstance(worker, dict) or worker.get("worker_id") != worker_id:
            raise RuntimeError("registered worker identity mismatch")
    except Exception:
        if all(value is not None for value in (workspace_id, tab_id, pane_id)):
            close_pending_launch(workspace_id, tab_id, pane_id)
        release_reservation(reservation)
        raise
    complete_reservation(reservation, worker_id)
    print(json.dumps(worker, separators=(",", ":")))


def managed_cwd(value):
    return isinstance(value, str) and Path(value).resolve() == REVIEW_WORKDIR


def exact_resumed_agent(worker, agents):
    recorded = [agent for agent in agents
                if agent.get("pane_id") == worker.get("pane_id")
                and agent.get("tab_id") == worker.get("tab_id")
                and agent.get("workspace_id") == worker.get("workspace_id")
                and managed_cwd(agent.get("foreground_cwd") or agent.get("cwd"))]
    if len(recorded) != 1:
        return []
    tab_panes = [pane for pane in panes(worker["workspace_id"])
                 if pane.get("tab_id") == worker["tab_id"]]
    info = result(command([HERDR, "pane", "process-info", "--pane", worker["pane_id"]]))
    processes = info.get("process_info", {}).get("foreground_processes", [])
    expected = ["opencode", "-s", worker["session_id"], "--agent", "build"]
    if ([pane.get("pane_id") for pane in tab_panes] == [worker["pane_id"]]
            and len(processes) == 1 and processes[0].get("argv") == expected):
        return recorded
    return []


def reconcile_pr(worker, token):
    if worker["state"] != "draft_pr" or not worker.get("pr_url"):
        return token, worker, None
    if token is None:
        token = command([
            GH, "auth", "token", "--hostname", "github.com", "--user", GITHUB_ACCOUNT,
        ], parse=False).strip()
        if not token:
            raise RuntimeError("configured GitHub account returned no token")
    pull = command([
        GH, "pr", "view", worker["pr_url"], "--repo", GITHUB_REPOSITORY,
        "--json", "state,isDraft,mergeCommit",
    ], env={**os.environ, "GH_TOKEN": token})
    if not isinstance(pull, dict):
        raise RuntimeError("GitHub pull request response is not an object")
    state = {"MERGED": "merged", "CLOSED": "closed"}.get(pull.get("state"))
    merge_identity = pull.get("mergeCommit", {}).get("oid") if state == "merged" else None
    if state == "merged" and merge_identity is None:
        raise RuntimeError("GitHub merge identity is missing")
    if merge_identity is not None and (len(merge_identity) not in (40, 64)
                                       or any(character not in "0123456789abcdef" for character in merge_identity)):
        raise RuntimeError("GitHub merge identity is invalid")
    if state:
        worker = command([
            DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"], "--state", state,
        ])
    return token, worker, merge_identity


def watchdog():
    LOCK.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(LOCK.parent, 0o700)
    lock = LOCK.open("a+")
    os.chmod(LOCK, 0o600)
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print('{"events":[],"status":"already_running"}')
        return
    workers = validated_workers(command([DBSCTRCTL, "improvement-status"]))
    current_workers = {worker["worker_id"]: worker for worker in workers}
    merge_identities = {}
    agents = records(command([HERDR, "agent", "list"]), "agents")
    token = None
    events = []
    for worker in workers:
        try:
            token, worker, merge_identity = reconcile_pr(worker, token)
            current_workers[worker["worker_id"]] = worker
            if merge_identity is not None:
                merge_identities[worker["worker_id"]] = merge_identity
        except (OSError, subprocess.CalledProcessError, json.JSONDecodeError, RuntimeError) as error:
            events.append({"worker_id": worker["worker_id"], "status": "pr_check_failed", "error": str(error)})
        if worker["state"] in TERMINAL:
            continue
        matches = [agent for agent in agents
                   if agent.get("agent_session", {}).get("value") == worker["session_id"]]
        if not matches and worker.get("pane_id") and worker.get("tab_id") and worker.get("workspace_id"):
            recorded = [agent for agent in agents
                        if agent.get("pane_id") == worker["pane_id"]
                        and agent.get("tab_id") == worker["tab_id"]
                        and agent.get("workspace_id") == worker["workspace_id"]]
            try:
                matches = exact_resumed_agent(worker, agents) if len(recorded) == 1 else []
            except (OSError, subprocess.CalledProcessError, json.JSONDecodeError, RuntimeError):
                matches = []
            if recorded and not matches:
                command([DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"], "--state", "blocked"])
                current_workers[worker["worker_id"]] = {**worker, "state": "blocked"}
                events.append({"worker_id": worker["worker_id"], "status": "ambiguous"})
                continue
        if len(matches) > 1:
            command([DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"], "--state", "blocked"])
            current_workers[worker["worker_id"]] = {**worker, "state": "blocked"}
            events.append({"worker_id": worker["worker_id"], "status": "ambiguous"})
            continue
        if len(matches) == 1:
            status = matches[0].get("agent_status")
            if status in {"working", "idle", "blocked"}:
                continue
            if status != "missing":
                command([DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"], "--state", "blocked"])
                current_workers[worker["worker_id"]] = {**worker, "state": "blocked"}
                events.append({"worker_id": worker["worker_id"], "status": "unknown"})
                continue
        if worker["state"] == "blocked" or worker["recovery_attempts"] >= 3:
            events.append({"worker_id": worker["worker_id"], "status": "blocked"})
            continue
        launched = None
        try:
            workspace_id = workspace()
            session_id, tab_id, pane_id = launch(workspace_id, worker["worker_id"], worker["session_id"])
            launched = (workspace_id, tab_id, pane_id, session_id)
            command([
                DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"],
                "--state", worker["state"], "--workspace-id", workspace_id,
                "--tab-id", tab_id, "--pane-id", pane_id,
            ])
            command([DBSCTRCTL, "improvement-recover", "--worker-id", worker["worker_id"], "--action", "success"])
            events.append({"worker_id": worker["worker_id"], "session_id": session_id, "status": "recovered"})
        except (OSError, subprocess.CalledProcessError, json.JSONDecodeError, RuntimeError) as error:
            if launched:
                close_pending_launch(*launched[:3])
            command([DBSCTRCTL, "improvement-recover", "--worker-id", worker["worker_id"], "--action", "failed"])
            events.append({"worker_id": worker["worker_id"], "status": "recovery_failed", "error": str(error)})
    scheduler = state_connection()
    try:
        scheduler.execute("BEGIN IMMEDIATE")
        sync_worker_outcomes(scheduler, list(current_workers.values()), int(time.time()), merge_identities)
        scheduler.commit()
    except Exception:
        scheduler.rollback()
        raise
    finally:
        scheduler.close()
    print(json.dumps({"events": events}, separators=(",", ":")))


def persist_malformed_halt():
    try:
        connection = sqlite3.connect(STATE)
        connection.execute("UPDATE scheduler_state SET halt_reason='malformed_state' WHERE singleton=1")
        connection.commit()
        connection.close()
    except sqlite3.Error:
        pass


parser = argparse.ArgumentParser()
parser.add_argument("action", choices=("spawn", "watchdog", "analytics", "reset-schedule"))
parser.add_argument("--json", action="store_true")
parser.add_argument("--finalize-json")
parser.add_argument("--failure-json")
args = parser.parse_args()
try:
    if args.action == "analytics":
        request = json.loads(args.finalize_json) if args.finalize_json else None
        failure = json.loads(args.failure_json) if args.failure_json else None
        analytics(int(time.time()), args.json, request, failure)
    elif args.action == "reset-schedule":
        if args.finalize_json or args.failure_json:
            raise RuntimeError("reset-schedule does not accept analytics inputs")
        reset_schedule()
    else:
        if args.json or args.finalize_json or args.failure_json:
            raise RuntimeError(f"{args.action} does not accept analytics inputs")
        {"spawn": spawn, "watchdog": watchdog}[args.action]()
except (OSError, subprocess.CalledProcessError, json.JSONDecodeError, sqlite3.Error,
        KeyError, ValueError, RuntimeError) as error:
    raise SystemExit(str(error))
