#!/bin/bash
# op-session — Shared 1Password CLI session broker.
#
# This script is designed to be SOURCED, not executed:
#   . op-session        (from a shell or the `secret` script)
#   source op-session
#
# Purpose
# -------
# 1Password's desktop CLI integration authorizes `op` by the calling terminal's
# code signature. Agent subprocesses (e.g. opencode's bash tool, spawned under
# herdr) are NOT recognized terminal clients, so biometric auth never engages
# there and `op read` fails with "not currently signed in".
#
# This broker mints a session token ONCE in a TTY context (where biometric works)
# and caches it on disk (0600). Sibling panes and non-TTY agent shells then reuse
# the cached token via the OP_SESSION_<user_uuid> env var — no re-prompt, no TTY
# required downstream. Net effect under herdr: one Touch ID per session restart.
#
# The cached token is short-lived (1Password expires sessions after ~30 min idle).
# Validate it once before callers fan out to parallel item reads; otherwise a
# stale token can trigger one biometric prompt per parallel `op` process.

# --- Account identity (configured outside Git by this chezmoi instance) ---
# user_uuid drives the OP_SESSION_<uuid> env var name that `op` reads.
__OP_USER_UUID={{ .dotfiles_ai.onepassword.user_uuid | quote }}
__OP_ACCOUNT={{ .dotfiles_ai.onepassword.account | quote }}
__OP_SESSION_VAR="OP_SESSION_${__OP_USER_UUID}"

__OP_CACHE_DIR="$HOME/.cache/op"
__OP_CACHE_FILE="$__OP_CACHE_DIR/session"
__OP_TIMEOUT_SECONDS="${OP_TIMEOUT_SECONDS:-8}"
__OP_LOCK_DIR="$__OP_CACHE_DIR/session.lock"
__OP_KEYCHAIN_SERVICE={{ .dotfiles_ai.onepassword.keychain_service | quote }}

__op_clear_session_env() {
  unset "$__OP_SESSION_VAR" OP_SESSION OP_SESSION_my
}

__op_is_ssh() {
  [ -n "${SSH_CONNECTION:-}${SSH_TTY:-}" ]
}

__op_is_herdr() {
  [ -n "${HERDR_ENV:-}" ]
}

__op_fail_ssh_without_service_token() {
  echo "op-session: SSH shells require OP_SERVICE_ACCOUNT_TOKEN or a valid cached 1Password session." >&2
  echo "op-session: inject OP_SERVICE_ACCOUNT_TOKEN into this Herdr/SSH session, then run 'secret'." >&2
  return 1
}

__op_fail_herdr_without_service_token() {
  echo "op-session: Herdr shells require OP_SERVICE_ACCOUNT_TOKEN from env or macOS Keychain." >&2
  echo "op-session: repair it in Keychain Access (login keychain):" >&2
  echo "op-session: item=$__OP_KEYCHAIN_SERVICE account=$__OP_ACCOUNT; allow /usr/bin/security" >&2
  return 1
}

__op_timeout() {
  perl -e '
    use strict;
    use warnings;
    my $timeout = shift @ARGV;
    my $pid = fork();
    die "fork failed\n" unless defined $pid;
    if ($pid == 0) {
      exec @ARGV;
      exit 127;
    }
    local $SIG{ALRM} = sub {
      kill "TERM", $pid;
      select undef, undef, undef, 0.2;
      kill "KILL", $pid;
      exit 124;
    };
    alarm $timeout;
    waitpid($pid, 0);
    my $status = $?;
    exit 127 if $status == -1;
    exit(128 + ($status & 127)) if $status & 127;
    exit($status >> 8);
  ' "$__OP_TIMEOUT_SECONDS" "$@"
}

# --- Validate that `op` can actually read vaults with the current session ---
# `op whoami` is NOT sufficient — it can succeed for an expired session.
__op_session_valid() {
  __op_timeout op vault list >/dev/null 2>&1
}

__op_load_keychain_service_token() {
  command -v security >/dev/null 2>&1 || return 1
  local tok err
  err="$(mktemp "${TMPDIR:-/tmp}/op-keychain.XXXXXX")" || return 1
  tok="$(security find-generic-password -s "$__OP_KEYCHAIN_SERVICE" -a "$__OP_ACCOUNT" -w 2>|"$err")" || {
    if [ -s "$err" ]; then
      sed 's/^/op-session: Keychain: /' "$err" >&2
    else
      echo "op-session: Keychain item is missing or inaccessible." >&2
    fi
    command rm -f "$err"
    return 1
  }
  command rm -f "$err"
  [ -n "$tok" ] || return 1
  export OP_SERVICE_ACCOUNT_TOKEN="$tok"
}

# --- Try the on-disk cached token first ---
__op_load_cached() {
  [ -r "$__OP_CACHE_FILE" ] || return 1
  local tok
  tok="$(cat "$__OP_CACHE_FILE" 2>/dev/null)"
  [ -n "$tok" ] || return 1
  export "$__OP_SESSION_VAR"="$tok"
  export OP_ACCOUNT="$__OP_ACCOUNT"
  __op_session_valid
}

# --- Mint a fresh token (requires a TTY for the biometric prompt) ---
__op_mint() {
  if [ ! -t 0 ]; then
    return 1
  fi
  mkdir -p "$__OP_CACHE_DIR" && chmod 700 "$__OP_CACHE_DIR"
  if [ -n "${OP_SESSION_FORCE_MINT:-}" ]; then
    __op_clear_session_env
    command rm -rf "$__OP_LOCK_DIR"
  fi
  if ! mkdir "$__OP_LOCK_DIR" 2>/dev/null; then
    local i
    for i in 1 2 3 4 5; do
      sleep 1
      __op_load_cached && return 0
    done
    command rmdir "$__OP_LOCK_DIR" 2>/dev/null || return 1
    mkdir "$__OP_LOCK_DIR" 2>/dev/null || return 1
  fi
  local tok err
  err="$(mktemp "${TMPDIR:-/tmp}/op-session.XXXXXX")" || return 1
  tok="$(__op_timeout op signin --account "$__OP_ACCOUNT" --force --raw 2>|"$err")"
  if [ -z "$tok" ]; then
    [ ! -s "$err" ] || sed 's/^/op-session: op signin: /' "$err" >&2
    command rm -f "$err"
    command rmdir "$__OP_LOCK_DIR" 2>/dev/null
    return 1
  fi
  command rm -f "$err"
  export "$__OP_SESSION_VAR"="$tok"
  export OP_ACCOUNT="$__OP_ACCOUNT"
  __op_session_valid || { command rmdir "$__OP_LOCK_DIR" 2>/dev/null; return 1; }
  # Persist for sibling panes / agent shells (0600 in a 0700 dir).
  printf '%s' "$tok" >| "$__OP_CACHE_FILE" && chmod 600 "$__OP_CACHE_FILE"
  command rmdir "$__OP_LOCK_DIR" 2>/dev/null
  return 0
}

# --- Resolution order: existing env session → cache → fresh mint ---
if [ -n "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
  __op_session_valid || {
    echo "op-session: OP_SERVICE_ACCOUNT_TOKEN is invalid or lacks access." >&2
    return 1 2>/dev/null || exit 1
  }
elif __op_is_herdr; then
  __op_load_keychain_service_token || {
    __op_fail_herdr_without_service_token
    return 1 2>/dev/null || exit 1
  }
  __op_session_valid || {
    echo "op-session: Keychain OP_SERVICE_ACCOUNT_TOKEN is invalid or lacks access." >&2
    return 1 2>/dev/null || exit 1
  }
elif [ -n "${OP_SESSION_FORCE_MINT:-}" ]; then
  __op_mint || {
    echo "op-session: failed to mint a fresh 1Password session." >&2
    return 1 2>/dev/null || exit 1
  }
elif [ -n "${!__OP_SESSION_VAR:-}" ]; then
  export OP_ACCOUNT="$__OP_ACCOUNT"
  if ! __op_session_valid; then
    __op_clear_session_env
    if __op_is_ssh; then
      __op_fail_ssh_without_service_token
      return 1 2>/dev/null || exit 1
    fi
    OP_SESSION_FORCE_MINT=1 __op_mint || {
      echo "op-session: current 1Password session is stale." >&2
      return 1 2>/dev/null || exit 1
    }
  fi
elif __op_load_cached; then
  : # reused valid cached token
elif __op_is_ssh; then
  __op_fail_ssh_without_service_token || return 1 2>/dev/null || exit 1
elif __op_mint; then
  : # minted + cached a fresh token
else
  echo "op-session: no valid 1Password session." >&2
  if [ ! -t 0 ]; then
    echo "op-session: this is a non-TTY shell — it cannot prompt for Touch ID." >&2
    echo "op-session: run 'secret' (or '. op-session') once in an interactive herdr pane" >&2
    echo "op-session: to populate the shared cache, then this shell will inherit it." >&2
  else
    echo "op-session: ensure the 1Password app is unlocked and CLI integration is enabled." >&2
  fi
  return 1 2>/dev/null || exit 1
fi
