{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "gpt-5.6-sol": {
          "variants": {
            "medium": { "reasoningEffort": "medium" }
          }
        },
        "gpt-5.6-terra": {
          "variants": {
            "medium": { "reasoningEffort": "medium" }
          }
        }
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": {{ .dotfiles_ai.opencode.bedrock_region | toJson }},
        "profile": {{ .dotfiles_ai.opencode.bedrock_profile | toJson }}
      },
      "models": {
        "global.anthropic.claude-opus-4-8": {
          "variants": {
            "medium": {
              "reasoningConfig": {
                "type": "adaptive",
                "maxReasoningEffort": "medium",
                "display": "summarized"
              }
            }
          }
        },
        "global.anthropic.claude-sonnet-5": {
          "variants": {
            "medium": {
              "reasoningConfig": {
                "type": "adaptive",
                "maxReasoningEffort": "medium",
                "display": "summarized"
              }
            }
          }
        }
      }
    },
    "google": {},
    "moonshotai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Moonshot (Kimi)",
      "options": {
        "baseURL": "https://api.moonshot.ai/v1",
        "apiKey": "{env:MOONSHOT_API_KEY}"
      },
      "models": {
        "kimi-k2-turbo-preview": {
          "name": "Kimi K2 Turbo (preview)",
          "limit": { "context": 256000, "output": 8192 }
        },
        "moonshot-v1-32k": {
          "name": "Moonshot v1 32k",
          "limit": { "context": 32000, "output": 4096 }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": {{ .dotfiles_ai.opencode.lmstudio_base_url | toJson }}
      },
      "models": {
        "mistralai/devstral-small-2-2512": {
          "name": "Devstral Small 2 (MLX 4bit, local)",
          "limit": { "context": 65536, "output": 8192 }
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B (MLX 4bit, local)",
          "limit": { "context": 32768, "output": 16384 }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" }
    }
  },
  "agent": {
    "build": {
      "permission": {
        "dbsctr_begin": "allow",
        "dbsctr_attach": "allow",
        "external_directory": {
          "~/.local/state/dbsctr/worktrees/**": "allow"
        }
      }
    },
    "plan": {
      "model": {{ .dotfiles_ai.opencode.default_model | toJson }},
      "variant": "medium",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "dbsctrctl attach-runtime*": "deny",
          "*/dbsctrctl attach-runtime*": "deny",
          "env *dbsctrctl attach-runtime*": "deny",
          "command *dbsctrctl attach-runtime*": "deny"
        },
        "dbsctr_begin": "deny",
        "dbsctr_attach": "deny",
        "task": {
          "*": "deny",
          "explore-openai": "allow",
          "scout-openai": "allow"
        }
      }
    }
  },
  "default_agent": "plan",
  "model": {{ .dotfiles_ai.opencode.default_model | toJson }},
  "small_model": {{ .dotfiles_ai.opencode.small_model | toJson }},
  "plugin": ["@dietrichgebert/ponytail@4.8.4"],
  "permission": {
    "dbsctr_status": "allow",
    "dbsctr_begin": "deny",
    "dbsctr_attach": "deny",
    "dbsctr_audit": "allow",
    "dbsctr_inspect": "allow",
    "dbsctr_review": "allow",
    "dbsctr_review_complete": "ask",
    "dbsctr_review_history": "allow",
    "dbsctr_review_history_save": "allow",
    "context7_*": "deny",
    "external_directory": "deny",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git *push*--force*": "deny",
      "git push *+*": "deny",
      "git commit --no-verify*": "deny",
      "git commit -n*": "deny",
      "git *commit*--no-verify*": "deny",
      "dbsctrctl gate-commit*": "allow",
      "dbsctrctl final-push*": "allow",
      "dbsctrctl approve-exception*": "ask",
      "dbsctrctl record-dvc-push*": "ask",
      "dbsctrctl record-evidence*": "ask",
      "dbsctrctl attach-runtime*": "deny",
      "*/dbsctrctl attach-runtime*": "deny",
      "env *dbsctrctl attach-runtime*": "deny",
      "command *dbsctrctl attach-runtime*": "deny",
      "dbsctrctl review-complete*": "ask",
      "*/dbsctrctl review-complete*": "ask",
      "env *dbsctrctl review-complete*": "ask",
      "command *dbsctrctl review-complete*": "ask",
      "dbsctrctl review-history*": "allow",
      "*/dbsctrctl review-history*": "allow",
      "env *dbsctrctl review-history*": "allow",
      "command *dbsctrctl review-history*": "allow",
      "dbsctrctl review-history-save*": "ask",
      "*/dbsctrctl review-history-save*": "ask",
      "env *dbsctrctl review-history-save*": "ask",
      "command *dbsctrctl review-history-save*": "ask",
      "dbsctrctl review-migrate*": "ask",
      "*/dbsctrctl review-migrate*": "ask",
      "env *dbsctrctl review-migrate*": "ask",
      "command *dbsctrctl review-migrate*": "ask",
      "dbsctrctl review-backup*": "ask",
      "*/dbsctrctl review-backup*": "ask",
      "env *dbsctrctl review-backup*": "ask",
      "command *dbsctrctl review-backup*": "ask",
      "dbsctrctl review-restore*": "ask",
      "*/dbsctrctl review-restore*": "ask",
      "env *dbsctrctl review-restore*": "ask",
      "command *dbsctrctl review-restore*": "ask",
      "dbsctrctl review-prune*": "ask",
      "*/dbsctrctl review-prune*": "ask",
      "env *dbsctrctl review-prune*": "ask",
      "command *dbsctrctl review-prune*": "ask",
      "dbsctrctl review-forget*": "ask",
      "*/dbsctrctl review-forget*": "ask",
      "env *dbsctrctl review-forget*": "ask",
      "command *dbsctrctl review-forget*": "ask",
      "dbsctrctl cleanup*": "ask",
      "herdr server stop*": "ask",
      "herdr config reset-keys*": "ask",
      "herdr worktree remove*": "ask",
      "herdr workspace close*": "ask",
      "herdr pane close*": "ask",
      "herdr tab close*": "ask",
      "herdr session stop*": "ask",
      "herdr session delete*": "ask",
      "git reset --hard*": "ask",
      "git clean *": "ask",
      "gh *": "ask",
      "aws *": "ask",
      "npm install*": "ask",
      "npm publish*": "ask",
      "dvc push*": "ask",
      "chezmoi apply*": "ask",
      "launchctl bootstrap*": "ask",
      "launchctl bootout*": "ask"
    }
  },
  "experimental": {
    "policies": [
      { "effect": "deny", "action": "provider.use", "resource": "anthropic" }
    ]
  }
}
