#!/usr/bin/env python3
import json
import os
import subprocess
import tempfile
from pathlib import Path

DBSCTRCTL = os.environ.get("DBSCTRCTL", {{ printf "%s/.local/bin/dbsctrctl" .chezmoi.homeDir | quote }})
HERDR = os.environ.get("HERDR", {{ .dotfiles_ai.herdr.executable | quote }})
GH = os.environ.get("GH", "gh")
GITHUB_ACCOUNT = {{ .dotfiles_ai.hermes.github_account | quote }}
GITHUB_REPOSITORY = {{ .dotfiles_ai.hermes.github_repository | quote }}
REVIEW_WORKDIR = Path({{ .dotfiles_ai.hermes.review_workdir | quote }}).resolve()
STATE = Path(os.environ.get("DBSCTR_WATCHDOG_STATE", {{ printf "%s/.local/state/dotfiles-ai/hermes-watchdog.json" .chezmoi.homeDir | quote }}))
TERMINAL = {"merged", "closed", "abandoned"}


def command(argv):
    return json.loads(subprocess.run(argv, check=True, text=True, capture_output=True).stdout)


def managed_cwd(value):
    if not isinstance(value, str):
        return False
    return Path(value).resolve() == REVIEW_WORKDIR


workers = command([DBSCTRCTL, "improvement-status"])["workers"]
token = None
pr_failures = set()
for index, worker in enumerate(workers):
    if worker["state"] != "draft_pr" or not worker.get("pr_url"):
        continue
    try:
        if token is None:
            token = subprocess.run(
                [GH, "auth", "token", "--hostname", "github.com", "--user", GITHUB_ACCOUNT],
                check=True, text=True, capture_output=True,
            ).stdout.strip()
            if not token:
                raise RuntimeError("configured GitHub account returned no token")
        result = subprocess.run(
            [GH, "pr", "view", worker["pr_url"], "--repo", GITHUB_REPOSITORY, "--json", "state,isDraft"],
            check=True, text=True, capture_output=True, env={**os.environ, "GH_TOKEN": token},
        )
        pull_request = json.loads(result.stdout)
        if not isinstance(pull_request, dict):
            raise RuntimeError("GitHub pull request response is not an object")
        state = {"MERGED": "merged", "CLOSED": "closed"}.get(pull_request.get("state"))
        if state:
            worker = command([DBSCTRCTL, "improvement-update", "--worker-id", worker["worker_id"], "--state", state])
            workers[index] = worker
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError, RuntimeError):
        pr_failures.add(worker["worker_id"])

agents = command([HERDR, "agent", "list"])
agents = agents.get("result", agents).get("agents", [])
actionable = []
for worker in workers:
    if worker["state"] in TERMINAL:
        continue
    if worker["worker_id"] in pr_failures:
        actionable.append({"worker_id": worker["worker_id"], "state": worker["state"],
                           "status": "pr_check_failed", "recovery_attempts": worker["recovery_attempts"]})
    matches = [agent for agent in agents if agent.get("agent_session", {}).get("value") == worker["session_id"]]
    if not matches and worker.get("pane_id") and worker.get("tab_id") and worker.get("workspace_id"):
        recorded = [agent for agent in agents
                    if agent.get("pane_id") == worker["pane_id"]
                    and agent.get("tab_id") == worker["tab_id"]
                    and agent.get("workspace_id") == worker["workspace_id"]
                    and managed_cwd(agent.get("foreground_cwd") or agent.get("cwd"))]
        if len(recorded) == 1:
            try:
                panes = command([HERDR, "pane", "list", "--workspace", worker["workspace_id"]])
                panes = panes.get("result", panes).get("panes", [])
                tab_panes = [pane for pane in panes if pane.get("tab_id") == worker["tab_id"]]
                info = command([HERDR, "pane", "process-info", "--pane", worker["pane_id"]])
                processes = info.get("result", info).get("process_info", {}).get("foreground_processes", [])
                expected = ["opencode", "-s", worker["session_id"], "--agent", "build"]
                if ([pane.get("pane_id") for pane in tab_panes] == [worker["pane_id"]]
                        and sum(process.get("argv") == expected for process in processes) == 1):
                    matches = recorded
            except (OSError, subprocess.CalledProcessError, json.JSONDecodeError):
                pass
    status = matches[0].get("agent_status", "unknown") if len(matches) == 1 else (
        "missing" if not matches else "ambiguous"
    )
    if status in {"missing", "ambiguous", "blocked", "idle", "done", "unknown"}:
        actionable.append({"worker_id": worker["worker_id"], "state": worker["state"],
                           "status": status, "recovery_attempts": worker["recovery_attempts"]})

payload = json.dumps(actionable, sort_keys=True, separators=(",", ":"))
previous = STATE.read_text(encoding="utf-8") if STATE.is_file() else None
STATE.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
os.chmod(STATE.parent, 0o700)
descriptor, temporary = tempfile.mkstemp(prefix=".hermes-watchdog-", dir=STATE.parent)
try:
    with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
        handle.write(payload)
        handle.flush()
        os.fsync(handle.fileno())
    os.chmod(temporary, 0o600)
    os.replace(temporary, STATE)
finally:
    Path(temporary).unlink(missing_ok=True)

urgent = any(item["status"] == "missing" and item["state"] != "blocked"
             and item["recovery_attempts"] < 3 for item in actionable)
if actionable and (urgent or payload != previous):
    print(json.dumps({"wakeAgent": True, "context": {"workers": actionable}}, separators=(",", ":")))
else:
    print('{"wakeAgent":false}')
